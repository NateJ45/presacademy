# Sanity Studio environment (gitignored as .env). Copy to studio/.env and fill in
# after creating the project at sanity.io/manage.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production

# The deployed site URL, used by the Studio's preview links once the site is live.
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
