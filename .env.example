# Copy this file to `.env` and fill in real values for local dev.
# In production, set these in Cloudflare → Workers & Pages → your project → Settings → Variables.
#
# Leave PUBLIC_SANITY_PROJECT_ID unset (or empty) to build with empty content;
# pages will render their empty-state fallbacks. No Sanity project is required
# to clone and build this starter.

# ── Sanity ────────────────────────────────────────────────────────────────────
# Create a project at sanity.io/manage, then paste its project ID here.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2026-05-01

# Read token — bypasses Sanity's anonymous API filter so the full dataset is
# readable at build time. Create at sanity.io/manage → your project → API → Tokens
# with Viewer (read-only) permission. Mark as Secret in Cloudflare.
SANITY_API_READ_TOKEN=

# Write token — only needed for seed/import scripts (e.g. npm run seed:*).
# Create with Editor permission. Never expose as PUBLIC_.
SANITY_API_WRITE_TOKEN=

# ── Sanity Studio (studio/ directory only) ────────────────────────────────────
# These mirror the Astro-side vars but are read via process.env in the Studio.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
# Your deployed Workers URL for the Studio iframe preview pane.
SANITY_STUDIO_PREVIEW_URL=

# ── Contact form ──────────────────────────────────────────────────────────────
# Without this key the contact form falls back to a no-op + inline notice.
# Get a free key at web3forms.com.
PUBLIC_WEB3FORMS_KEY=

# ── Scheduling ────────────────────────────────────────────────────────────────
# Your Calendly public URL (e.g. https://calendly.com/yourusername).
PUBLIC_CALENDLY_URL=

# ── Cloudflare Web Analytics ──────────────────────────────────────────────────
# Without this token the analytics beacon is omitted (site still works fine).
PUBLIC_CF_ANALYTICS_TOKEN=

# ── Newsletter / ESP ──────────────────────────────────────────────────────────
# Optional build-time override for the newsletter form action URL.
# Prefer setting formActionUrl in Sanity Studio (siteSettings → Newsletter).
PUBLIC_NEWSLETTER_FORM_ACTION=
