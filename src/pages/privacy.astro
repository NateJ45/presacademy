---
// Safe to edit by hand
// Privacy policy page. Fetches the privacyPage singleton from Sanity for the
// body and lastUpdated date. When the doc doesn't exist yet (or Sanity isn't
// reachable), a plain-voice fallback policy is rendered so the page is always
// live and accurate.
//
// Reuses PortableText for the body when Sanity content is present; falls back
// to static HTML copy for the period before the editor publishes the doc.

import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import heroPrivacy from '@/assets/placeholders/study-bible-notebook.jpg';
import PortableTextStatic from '@/components/PortableTextStatic.astro';
import Sections from '@/components/Sections.astro';
import { getPrivacyPage, getSiteSettings } from '@/lib/queries';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';

const [page, siteSettings] = await Promise.all([
  getPrivacyPage().catch(() => null),
  getSiteSettings().catch(() => null),
]);
const settings = resolveSiteSettings(siteSettings);

const title       = page?.seoTitle       ?? `Privacy Policy · ${site.name}`;
const description = page?.seoDescription ?? 'How we handle the information you share when you reach out or subscribe.';

const heroEyebrow  = page?.heroEyebrow  ?? 'Transparency first.';
const heroHeadline = page?.heroHeadline ?? 'Privacy Policy';
const heroSubhead  = page?.heroSubhead  ?? '';

// Format the lastUpdated date from Sanity or fall back to a static string.
function formatDate(d?: string): string {
  if (!d) return '';
  const date = new Date(d);
  if (Number.isNaN(date.getTime())) return '';
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
const lastUpdated = formatDate(page?.lastUpdated);

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Privacy Policy', url: `${site.url}/privacy` },
  ]),
];

// Contact email for the fallback copy
const contactEmail = settings.email;

// Whether to use Sanity body content
const hasSanityBody = Boolean(page?.body);
---

<BaseLayout {title} {description} {schemas} {siteSettings} seoImage={page?.seoImage}>
  {/* Hero — text variant, short height. */}
  <Hero
    eyebrow={heroEyebrow}
    headline={heroHeadline}
    subhead={heroSubhead}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroPrivacy}
    localImageAlt="An open Bible, reading glasses, and a notebook laid out for study"
    headingId="privacy-hero-heading"
    size="short"
  />

  <section class="bg-background" aria-label="Privacy policy">
    <div class="mx-auto max-w-3xl px-m py-section-lg">
      {lastUpdated && (
        <p class="text-xs uppercase tracking-eyebrow text-foreground/80 mb-l">
          Last updated: {lastUpdated}
        </p>
      )}

      {hasSanityBody ? (
        <PortableTextStatic
          value={page!.body}
          className="prose-friendly"
        />
      ) : (
        <div class="space-y-l text-foreground leading-relaxed">
          <p class="text-foreground/80">
            This is the privacy policy for {site.name}. The goal here is to be
            straightforward about what information we collect and why.
          </p>

          <div>
            <h2 class="font-display text-h3 text-foreground mb-s">What gets collected</h2>
            <p class="text-foreground/80">
              When you email the church or send a message through this site, you share your name,
              email address, and whatever details you include. We use that information only to
              respond to you. Nothing else.
            </p>
            <p class="mt-s text-foreground/80">
              If you subscribe to our newsletter, your email address goes to our email provider so
              occasional news from the church can reach you. It is not shared with anyone else.
            </p>
          </div>

          <div>
            <h2 class="font-display text-h3 text-foreground mb-s">What doesn't happen</h2>
            <ul class="list-disc pl-l space-y-1 text-foreground/80">
              <li>Your information is never sold.</li>
              <li>There is no ad targeting or tracking pixels on this site.</li>
              <li>Traffic is measured with Cloudflare Web Analytics, which counts page visits without setting cookies or identifying individual visitors.</li>
            </ul>
          </div>

          <div>
            <h2 class="font-display text-h3 text-foreground mb-s">Unsubscribing from the newsletter</h2>
            <p class="text-foreground/80">
              Every email includes an unsubscribe link at the bottom. Click it and you're off the
              list right away. If you run into any trouble, email directly and it'll be handled
              promptly.
            </p>
          </div>

          <div>
            <h2 class="font-display text-h3 text-foreground mb-s">Questions or data requests</h2>
            <p class="text-foreground/80">
              If you have questions about how your information is handled, or want your data
              removed, reach out at{' '}
              <a
                href={`mailto:${contactEmail}`}
                class="text-link underline underline-offset-2 hover:text-primary transition-colors"
              >
                {contactEmail}
              </a>.
              You'll hear back within a few business days.
            </p>
          </div>

          <p class="text-xs text-muted-foreground border-t border-border-soft pt-l">
            This policy was last reviewed in May 2026 and will be updated if anything meaningful
            changes about how this site handles your data.
          </p>
        </div>
      )}
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />
</BaseLayout>
