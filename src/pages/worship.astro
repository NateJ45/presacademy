---
// Safe to edit by hand for copy + structure changes.
// Worship page. Service time, what to expect, communion, children in worship,
// and how to watch online.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPageHero, getSiteSettings, getWorshipResources } from '@/lib/queries';
import heroWorship from '@/assets/placeholders/place-sanctuary-wooden-pews.jpg';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import { Image } from 'astro:assets';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';
import SanityImage from '@/components/SanityImage.astro';
import ArchOrnament from '@/components/ArchOrnament.astro';
import tiffanyWindows from '@/assets/placeholders/community-welcome-pair.jpg';
import { serviceTime } from '@/lib/serviceTime';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getPageHero('worshipPage').catch(() => null);
const worshipResources = await getWorshipResources(6).catch(() => []);
const settings = resolveSiteSettings(siteSettings);
// Service time derives from the single canonical source (siteSettings.worshipService).
const st = serviceTime(siteSettings?.worshipService);

const fmtDate = (d: string) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '';

const title = page?.seoTitle ?? `Worship · ${site.name}`;
const description =
  page?.seoDescription ??
  'Join us for worship this Sunday. A traditional, liturgical service with communion on the first Sunday of each month. Whoever you are, you are welcome here.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Worship', url: `${site.url}/worship` },
  ]),
];

const pillPrimary =
  'press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] bg-primary text-primary-foreground hover:bg-primary-dark transition-colors';
const pillOutline =
  'press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] border border-primary text-link hover:bg-accent transition-colors';
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'Sunday Worship'}
    headline={page?.heroHeadline ?? "There's a place for you here."}
    subhead={page?.heroSubhead ?? "Whether you're a weekly churchgoer, haven't been in ages, or don't know anything about Christianity, you are welcome at The Presbyterian Academy."}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroWorship}
    localImageAlt="A simple sanctuary with wooden pews set for worship"
    headingId="worship-hero"
    size="short"
  />

  {/* Service at a glance */}
  <section class="surface-warm bg-muted" aria-labelledby="worship-times">
    <div class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 md:grid-cols-[1fr_1.2fr] gap-l md:gap-section-md items-start">
      <div>
        <p class="text-xs uppercase tracking-eyebrow text-foreground/80">{page?.gatherEyebrow ?? 'When we gather'}</p>
        <div class="mt-s mb-m h-px w-12 bg-primary/60" aria-hidden="true"></div>
        <p class="font-display text-h1 text-foreground leading-none">{st.gatherTime}</p>
        <p class="mt-s text-lg text-foreground/85">{st.gatherDay}</p>
        <p class="mt-m text-foreground/80">{settings.addressLine}<br />{settings.cityStateZip}</p>
        <div class="mt-l flex flex-wrap gap-s">
          <a href={page?.gatherDirectionsCta?.externalUrl || '/contact'} class={pillPrimary}>{page?.gatherDirectionsCta?.label || 'Get Directions'}</a>
          <a href={page?.gatherWatchCta?.externalUrl || settings.social.youtube} target="_blank" rel="noopener noreferrer" class={pillOutline}>{page?.gatherWatchCta?.label || 'Watch Online'}</a>
        </div>
      </div>
      <div class="text-foreground/85 text-lg leading-relaxed space-y-m">
        <p>
          {page?.serviceBodyP1 ?? 'Our service follows a traditional, liturgical format, with hymns, spirituals, and anthems led by organ and choir. We celebrate the Eucharist on the first Sunday of each month.'}
        </p>
        <p>
          {page?.serviceBodyP2 ?? 'Come as you are. Casual attire is always welcome. There is no wrong way to be here, and no experience required.'}
        </p>
      </div>
    </div>
  </section>

  {/* Plan your visit — practical first-visit info */}
  <section class="bg-background" aria-labelledby="plan-visit">
    <div class="mx-auto max-w-content px-m py-section-lg">
      <SectionHeading
        eyebrow={page?.planEyebrow ?? 'Planning your first visit?'}
        headline={page?.planHeadline ?? "Here's what to know"}
        headingId="plan-visit"
        align="center"
        class="mx-auto"
      />
      <div class="mt-l grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-m" data-stagger-grid>
        <article class="card-lift rounded-md border border-border-soft bg-card p-l">
          <h3 class="font-display text-h4 text-foreground">{page?.planCard1Title ?? 'Getting here'}</h3>
          <p class="mt-s text-foreground/80 leading-relaxed">{page?.planCard1Body ?? 'We are at 9463 Cincinnati Columbus Rd in downtown West Chester Township, close to public transit, with first-come, first-served free parking.'}</p>
        </article>
        <article class="card-lift rounded-md border border-border-soft bg-card p-l">
          <h3 class="font-display text-h4 text-foreground">{page?.planCard2Title ?? 'What to wear'}</h3>
          <p class="mt-s text-foreground/80 leading-relaxed">{page?.planCard2Body ?? 'Whatever feels right to you. Some dress up, many do not. Come as you are.'}</p>
        </article>
        <article class="card-lift rounded-md border border-border-soft bg-card p-l">
          <h3 class="font-display text-h4 text-foreground">{page?.planCard3Title ?? 'For families'}</h3>
          <p class="mt-s text-foreground/80 leading-relaxed">{page?.planCard3Body ?? "Children are welcome in worship, with a children's message and a cry room if you need it."} <a href={page?.kidsMoreCta?.externalUrl || '/kids'} class="text-link underline underline-offset-2 hover:text-primary-dark transition-colors">{page?.kidsMoreCta?.label || 'More for kids'}</a>.</p>
        </article>
        <article class="card-lift rounded-md border border-border-soft bg-card p-l">
          <h3 class="font-display text-h4 text-foreground">{page?.planCard4Title ?? 'Accessibility'}</h3>
          <p class="mt-s text-foreground/80 leading-relaxed">{page?.planCard4Body ?? 'The sanctuary is accessible. If you need any accommodation to join us, reach out and we will be glad to help.'}</p>
        </article>
      </div>
    </div>
  </section>

  {/* Children in worship */}
  <section class="bg-muted" aria-labelledby="worship-kids">
    <div class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 md:grid-cols-2 gap-l md:gap-section-md items-center">
      <div>
        <SectionHeading
          eyebrow={page?.kidsEyebrow ?? 'Little ones welcome'}
          headline={page?.kidsHeadline ?? 'Children belong in worship'}
          headingId="worship-kids"
        />
        <div class="mt-l text-foreground/85 text-lg leading-relaxed space-y-m">
          <p>
            {page?.kidsBodyP1 ?? "Little ones are part of the worshipping congregation at The Presbyterian Academy, and we welcome their noise and their needs. We keep books, coloring materials, and fidget toys on hand, and there is a children's message during the service."}
          </p>
          <p>
            {page?.kidsBodyP2 ?? 'Need a quieter moment? A cry room with an audio stream of the service is always available.'}
          </p>
        </div>
      </div>
      {page?.childrenImage?.asset ? (
        <SanityImage
          source={page.childrenImage}
          width={1000}
          sizes="(min-width: 768px) 45vw, 100vw"
          alt={page.childrenImage.alt || 'Stained-glass windows in the sanctuary'}
          class="w-full h-auto rounded-md shadow-sm"
        />
      ) : (
        <Image
          src={tiffanyWindows}
          alt="A warm welcome between two people"
          widths={[480, 768, 968]}
          sizes="(min-width: 768px) 45vw, 100vw"
          class="w-full h-auto rounded-md shadow-sm"
        />
      )}
    </div>
  </section>

  {/* Worship resources — bulletins, orders of worship, newsletters (Sanity-driven) */}
  {worshipResources.length > 0 && (
    <section class="bg-background" aria-labelledby="worship-resources">
      <div class="mx-auto max-w-content px-m py-section-lg">
        <SectionHeading
          eyebrow={page?.resourcesEyebrow ?? 'Worship resources'}
          headline={page?.resourcesHeadline ?? 'Bulletins and downloads'}
          headingId="worship-resources"
        />
        <ul class="mt-l grid grid-cols-1 sm:grid-cols-2 gap-m list-none p-0">
          {worshipResources.map((r: any) => {
            const href = r.fileUrl || r.externalUrl;
            return (
              <li class="card-lift rounded-md border border-border-soft bg-card p-l">
                <p class="text-xs uppercase tracking-eyebrow text-foreground/80">
                  {r.type}{r.date ? ` · ${fmtDate(r.date)}` : ''}
                </p>
                <h3 class="mt-s font-display text-h4 text-foreground">{r.title}</h3>
                {r.description && <p class="mt-xs text-foreground/80 leading-relaxed">{r.description}</p>}
                {href && (
                  <a
                    href={href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-s inline-block text-link underline underline-offset-2 hover:text-primary-dark transition-colors"
                  >
                    {r.fileUrl ? 'Download PDF' : 'Open'}
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </div>
    </section>
  )}

  {/* Quote */}
  <section class="bg-muted" aria-label="Reflection">
    <div class="mx-auto max-w-3xl px-m py-section-lg text-center">
      {/* The arch ornament marks the page's one reflective pause, mirroring the
          closing-band treatment in FinalCta. Theme-aware gold via gold-ink. */}
      <ArchOrnament class="mb-m mx-auto text-gold-ink/70" />
      <blockquote class="font-display italic text-h3 text-foreground leading-snug">
        &ldquo;{page?.quoteText ?? 'We are called to an everlasting preoccupation with God.'}&rdquo;
      </blockquote>
      <p class="mt-m text-xs uppercase tracking-eyebrow text-foreground/80">{page?.quoteAttribution ?? 'A.W. Tozer'}</p>
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? "Come and See"}
    headline={page?.finalCtaHeadline ?? "Plan your first visit"}
    subhead={page?.finalCtaSubhead ?? "Have a question before Sunday? We would love to help you feel at home before you arrive."}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Get in Touch', linkType: 'external', externalUrl: '/contact' }}
  />
</BaseLayout>
