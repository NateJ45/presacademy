---
// Safe to edit by hand for copy + structure changes.
// Serve. Ways to serve our neighbors through the church.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getServePage, getSiteSettings } from '@/lib/queries';
import heroServe from '@/assets/placeholders/community-outdoor-gathering.jpg';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import Hero from '@/components/Hero.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getServePage().catch(() => null);
const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? `Serve · ${site.name}`;
const description =
  page?.seoDescription ??
  'Serve alongside The Presbyterian Academy. From our food ministry at the Main Street door to neighborhood gatherings, there are many ways to love our downtown West Chester Township neighbors.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Serve', url: `${site.url}/serve` },
  ]),
];

// Inline fallback. The ways-to-serve cards are editable in Sanity
// (servePage.ways); this const renders when that field is empty, so the page is
// identical until an editor overrides it.
const FALLBACK_WAYS = [
  { name: 'Food ministry', href: '/food', body: 'Help pack and hand out lunch bags, or host a community meal alongside our local partners. This is the heart of how we serve our neighbors.' },
  { name: 'Sunday hospitality', href: '/worship', body: 'Welcome visitors, help with coffee and fellowship, and make sure everyone who walks in feels at home.' },
  { name: 'Neighborhood events', href: '/events', body: 'Lend a hand at gatherings like our annual block party, free and open to all our neighbors.' },
];

const ways = page?.ways?.length ? page.ways : FALLBACK_WAYS;
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'Get Involved'}
    headline={page?.heroHeadline ?? 'Love our neighbors'}
    subhead={page?.heroSubhead ?? 'We are called to love God and our neighbors. Much of that happens right here in downtown West Chester Township.'}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroServe}
    localImageAlt="People gathered together at an outdoor event"
    headingId="serve-hero"
    size="short"
  />

  <section class="bg-background" aria-label="Ways to serve">
    <div class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 md:grid-cols-3 gap-m" data-stagger-grid>
      {ways.map((w) => (
        <a href={w.href} class="card-lift group block rounded-md border border-border-soft bg-card p-l no-underline">
          <h2 class="font-display text-h3 text-foreground group-hover:text-link transition-colors">{w.name}</h2>
          <p class="mt-s text-foreground/85 leading-relaxed">{w.body}</p>
          <span class="mt-m inline-flex items-center gap-xs text-xs uppercase tracking-eyebrow font-semibold text-link">{page?.serveLinkLabel ?? 'Learn more'} <span aria-hidden="true">&rarr;</span></span>
        </a>
      ))}
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.serveCtaEyebrow ?? 'Lend a Hand'}
    headline={page?.serveCtaHeadline ?? 'Ready to get involved?'}
    subhead={page?.serveCtaSubhead ?? 'Tell us where you would like to serve and we will help you find a place to plug in.'}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Get in Touch', linkType: 'external', externalUrl: '/contact' }}
  />
</BaseLayout>
