---
// Safe to edit by hand for copy + structure changes.
// Weddings. Overview, FAQ, and pricing for weddings in the historic sanctuary.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getWeddingsPage, getSiteSettings } from '@/lib/queries';
import heroWeddings from '@/assets/placeholders/place-church-aisle.jpg';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FormBlock from '@/components/FormBlock.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getWeddingsPage().catch(() => null);
const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? `Weddings · ${site.name}`;
const description =
  page?.seoDescription ??
  'Get married in our historic sanctuary. With its stained-glass windows and graceful architecture, it welcomes weddings of all sizes.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Weddings', url: `${site.url}/weddings` },
  ]),
];

// Inline fallbacks. The FAQ + pricing lists are editable in Sanity
// (weddingsPage.weddingFaqs / weddingPricing); these consts render when those
// fields are empty, so the page is identical until an editor overrides them.
const FALLBACK_FAQS = [
  { q: 'Who can get married at The Presbyterian Academy?', a: 'We welcome gay and straight couples. Because the sanctuary is a consecrated space, religious ceremonies must be Christian. Nonreligious ceremonies are welcome as long as they are respectful of the space and its purpose. There is no dress code.' },
  { q: 'What about music?', a: 'Our Music Director\'s services are built into a typical wedding package, which may include our pipe organ and a piano. Recorded music is available too, and our Music Director is glad to help you plan music that fits the space.' },
  { q: 'Can we use our own officiant?', a: 'Yes. We require premarital counseling for couples married in our sanctuary. Our pastor is glad to officiate Christian weddings, and that fee is waived for members of the congregation.' },
  { q: 'Can we celebrate communion?', a: 'Ordained clergy from our tradition and similar church bodies may preside at communion with the special permission of the church leadership. Ask us early and we will help you plan.' },
  { q: 'How many guests can the sanctuary hold?', a: 'The main floor of the sanctuary seats 600 people, with additional balcony seating should you need it.' },
  { q: 'What support and spaces are included?', a: 'A Wedding Coordinator assists at the rehearsal and the ceremony. Comfortable dressing rooms are included for preparation. On-site parking is available, with more public options nearby, and the sanctuary is accessible.' },
  { q: 'Is there space for a reception?', a: 'Our Fellowship Hall may be rented for an additional fee. Please note that it is a carpeted space.' },
];

const FALLBACK_PRICING = [
  { item: 'Standard package (rehearsal plus 3 hours of wedding-day use)', price: '$1,500' },
  { item: 'Officiant', price: '$500' },
  { item: 'Premarital counseling only', price: '$250' },
  { item: 'Live stream of the ceremony', price: '$250' },
];

const faqs = page?.weddingFaqs?.length ? page.weddingFaqs : FALLBACK_FAQS;
const pricing = page?.weddingPricing?.length ? page.weddingPricing : FALLBACK_PRICING;

---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'Weddings'}
    headline={page?.heroHeadline ?? 'Get married in our historic sanctuary'}
    subhead={page?.heroSubhead ?? 'Our historic sanctuary, with its stained-glass windows and graceful architecture, is a beautiful place to begin a marriage. We host weddings of every size.'}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroWeddings}
    localImageAlt="A church aisle leading toward the front"
    headingId="weddings-hero"
    size="short"
  />

  {/* FAQ */}
  <section class="bg-background" aria-labelledby="weddings-faq">
    <div class="mx-auto max-w-3xl px-m py-section-lg">
      <SectionHeading eyebrow={page?.faqEyebrow ?? 'The details'} headline={page?.faqHeadline ?? 'Common questions'} headingId="weddings-faq" />
      <div class="mt-l divide-y divide-border-soft border-t border-b border-border-soft">
        {faqs.map((f) => (
          <details class="group py-m">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-m font-display text-h4 text-foreground">
              {f.q}
              <span class="shrink-0 text-link transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-s text-foreground/85 leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* Pricing */}
  <section class="surface-warm bg-muted" aria-labelledby="weddings-pricing">
    <div class="mx-auto max-w-3xl px-m py-section-lg">
      <SectionHeading eyebrow={page?.pricingEyebrow ?? 'Pricing'} headline={page?.pricingHeadline ?? 'Clear and upfront'} headingId="weddings-pricing" align="center" class="mx-auto" />
      <ul class="mt-l list-none p-0 divide-y divide-border-soft border-t border-b border-border-soft">
        {pricing.map((p) => (
          <li class="flex items-baseline justify-between gap-m py-m">
            <span class="text-foreground">{p.item}</span>
            <span class="font-display text-h4 text-foreground shrink-0">{p.price}</span>
          </li>
        ))}
      </ul>
      <p class="mt-m text-sm text-foreground/70 text-center">{page?.pricingFootnote ?? 'The Fellowship Hall is available for receptions at an additional fee.'}</p>
    </div>
  </section>

  {/* Inquiry form (configurable in Sanity; falls back to a mailto when none is set) */}
  <section class="bg-background" aria-labelledby="weddings-inquire">
    <div class="mx-auto max-w-3xl px-m py-section-lg">
      <SectionHeading
        eyebrow={page?.inquireEyebrow ?? 'Say Hello'}
        headline={page?.inquireHeadline ?? 'Inquire about your date'}
        headingId="weddings-inquire"
        align="center"
        class="mx-auto"
      />
      <p class="mt-m text-lg text-foreground/85 leading-relaxed text-center">
        {page?.inquireIntro ?? 'Tell us a little about your day and we will be in touch to check availability and answer your questions.'}
      </p>
      <div class="mt-l">
        <FormBlock form={page?.inquiryForm} fallbackEmail={settings.email} fallbackLabel="Inquire About Your Date" />
      </div>
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? "Say Hello"}
    headline={page?.finalCtaHeadline ?? "Let's talk about your wedding"}
    subhead={page?.finalCtaSubhead ?? "Reach out to the office to check availability and start planning your day at The Presbyterian Academy."}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Contact the Office', linkType: 'external', externalUrl: '/contact' }}
  />
</BaseLayout>
