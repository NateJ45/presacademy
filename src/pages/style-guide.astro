---
// Safe to edit by hand
// INTERNAL STYLE GUIDE / BRAND REFERENCE (the "secret" page).
// A single living overview of the whole design system: every color token (light
// + dark), the fonts, the type scale, spacing / radius / motion tokens, the
// eyebrow rubric signature, and example components. Built FROM the design system
// so it doubles as a smoke test: toggle the header theme switch and the page
// re-skins itself.
//
// It is deliberately "secret": noindex (BaseLayout noindex prop), excluded from
// the sitemap (astro.config.mjs filter), and not linked from any nav. Reach it
// by typing the URL: /style-guide.
//
// Values mirror src/styles/globals.css. If a token changes there, update it here.

import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';

// ---- Color tokens, grouped. light/dark are the literal values in globals.css.
const colorGroups = [
  {
    title: 'Surfaces',
    note: 'Near-white warm paper, not stark white and not the old cream.',
    rows: [
      { name: 'Page surface', token: 'bg-background', light: '#FAF8F4', dark: '#1E1A17', role: 'The paper the whole site sits on.' },
      { name: 'Card / raised', token: 'bg-card', light: '#FFFFFF', dark: '#2A2420', role: 'Cards, popovers; lifts above the page.' },
      { name: 'Muted / alt band', token: 'bg-muted', light: '#F1F0EB', dark: '#262019', role: 'Quiet alternating section bands.' },
      { name: 'Hover surface', token: 'bg-accent', light: '#ECEAE3', dark: '#2E2820', role: 'Subtle hover fill (toggle, menu, outline buttons).' },
    ],
  },
  {
    title: 'Ink',
    note: 'Soft warm near-black, never pure #000.',
    rows: [
      { name: 'Ink (text)', token: 'text-foreground', light: '#1F1B18', dark: '#F1EAD9', role: 'Body and headings.' },
      { name: 'Muted text', token: 'text-muted-foreground', light: '#55514A', dark: '#B7AC9A', role: 'Secondary text, meta, captions.' },
    ],
  },
  {
    title: 'Brand green — the anchor',
    note: 'Deep Reformed forest green. Replaces oxblood as the lead color.',
    rows: [
      { name: 'Geneva Green', token: 'bg-primary', light: '#33503F', dark: '#33503F', role: 'Primary CTA fill (white text), static both themes.' },
      { name: 'Interactive green', token: '--primary / ring / link', light: '#33503F', dark: '#74A98A', role: 'Links, nav underline, focus ring, keyword emphasis. Lifts on the dark page.' },
      { name: 'Green Deep', token: '--color-primary-dark', light: '#2A4233', dark: '#2A4233', role: 'Hover / pressed anchor; deepest green text.' },
    ],
  },
  {
    title: 'Structural green band (chapel)',
    note: 'The footer + closing-CTA band. Static across themes. (Token name kept from the old oxblood band; it now carries green.)',
    rows: [
      { name: 'Band green', token: 'bg-chapel', light: '#2A4233', dark: '#2A4233', role: 'Footer + closing CTA fill.' },
      { name: 'Band green deepest', token: 'bg-chapel-deep', light: '#1F3227', dark: '#1F3227', role: 'Deeper base of the band gradient (surface-chapel).' },
      { name: 'Band text (cream)', token: 'text-chapel-foreground', light: '#F1EAD9', dark: '#F1EAD9', role: 'Cream text on the green band (about 9:1).' },
    ],
  },
  {
    title: 'Accents',
    note: 'One warm note (brass) and one sparing heritage thread (oxblood).',
    rows: [
      { name: 'Aged Brass', token: 'bg-gold', light: '#A87C3E', dark: '#A87C3E', role: 'Hairline rules and small accents. Green + gold pairing.' },
      { name: 'Oxblood (demoted)', token: '--color-oxblood', light: '#7A2A2C', dark: '#7A2A2C', role: 'A single sparing secondary accent. No longer a field/band.' },
      { name: 'Cloister Stone', token: 'border-secondary', light: '#B7A99B', dark: '#8C7E70', role: 'Quiet warm borders and stone eyebrows.' },
    ],
  },
  {
    title: 'States + lines',
    note: 'Theme-aware so each clears AA in both modes.',
    rows: [
      { name: 'Status green (Open)', token: '--status-success', light: '#2F6B4F', dark: '#6FBF95', role: 'The "Open" course pill.' },
      { name: 'Border', token: 'border-border', light: '#E6E3DB', dark: 'rgba(255,255,255,.12)', role: 'Default 1px borders.' },
      { name: 'Border soft', token: 'border-border-soft', light: '#EAE7DF', dark: 'rgba(255,255,255,.14)', role: 'Faint dividers and hairlines.' },
      { name: 'Brass as text', token: 'text-gold-ink', light: '#6E5128', dark: '#C9A06A', role: 'Brass used as readable TEXT (deepened for AA).' },
    ],
  },
];

// ---- Type scale (display sizes from globals.css).
const typeScale = [
  { name: 'Display H1', cls: 'font-display text-h1 leading-headline-tight text-foreground', meta: 'Fraunces · text-h1 · clamp(2.5–5rem) · weight 400', sample: 'Theological depth' },
  { name: 'H2', cls: 'font-display text-h2 text-foreground', meta: 'Fraunces · text-h2 · clamp(2–3rem)', sample: 'Learn something worth knowing' },
  { name: 'H3', cls: 'font-display text-h3 text-foreground', meta: 'Fraunces · text-h3 · clamp(1.5–2rem)', sample: 'A few courses to begin with' },
  { name: 'H4', cls: 'font-display text-h4 text-foreground', meta: 'Fraunces · text-h4 · clamp(1.25–1.5rem)', sample: 'Reading the Bible as one story' },
  { name: 'Italic moment', cls: 'font-display italic text-2xl text-foreground/90', meta: 'Fraunces italic · epigraphs / pull-quotes only', sample: 'Taught for ordinary believers.' },
  { name: 'Body (lead)', cls: 'text-lg text-foreground/80', meta: 'Source Sans 3 · 1.125rem · leading-relaxed', sample: 'Reformed formation for the people who actually lead the church: elders, teachers, and the lifelong curious.' },
  { name: 'Body', cls: 'text-base text-foreground/80', meta: 'Source Sans 3 · 1rem', sample: 'In person, in cohorts, at a pace that fits a working life.' },
];

// ---- Spacing / radius / motion reference.
const spacing = [
  { token: '--spacing-xs', value: 'clamp(.25–.5rem)' },
  { token: '--spacing-s', value: 'clamp(.5–1rem)' },
  { token: '--spacing-m', value: 'clamp(1–1.5rem)' },
  { token: '--spacing-l', value: 'clamp(2–3rem)' },
  { token: 'py-section-md', value: 'clamp(3–5rem)' },
  { token: 'py-section-lg', value: 'clamp(4–7rem)' },
  { token: 'max-w-content', value: '82.5rem' },
];
const motion = [
  { token: 'Default ease', value: 'cubic-bezier(.16,1,.3,1)' },
  { token: 'Default duration', value: '440ms' },
  { token: 'Scroll reveal', value: '600ms · [data-reveal]' },
  { token: 'Radius', value: '--radius 0.5rem' },
  { token: 'Arch radius (retired)', value: 'clamp(.5–.85rem)' },
  { token: 'Reduced motion', value: 'all idioms honor it' },
];
---

<BaseLayout
  title="Style guide (internal)"
  description="Internal brand reference for The Presbyterian Academy."
  noindex
>
  <div class="mx-auto max-w-content px-m py-section-md">
    {/* Intro */}
    <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Internal reference</p>
    <h1 class="mt-2 font-display text-h1 leading-headline-tight text-foreground">The brand, at a glance</h1>
    <p class="mt-m max-w-2xl text-lg text-foreground/80 leading-relaxed">
      Every color, font, token, and core component in one place. This page is built from the live
      design system, so the header theme switch re-skins it. It is not linked anywhere and is hidden
      from search. Direction A: green-anchored bookish minimalism.
    </p>
    <div class="mt-l h-px w-full bg-gold/50"></div>

    {/* ---- COLORS ---- */}
    <section class="mt-section-md" aria-label="Color tokens">
      <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Color</p>
      <h2 class="mt-2 font-display text-h2 text-foreground">Palette &amp; tokens</h2>
      <p class="mt-s text-sm text-muted-foreground">Each chip shows the literal value: <strong>L</strong> = light mode, <strong>D</strong> = dark mode.</p>

      <div class="mt-l grid gap-l sm:grid-cols-2">
        {colorGroups.map((group) => (
          <div class="rounded-lg border border-border-soft bg-card p-l">
            <h3 class="font-display text-h5 text-foreground">{group.title}</h3>
            <p class="mt-1 text-xs text-muted-foreground leading-relaxed">{group.note}</p>
            <ul class="mt-m space-y-3 list-none p-0">
              {group.rows.map((row) => (
                <li class="flex items-start gap-3">
                  <div class="flex shrink-0 gap-1" aria-hidden="true">
                    <span class="block h-9 w-9 rounded-md border border-foreground/15" style={`background:${row.light}`} title={`Light ${row.light}`}></span>
                    <span class="block h-9 w-9 rounded-md border border-foreground/15" style={`background:${row.dark}`} title={`Dark ${row.dark}`}></span>
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-medium text-foreground leading-tight">{row.name}</p>
                    <p class="font-mono text-xs text-muted-foreground">
                      <code>{row.token}</code> · L {row.light} · D {row.dark}
                    </p>
                    <p class="mt-0.5 text-xs text-foreground/70 leading-snug">{row.role}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    {/* ---- TYPOGRAPHY ---- */}
    <section class="mt-section-lg" aria-label="Typography">
      <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Type</p>
      <h2 class="mt-2 font-display text-h2 text-foreground">Typography</h2>
      <div class="mt-m grid gap-m sm:grid-cols-2">
        <div class="rounded-lg border border-border-soft bg-card p-l">
          <p class="text-xs uppercase tracking-eyebrow text-muted-foreground">Display</p>
          <p class="mt-2 font-display text-4xl text-foreground">Fraunces</p>
          <p class="mt-1 text-sm text-muted-foreground">Variable serif. Headings at weight 400, tight tracking. Italic reserved for epigraphs.</p>
          <p class="mt-3 font-display text-2xl text-foreground">Aa Bb Cc · 0123456789 · &amp; ?!</p>
        </div>
        <div class="rounded-lg border border-border-soft bg-card p-l">
          <p class="text-xs uppercase tracking-eyebrow text-muted-foreground">Body</p>
          <p class="mt-2 text-4xl text-foreground">Source Sans 3</p>
          <p class="mt-1 text-sm text-muted-foreground">Humanist sans. Body, UI, eyebrows, meta.</p>
          <p class="mt-3 text-2xl text-foreground">Aa Bb Cc · 0123456789 · &amp; ?!</p>
        </div>
      </div>

      <div class="mt-l space-y-l rounded-lg border border-border-soft bg-card p-l">
        {typeScale.map((t) => (
          <div class="grid gap-1 sm:grid-cols-[1fr_auto] sm:items-baseline">
            <div class={t.cls}>{t.sample}</div>
            <p class="font-mono text-xs text-muted-foreground sm:text-right">{t.meta}</p>
          </div>
        ))}
      </div>
    </section>

    {/* ---- THE EYEBROW RUBRIC (signature) ---- */}
    <section class="mt-section-lg" aria-label="Eyebrow rubric">
      <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Signature</p>
      <h2 class="mt-2 font-display text-h2 text-foreground">The eyebrow rubric</h2>
      <p class="mt-s max-w-2xl text-foreground/80 leading-relaxed">
        The distinctive mark, replacing the retired Romanesque arch. A short brand-green leading rule
        before every section and hero eyebrow. On dark, green, or photo surfaces it lifts to brass
        (<code class="font-mono text-sm">.eyebrow-inverse</code>) so it stays visible.
      </p>
      <div class="mt-l grid gap-m sm:grid-cols-2">
        <div class="rounded-lg border border-border-soft bg-card p-l">
          <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">On paper</p>
          <p class="mt-2 font-mono text-xs text-muted-foreground">.eyebrow · green rule</p>
        </div>
        <div class="surface-chapel rounded-lg p-l">
          <p class="eyebrow eyebrow-inverse text-xs uppercase tracking-eyebrow text-chapel-foreground/85">On the green band</p>
          <p class="mt-2 font-mono text-xs text-chapel-foreground/70">.eyebrow.eyebrow-inverse · brass rule</p>
        </div>
      </div>
    </section>

    {/* ---- COMPONENTS ---- */}
    <section class="mt-section-lg" aria-label="Components">
      <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Components</p>
      <h2 class="mt-2 font-display text-h2 text-foreground">Example components</h2>

      {/* Buttons */}
      <h3 class="mt-l font-display text-h5 text-foreground">Buttons</h3>
      <div class="mt-m flex flex-wrap items-center gap-3">
        <button type="button" class="press-tactile inline-flex items-center rounded-full bg-primary px-l py-s text-xs font-semibold uppercase tracking-eyebrow text-primary-foreground transition-colors hover:bg-primary-dark">Browse courses</button>
        <button type="button" class="press-tactile inline-flex items-center rounded-full border border-foreground px-l py-s text-xs font-semibold uppercase tracking-eyebrow text-foreground transition-colors hover:bg-accent">Book a free intro</button>
        <a href="/style-guide" class="text-sm text-link underline underline-offset-4 hover:text-primary-dark">A text link</a>
      </div>

      {/* Pills / badges */}
      <h3 class="mt-l font-display text-h5 text-foreground">Pills &amp; badges</h3>
      <div class="mt-m flex flex-wrap items-center gap-3">
        <span class="inline-flex items-center rounded-full border border-status-success/40 px-3 py-1 text-xs font-semibold uppercase tracking-eyebrow text-status-success">Open</span>
        <span class="inline-flex items-center rounded-full bg-gold/15 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-eyebrow text-gold-ink">Scripture</span>
        <span class="inline-flex items-center rounded-full bg-muted px-3 py-1 text-xs uppercase tracking-eyebrow text-muted-foreground">Fall 2026</span>
      </div>

      {/* Cards */}
      <h3 class="mt-l font-display text-h5 text-foreground">Card</h3>
      <div class="mt-m grid gap-l sm:grid-cols-2">
        <article class="card-lift rounded-lg border border-border-soft bg-card p-l">
          <div class="flex items-center justify-between">
            <span class="text-xs uppercase tracking-eyebrow text-gold-ink">Scripture</span>
            <span class="inline-flex items-center rounded-full border border-status-success/40 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-eyebrow text-status-success">Open</span>
          </div>
          <h4 class="mt-3 font-display text-h4 text-foreground">Reading the Bible as One Story</h4>
          <p class="mt-1 text-sm text-foreground/70">The Rev. Dr. Miriam Hale</p>
          <p class="mt-3 text-sm text-foreground/80">Fall 2026 · 8 sessions · $195, audit $95</p>
        </article>
        <article class="card-lift rounded-lg border border-border-soft bg-card p-l">
          <span class="text-xs uppercase tracking-eyebrow text-gold-ink">Faculty</span>
          <h4 class="mt-3 font-display text-h4 text-foreground">An ordained minister and scholar</h4>
          <p class="mt-2 text-sm text-foreground/80 leading-relaxed">Cards lift on hover (.card-lift), with a soft border and serif title.</p>
        </article>
      </div>

      {/* SectionHeading component, both tones */}
      <h3 class="mt-l font-display text-h5 text-foreground">SectionHeading component</h3>
      <div class="mt-m rounded-lg border border-border-soft bg-card p-l">
        <SectionHeading
          eyebrow="What we believe"
          headline="Confessional, and warm about it"
          subhead="The shared section-heading pattern: the eyebrow rubric, a serif headline, an optional lede."
          headingId="sg-section-default"
        />
      </div>

      {/* Green structural band */}
      <h3 class="mt-l font-display text-h5 text-foreground">Structural green band</h3>
      <div class="mt-m overflow-hidden rounded-lg">
        <div class="surface-chapel px-l py-section-md text-center">
          <p class="eyebrow eyebrow-inverse mx-auto inline-flex text-xs uppercase tracking-eyebrow text-chapel-foreground/80">Begin your formation</p>
          <p class="mt-3 font-display text-h3 text-chapel-foreground">Tell us what you want to learn</p>
          <div class="mt-l flex justify-center">
            <button type="button" class="press-tactile inline-flex items-center rounded-full bg-chapel-foreground px-l py-s text-xs font-semibold uppercase tracking-eyebrow text-chapel transition-opacity hover:opacity-90">Request information</button>
          </div>
        </div>
      </div>
    </section>

    {/* ---- TOKENS: spacing / motion ---- */}
    <section class="mt-section-lg" aria-label="Spacing and motion tokens">
      <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Tokens</p>
      <h2 class="mt-2 font-display text-h2 text-foreground">Spacing, radius &amp; motion</h2>
      <div class="mt-m grid gap-m sm:grid-cols-2">
        <div class="rounded-lg border border-border-soft bg-card p-l">
          <p class="text-xs uppercase tracking-eyebrow text-muted-foreground">Spacing &amp; layout</p>
          <dl class="mt-3 space-y-2">
            {spacing.map((s) => (
              <div class="flex items-baseline justify-between gap-4">
                <dt class="font-mono text-xs text-foreground">{s.token}</dt>
                <dd class="font-mono text-xs text-muted-foreground">{s.value}</dd>
              </div>
            ))}
          </dl>
        </div>
        <div class="rounded-lg border border-border-soft bg-card p-l">
          <p class="text-xs uppercase tracking-eyebrow text-muted-foreground">Radius &amp; motion</p>
          <dl class="mt-3 space-y-2">
            {motion.map((m) => (
              <div class="flex items-baseline justify-between gap-4">
                <dt class="font-mono text-xs text-foreground">{m.token}</dt>
                <dd class="font-mono text-xs text-muted-foreground">{m.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>

    {/* ---- RETIRED ---- */}
    <section class="mt-section-lg" aria-label="Retired">
      <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">For the record</p>
      <h2 class="mt-2 font-display text-h2 text-foreground">Retired in Direction A</h2>
      <ul class="mt-m max-w-2xl space-y-2 text-foreground/80">
        <li class="flex gap-2"><span class="text-gold-ink" aria-hidden="true">&times;</span> The Romanesque arch crop (<code class="font-mono text-sm">--arch-radius</code> neutralized to a quiet rounding).</li>
        <li class="flex gap-2"><span class="text-gold-ink" aria-hidden="true">&times;</span> The 4% paper-grain texture (<code class="font-mono text-sm">body::before</code> opacity 0).</li>
        <li class="flex gap-2"><span class="text-gold-ink" aria-hidden="true">&times;</span> Oxblood as a structural field / band color (demoted to a sparing accent).</li>
        <li class="flex gap-2"><span class="text-gold-ink" aria-hidden="true">&times;</span> The calligraphic script accent (off by default; no script font loads).</li>
      </ul>
    </section>
  </div>
</BaseLayout>
