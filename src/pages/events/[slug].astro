---
// Safe to edit by hand for copy + structure changes.
// Event detail page. Built for each event slug in Sanity. Without a Sanity
// project there are no slugs, so no detail pages are generated (the index's
// fallback rhythms render as plain rows instead of links).

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllEventSlugs, getEventBySlug, getEventsPage, getSiteSettings } from '@/lib/queries';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import SanityImage from '@/components/SanityImage.astro';
import PortableText from '@/components/PortableText';
import FinalCta from '@/components/FinalCta.astro';

export async function getStaticPaths() {
  const slugs = await getAllEventSlugs().catch(() => []);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const [event, siteSettings, eventsPage] = await Promise.all([
  getEventBySlug(slug as string),
  getSiteSettings().catch(() => null),
  getEventsPage().catch(() => null),
]);

const settings = resolveSiteSettings(siteSettings);

if (!event) {
  return Astro.redirect('/404');
}

const title = `${event.title} · ${site.name}`;
const description = event.summary ?? `An event at ${site.name}.`;

function whenLabel(ev: any): string {
  if (ev.scheduleLabel) return ev.scheduleLabel;
  if (ev.start) {
    return new Date(ev.start).toLocaleString('en-US', {
      weekday: 'long', month: 'long', day: 'numeric', year: 'numeric',
      hour: 'numeric', minute: '2-digit',
    });
  }
  return '';
}

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Events', url: `${site.url}/events` },
    { name: event.title ?? (slug as string), url: `${site.url}/events/${slug}` },
  ]),
];

// Event JSON-LD when a concrete start date is set.
if (event.start) {
  schemas.push(
    JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Event',
      name: event.title,
      startDate: event.start,
      ...(event.end ? { endDate: event.end } : {}),
      eventStatus: 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      description: event.summary ?? undefined,
      location: {
        '@type': 'Place',
        name: event.location ?? site.name,
        // Build address only from resolved Sanity values; omit fields that
        // are not yet populated rather than emitting placeholder West Chester Township data.
        address: (() => {
          const addr: Record<string, string> = { '@type': 'PostalAddress' };
          if (settings.addressLine) addr.streetAddress = settings.addressLine;
          if (settings.addressLocality) addr.addressLocality = settings.addressLocality;
          if (settings.addressRegion) addr.addressRegion = settings.addressRegion;
          if (settings.postalCode) addr.postalCode = settings.postalCode;
          addr.addressCountry = 'US';
          return addr;
        })(),
      },
      organizer: { '@type': 'Organization', name: site.name, url: site.url },
    }),
  );
}

const pillPrimary =
  'press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] bg-primary text-primary-foreground hover:bg-primary-dark transition-colors';
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <article>
    <header class="bg-background">
      <div class="mx-auto max-w-3xl px-m pt-section-lg pb-l">
        <p class="text-xs uppercase tracking-widest text-foreground/80 mb-s">
          <a href="/events" class="hover:text-primary-dark transition-colors">Events</a>
          {event.category && <span class="mx-xs">·</span>}
          {event.category && <span>{event.category}</span>}
        </p>
        <h1 class="font-display text-h1 text-foreground leading-tight">{event.title}</h1>
        <p class="mt-m text-lg text-foreground/80">{whenLabel(event)}</p>
        {event.location && <p class="mt-xs text-foreground/70">{event.location}</p>}
        {event.summary && <p class="mt-m text-xl text-foreground/85 leading-relaxed">{event.summary}</p>}
        {(event.cost || event.audience) && (
          <p class="mt-m text-foreground/70">{event.cost}{event.cost && event.audience ? ' · ' : ''}{event.audience}</p>
        )}
        {event.registrationUrl && (
          <div class="mt-l">
            <a href={event.registrationUrl} target="_blank" rel="noopener noreferrer" class={pillPrimary}>{event.registrationLabel ?? 'Register'}</a>
          </div>
        )}
        {(event.contactName || event.contactEmail) && (
          <p class="mt-m text-sm text-foreground/70">
            Questions? Contact {event.contactName || 'the office'}{event.contactEmail ? ' at ' : ''}{event.contactEmail && <a href={`mailto:${event.contactEmail}`} class="text-link hover:text-primary-dark underline underline-offset-2">{event.contactEmail}</a>}.
          </p>
        )}
      </div>
    </header>

    {event.image?.asset && (
      <figure class="mx-auto max-w-4xl px-m">
        <SanityImage source={event.image} width={1600} loading="eager" sizes="(min-width: 920px) 896px, 100vw" class="w-full h-auto rounded-md" />
      </figure>
    )}

    {event.description && (
      <div class="mx-auto max-w-3xl px-m py-section-lg">
        {/* Plain rich text — no interactive blocks, so server-rendered with no client JS. */}
        <PortableText value={event.description} className="text-foreground/85 text-lg leading-relaxed" />
      </div>
    )}
  </article>

  <FinalCta
    eyebrow={eventsPage?.detailFinalCtaEyebrow ?? "Want to learn more?"}
    headline={eventsPage?.detailFinalCtaHeadline ?? "Tell us what you want to learn"}
    subhead={eventsPage?.detailFinalCtaSubhead ?? "Request information or book a free intro. No pressure."}
    cta={eventsPage?.detailFinalCta?.label ? eventsPage.detailFinalCta : { label: 'Get started', linkType: 'external', externalUrl: '/get-started' }}
  />
</BaseLayout>
