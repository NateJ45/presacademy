---
// Safe to edit for layout. The BODY TEXT here is a generic orthodox-Protestant
// placeholder statement of faith. Replace it with your congregation's own
// statement, set by the church's leadership (rebrand checklist).

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getBeliefsPage, getSiteSettings } from '@/lib/queries';
import heroBeliefs from '@/assets/tiffany-windows.webp';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getBeliefsPage().catch(() => null);
const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? `What We Believe · ${site.name}`;
const description =
  page?.seoDescription ??
  'What First Church of Springfield believes about humanity, God, and the good news of Jesus Christ, and where we fit and are going as a church.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'What We Believe', url: `${site.url}/what-we-believe` },
  ]),
];

// The three core questions and placeholder answers.
// Each question/answer is editable in Sanity; the backtick fallbacks below
// render when the field is empty.
const beliefs = [
  {
    q: page?.beliefsQ1 ?? `Who is humanity?`,
    a: [
      page?.beliefsQ1A1 ?? `Humanity and all things, seen and unseen, were created by God out of the abundance of the divine love of the Trinity. Humanity is created in God's image, meaning that each person is invested with profound worth and dignity, and charged with authority to care for and serve creation as God does. We do not live out our identity as image-bearers, and like all things, without Christ we are captive to Sin and Death. But because we are created out of God's extraordinary love, Augustine of Hippo says, "Our hearts are restless until they find rest in you."`,
    ],
  },
  {
    q: page?.beliefsQ2 ?? `Who is God?`,
    a: [
      page?.beliefsQ2A1 ?? `God is love, eternally three Persons and one Being. God is Father, Son, and Holy Spirit, each coeternal, consubstantial, and coequal with one another. God is revealed to us in Jesus Christ, who is fully God and fully human, incarnate by the power of the Holy Spirit and the courageous yes of Mary. Because of this, we know God as the One who gives himself. God is holy, complete within himself, all-powerful, all-knowing, and unchanging, and his nature defines the Good.`,
    ],
  },
  {
    q: page?.beliefsQ3 ?? `What is the good news?`,
    a: [
      page?.beliefsQ3A1 ?? `Because of humanity's rebellion against God, all of creation suffers in bondage to the powers of Sin and Death, and all things were spiraling toward destruction. In Christ, God the Son entered creation as a creature, and brought God's miraculous healing, abundance, and truth to real people. He died in sacrifice to take away the sin of the world, and defeated death by rising bodily from the grave. He lives today, human and God, at the right hand of the Father, and will come again to judge the world and reign forever. Jesus is still with us by the power of the Holy Spirit, who is active in this world, continuing what he started long ago. Anyone who believes in Jesus is a new creation, forgiven of all their sin, and looks forward to the hope of resurrection and the promise of eternal life.`,
      page?.beliefsQ3A2 ?? `John of Patmos said this of God's plan for the world to come: "I heard a loud voice from the throne, saying, 'Look! The home of God is among mortals. He will dwell with them, and they will be his peoples, and God himself will be with them and be their God'" (Rev. 21:3).`,
    ],
  },
];

// Where We Fit: our place in the wider Church (placeholder copy).
// Titles and bodies are editable in Sanity; backtick fallbacks render when empty.
const whereWeFit = [
  {
    title: page?.fitCard1Title ?? `Biblical`,
    body: page?.fitCard1Body ?? `We live under the authority of scripture, the true and authoritative witness to the Word of God incarnate, and interpret it by the guiding light of God revealed in Jesus, its true center. The Bible is a collection of various kinds of literature, written in many times by many people, all truly and fully inspired by God the Spirit to tell the one, unified story of God's plan to live among us, enfold us into the Triune love, and make all things new.`,
  },
  {
    title: page?.fitCard2Title ?? `Rooted`,
    body: page?.fitCard2Body ?? `We affirm the ecumenical creeds of the Church. We believe in God's sovereign, providential care for all things, his irrevocable choice to save, and his everlasting covenant promise to be faithful to his people. We celebrate God's glory displayed in creation, salvation, and restoration. We are led by the humble, growing confessions of our tradition, which we accept as a reliable and faithful exposition of what scripture leads us to believe and do.`,
  },
  {
    title: page?.fitCard3Title ?? `Inclusive`,
    body: page?.fitCard3Body ?? `We believe that correctly interpreted, scripture leads us to live out the gospel by the full and sincere welcome of women and LGBTQ people. Accordingly, we do not place restrictions of identity on the Spirit's calling to leadership, and we celebrate the gift of faithful marriage between two people of any gender.`,
  },
];

// Where We're Going: how we live as a congregation (placeholder copy).
// Titles and bodies are editable in Sanity; backtick fallbacks render when empty.
const whereWeGoing = [
  {
    title: page?.goingCard1Title ?? `Neighborhood ministry`,
    body: page?.goingCard1Body ?? `It matters that we were called to be the Church on Main Street, and we are committed to loving our neighbors and preaching the gospel here in downtown Springfield.`,
  },
  {
    title: page?.goingCard2Title ?? `Authentic & joyful worship`,
    body: page?.goingCard2Body ?? `Our congregation loves its music, liturgy, and fellowship. We are seeking to revel in the abundant life of God by offering our praise and thanksgiving and receiving the gifts of Word and Table.`,
  },
  {
    title: page?.goingCard3Title ?? `Warm welcome`,
    body: page?.goingCard3Body ?? `Community is formed in warmth and self-giving. We believe that God is at work drawing people to himself, and we continually prepare to receive, embrace, and grow into the Church of tomorrow, making disciples of all people.`,
  },
];

// Inline fallback. The dig-deeper resource links are editable in Sanity
// (beliefsPage.resources); this const renders when that field is empty, so the
// page is identical until an editor overrides it.
const FALLBACK_RESOURCES = [
  { label: 'Community groups at First Church', href: '/grow', external: false },
  { label: 'Lectio 365', href: 'https://www.24-7prayer.com/resource/lectio-365/', external: true },
  { label: 'BibleProject', href: 'https://bibleproject.com/', external: true },
  { label: 'Practicing the Way', href: 'https://practicingtheway.org/', external: true },
];

const resources = page?.resources?.length ? page.resources : FALLBACK_RESOURCES;
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'What We Believe'}
    headline={page?.heroHeadline ?? 'The faith we share'}
    subhead={page?.heroSubhead ?? 'What we hold to be true about humanity, about God, and about the good news of Jesus Christ.'}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroBeliefs}
    localImageAlt="A stained-glass window at First Church"
    headingId="believe-hero"
    size="short"
  />

  {/* Scripture epigraph + the three core questions (verbatim) */}
  <section class="bg-background" aria-label="What we believe">
    <div class="mx-auto max-w-content px-m py-section-lg">
      <blockquote class="mx-auto max-w-prose text-center">
        <p class="font-display text-h3 leading-snug text-foreground/90">
          {page?.scriptureQuote ?? "“The Word became flesh and dwelt among us, and we have seen his glory, glory as of the only Son from the Father, full of grace and truth.”"}
        </p>
        <cite class="mt-s block text-sm not-italic uppercase tracking-eyebrow text-muted-foreground">{page?.scriptureCitation ?? 'John 1:14'}</cite>
      </blockquote>

      <div class="mt-section-md space-y-section-md">
        {beliefs.map((item) => (
          <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-m md:gap-section-md items-start border-b border-border-soft pb-section-md last:border-b-0 last:pb-0">
            <h2 class="font-display text-h3 text-foreground md:sticky md:top-24">{item.q}</h2>
            <div class="text-foreground/85 text-lg leading-relaxed space-y-m">
              {item.a.map((p) => <p>{p}</p>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Where We Fit */}
  <section class="surface-warm bg-muted" aria-labelledby="fit-heading">
    <div class="mx-auto max-w-content px-m py-section-lg">
      <SectionHeading
        eyebrow={page?.fitEyebrow ?? 'Our place in the Church'}
        headline={page?.fitHeadline ?? 'Where We Fit'}
        headingId="fit-heading"
        align="center"
        class="mx-auto"
      />
      <div class="mt-section-md grid grid-cols-1 md:grid-cols-3 gap-l" data-stagger-grid>
        {whereWeFit.map((b) => (
          <article class="card-lift rounded-md border border-border-soft bg-card p-l">
            <h3 class="font-display text-h3 text-foreground">{b.title}</h3>
            <p class="mt-s text-foreground/85 leading-relaxed">{b.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* Where We're Going */}
  <section class="bg-background" aria-labelledby="going-heading">
    <div class="mx-auto max-w-content px-m py-section-lg">
      <SectionHeading
        eyebrow={page?.goingEyebrow ?? 'Our hope'}
        headline={page?.goingHeadline ?? "Where We're Going"}
        headingId="going-heading"
        align="center"
        class="mx-auto"
      />
      <div class="mt-section-md grid grid-cols-1 md:grid-cols-3 gap-l" data-stagger-grid>
        {whereWeGoing.map((v) => (
          <article class="card-lift rounded-md border border-border-soft bg-card p-l">
            <h3 class="font-display text-h4 text-foreground">{v.title}</h3>
            <p class="mt-s text-foreground/80 leading-relaxed">{v.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* Dig deeper */}
  <section class="surface-warm bg-muted" aria-labelledby="deeper-heading">
    <div class="mx-auto max-w-content px-m py-section-md text-center">
      <h2 id="deeper-heading" class="font-display text-h4 text-foreground">{page?.deeperHeadline ?? 'Want to dig deeper?'}</h2>
      <p class="mt-s text-foreground/80">{page?.deeperIntro ?? 'Explore these resources, and join a community group at First Church.'}</p>
      <ul class="mt-l flex flex-wrap justify-center gap-x-l gap-y-s">
        {resources.map((r) => (
          <li>
            <a
              href={r.href}
              class="text-link underline underline-offset-2 hover:text-primary-dark transition-colors"
              {...(r.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >{r.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? 'Come and See'}
    headline={page?.finalCtaHeadline ?? 'The best way to know us is to worship with us'}
    subhead={page?.finalCtaSubhead ?? 'Join us this Sunday, or reach out with any question about faith and life at First Church.'}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Plan a Visit', linkType: 'external', externalUrl: '/worship' }}
  />
</BaseLayout>
