---
// Safe to edit by hand for copy + structure changes.
// Contact page. Address, phone, email, office hours, who-to-contact, a map,
// and getting-here notes. (A Web3Forms contact form can be added later; for now
// the page surfaces direct contact paths, which is how most visitors reach a church.)

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getContactPage, getSiteSettings } from '@/lib/queries';
import heroContact from '@/assets/placeholders/teach-seminar-discussion.jpg';
import { breadcrumbSchema } from '@/lib/schemas';
import { telHref } from '@/lib/phone';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FormBlock from '@/components/FormBlock.astro';
import { MapPin, Phone, Mail, Clock } from 'lucide-react';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getContactPage().catch(() => null);

// One resolved settings object; every contact value below comes from Sanity via
// this helper, with no hardcoded site.ts fallbacks.
const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? `Contact · ${site.name}`;
const description =
  page?.seoDescription ??
  'Reach The Presbyterian Academy. Address, phone, email, office hours, and how to find the West Chester campus.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Contact', url: `${site.url}/contact` },
  ]),
];

// Address comes from Sanity (siteSettings), resolved into consts so the embedded
// map query and the visible address read the same values.
const addressLine = settings.addressLine;
const cityStateZip = settings.cityStateZip;

const mapQuery = encodeURIComponent(`${addressLine}, ${cityStateZip}`);

// Inline fallback. The who-to-reach rows are editable in Sanity
// (contactPage.contactReasons); this const renders when that field is empty, so
// the page is identical until an editor overrides it. The default emails come
// from Sanity siteSettings (public + pastoral) via the resolver.
const FALLBACK_REASONS = [
  { label: 'General questions', value: settings.email, href: `mailto:${settings.email}` },
  { label: 'Courses and enrollment', value: 'Request information', href: '/get-started' },
  { label: 'Pricing and scholarships', value: 'See pricing', href: '/pricing' },
];

const reasons = page?.contactReasons?.length ? page.contactReasons : FALLBACK_REASONS;
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'Contact'}
    headline={page?.heroHeadline ?? 'Get in touch'}
    subhead={page?.heroSubhead ?? 'Questions about a course, scholarships, or getting started? Here is how to reach us.'}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroContact}
    localImageAlt="A teacher and adult students together in a library"
    headingId="contact-hero"
    size="short"
  />

  <section class="bg-background" aria-label="Contact details">
    <div class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 lg:grid-cols-2 gap-l lg:gap-section-md items-start">
      {/* Details */}
      <div class="space-y-l">
        <ul class="space-y-m list-none p-0 text-lg">
          <li class="flex items-start gap-s">
            <MapPin size={20} aria-hidden="true" className="mt-1 shrink-0 text-primary" />
            <span>{addressLine}<br />{cityStateZip}</span>
          </li>
          <li class="flex items-start gap-s">
            <Phone size={20} aria-hidden="true" className="mt-1 shrink-0 text-primary" />
            <a href={telHref(settings.phone)} class="text-link hover:text-primary-dark underline underline-offset-2 transition-colors">{settings.phone}</a>
          </li>
          <li class="flex items-start gap-s">
            <Mail size={20} aria-hidden="true" className="mt-1 shrink-0 text-primary" />
            <a href={`mailto:${settings.email}`} class="text-link hover:text-primary-dark underline underline-offset-2 transition-colors break-all">{settings.email}</a>
          </li>
          <li class="flex items-start gap-s">
            <Clock size={20} aria-hidden="true" className="mt-1 shrink-0 text-primary" />
            <span>Office hours: {settings.officeHours}</span>
          </li>
        </ul>

        <div class="border-t border-border-soft pt-l">
          <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80 mb-s">{page?.whoToReachLabel ?? 'Who to reach'}</p>
          <ul class="space-y-2 list-none p-0">
            {reasons.map((r) => (
              <li class="flex flex-wrap justify-between gap-m border-b border-border-soft pb-2 last:border-b-0">
                <span class="text-foreground">{r.label}</span>
                <a href={r.href} class="text-link hover:text-primary-dark underline underline-offset-2 transition-colors break-all">{r.value}</a>
              </li>
            ))}
          </ul>
        </div>

        <div class="border-t border-border-soft pt-l text-foreground/80 leading-relaxed">
          <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80 mb-s">{page?.gettingHereLabel ?? 'Getting here'}</p>
          <p>
            {page?.gettingHereBody ?? 'Courses meet in person on the West Chester campus, with free on-site parking. The building is a short drive from the interstate.'}
          </p>
        </div>
      </div>

      {/* Map */}
      <div class="rounded-md overflow-hidden border border-border-soft min-h-[320px] h-full">
        <iframe
          title="Map to The Presbyterian Academy"
          src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
          width="100%"
          height="100%"
          style="min-height: 360px; border: 0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  {/* Contact form (configurable in Sanity; falls back to a mailto when none is set) */}
  <section class="surface-warm bg-muted" aria-labelledby="contact-form">
    <div class="mx-auto max-w-3xl px-m py-section-lg">
      <SectionHeading
        eyebrow={page?.whatToExpectEyebrow ?? 'Send a Note'}
        headline={page?.formSectionHeadline ?? 'Start the conversation'}
        headingId="contact-form"
      />
      {page?.formIntroNote && (
        <p class="mt-m text-lg text-foreground/85 leading-relaxed">{page.formIntroNote}</p>
      )}
      <div class="mt-l">
        <FormBlock form={page?.contactForm} fallbackEmail={settings.email} fallbackLabel="Email the Office" />
      </div>
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? "Ready to begin?"}
    headline={page?.finalCtaHeadline ?? "Tell us what you want to learn"}
    subhead={page?.finalCtaSubhead ?? "Request information or book a free intro. No application fee, no pressure."}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Request information', linkType: 'external', externalUrl: '/get-started' }}
  />
</BaseLayout>
