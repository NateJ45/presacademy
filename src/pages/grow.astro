---
// Safe to edit by hand for copy + structure changes.
// Grow. Community groups: Bible study, Theology on Tap, reading groups.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGrowPage, getSiteSettings } from '@/lib/queries';
import heroGrow from '@/assets/hero-grow.webp';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import Hero from '@/components/Hero.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getGrowPage().catch(() => null);
const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? `Grow · ${site.name}`;
const description =
  page?.seoDescription ??
  'Community groups at First Church: Bible study, Theology on Tap, and reading groups. Drop in and walk with others on the Way of Jesus.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Grow', url: `${site.url}/grow` },
  ]),
];

// Inline fallback. The community-group cards are editable in Sanity
// (growPage.groups); this const renders when that field is empty, so the page
// is identical until an editor overrides it.
const FALLBACK_GROUPS = [
  { name: 'Mid-Morning Bible Study', when: 'First and third Thursdays, 10am', where: 'The Pastor\'s Office', body: 'Read through books of the Bible together over coffee.' },
  { name: 'Theology on Tap', when: 'Third Thursdays, 7pm', where: 'Rotating neighborhood pubs', body: 'Read short pieces of theological writing over drinks and good conversation.' },
  { name: 'Alpha to Omega Bible Reading Group', when: 'Thursdays, 5pm to 6pm', where: 'By conference call', body: 'Read through the whole Bible together, a stretch at a time.' },
  { name: 'First Church Book Group', when: 'Select Sundays, 9:30am', where: 'At the church', body: 'Read and discuss a book together before worship.' },
];

const groups = page?.groups?.length ? page.groups : FALLBACK_GROUPS;
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'Get Involved'}
    headline={page?.heroHeadline ?? 'Community Groups at First Church'}
    subhead={page?.heroSubhead ?? 'Drop in and walk with others on the Way of Jesus.'}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroGrow}
    localImageAlt="Inside the historic sanctuary at First Church"
    headingId="grow-hero"
    size="short"
  />

  <section class="bg-background" aria-label="Community groups">
    <div class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 md:grid-cols-2 gap-m" data-stagger-grid>
      {groups.map((g) => (
        <article class="card-lift rounded-md border border-border-soft bg-card p-l">
          <h2 class="font-display text-h3 text-foreground">{g.name}</h2>
          <p class="mt-xs text-xs uppercase tracking-eyebrow text-foreground/80">{g.when} · {g.where}</p>
          <p class="mt-s text-foreground/85 leading-relaxed">{g.body}</p>
        </article>
      ))}
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? 'Join In'}
    headline={page?.finalCtaHeadline ?? 'Find your people at First Church'}
    subhead={page?.finalCtaSubhead ?? 'Everyone is welcome at every group. Check the calendar for the next gathering, or just show up.'}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'See the Calendar', linkType: 'external', externalUrl: '/events' }}
  />
</BaseLayout>
