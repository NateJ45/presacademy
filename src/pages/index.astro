---
// Safe to edit by hand for copy + structure changes.
// Home page for The Presbyterian Academy (lay school) in the Rule & Ledger
// design language. Section order: split hero with a "next cohort" ledger line ->
// wayfinding ledger -> "Start here" course rail -> stat/heritage band -> course
// catalog preview -> faculty strip -> testimonials -> closing colophon CTA.
//
// Hero/SEO/finalCta copy flows from the homePage singleton with school
// fallbacks; the rails populate from the catalog collections. The hero text
// shows the homePage singleton's current value, so it flips to school copy once
// homePage is reseeded.

import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  getHomePage,
  getSiteSettings,
  getFeaturedCourses,
  getStartHereCourses,
  getFeaturedFaculty,
  getFeaturedTestimonials,
  getNextTerm,
} from '@/lib/queries';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import SanityImage from '@/components/SanityImage.astro';
import CourseCard from '@/components/CourseCard.astro';
import FacultyCard from '@/components/FacultyCard.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const [page, siteSettings, featuredCourses, startHere, featuredFaculty, testimonials, nextTerm] = await Promise.all([
  getHomePage().catch(() => null),
  getSiteSettings().catch(() => null),
  getFeaturedCourses(6).catch(() => []),
  getStartHereCourses().catch(() => []),
  getFeaturedFaculty(3).catch(() => []),
  getFeaturedTestimonials(3).catch(() => []),
  getNextTerm().catch(() => null),
]);
const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? site.name;
const description =
  page?.seoDescription ??
  'Reformed formation taught in person, in cohorts, for the people who lead the church: elders, teachers, small-group hosts, and the lifelong curious.';

const heroEyebrow = page?.heroEyebrow ?? 'The Presbyterian Academy';
const heroHeadline = page?.heroHeadline ?? 'Theological depth, taught for ordinary believers.';
const heroSubhead =
  page?.heroSubhead ??
  'Reformed formation for the people who actually lead the church: elders, teachers, small-group hosts, and the lifelong curious. In person, in cohorts, at a pace that fits a working life.';
const heroImg = (page?.heroImages?.length ? page.heroImages[0] : page?.heroImage) ?? null;

function fmtDate(d?: string): string {
  if (!d) return '';
  return new Date(`${d}T00:00:00`).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
const cityLine = settings.addressLocality ?? 'West Chester, Ohio';

const wayfinding = [
  { n: '01', title: 'Take a course', body: 'Browse the catalog by topic or teacher.', href: '/courses' },
  { n: '02', title: 'Meet the teachers', body: 'Ordained ministers and Reformed scholars.', href: '/faculty' },
  { n: '03', title: 'Find your path', body: 'A starting point for where you are now.', href: '/for-you' },
  { n: '04', title: 'Start free', body: 'Sit in on a class, no commitment.', href: '/get-started' },
];

// Stats for a NEW (2026) school: structure + standards, not a track record.
// No founding year and no alumni counts — the school is brand-new, so historical
// figures would be false. Only the 100% faculty figure counts up.
const stats = [
  { value: '100%', label: 'Ordained or credentialed faculty' },
  { value: 'In person', label: 'Taught in cohorts', count: false },
  { value: 'Need-based', label: 'Scholarships every term', count: false },
  { value: 'Reformed', label: 'Rooted in the Westminster Standards', count: false },
];

const pillPrimary =
  'press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] bg-primary text-primary-foreground hover:bg-primary-dark transition-colors';
const pillGhost =
  'press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] border border-foreground text-foreground hover:bg-accent transition-colors';
---

<BaseLayout {title} {description} {siteSettings}>
  {/* Split hero */}
  <section class="bg-background hero-atmos overflow-hidden" aria-labelledby="home-hero">
    <div class="mx-auto grid max-w-content items-center gap-x-12 gap-y-l px-m py-section-lg lg:grid-cols-[1.05fr_.95fr]">
      <div class="hero-entry-stagger">
        <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">{heroEyebrow}</p>
        <h1 id="home-hero" class="mt-4 font-display text-h1 leading-headline-tight text-foreground">
          <span class="kinetic-words">{heroHeadline.split(' ').map((word: string, i: number) => (
            <><span class="w" style={`--i:${i}`}><span>{word}</span></span>{' '}</>
          ))}</span>
        </h1>
        <p class="mt-m max-w-xl text-lg leading-relaxed text-foreground/80">{heroSubhead}</p>
        <div class="mt-l flex flex-wrap gap-3">
          <a href="/courses" class={pillPrimary}>Browse courses</a>
          <a href="/get-started" class={pillGhost}>Book a free intro</a>
        </div>
        <div class="mt-l h-px w-full bg-gold/50"></div>
        {nextTerm && (
          <p class="mt-4 text-sm text-foreground/75">
            <span class="font-display tabular-nums uppercase tracking-[0.12em] text-gold-ink">Next cohort begins</span>
            &nbsp; {fmtDate(nextTerm.startDate)} &nbsp;·&nbsp; {nextTerm.title} &nbsp;·&nbsp; {cityLine}
          </p>
        )}
      </div>
      <div>
        <div class="h-0.5 w-full bg-gold"></div>
        <div class="img-zoom relative aspect-[4/5] overflow-hidden bg-muted">
          {heroImg?.asset ? (
            <SanityImage source={heroImg} width={900} loading="eager" fetchpriority="high" sizes="(min-width: 1024px) 520px, 90vw" class="h-full w-full object-cover parallax-slow" />
          ) : (
            <div class="image-well h-full w-full parallax-slow"></div>
          )}
        </div>
      </div>
    </div>
  </section>

  {/* Wayfinding ledger */}
  <section class="border-y border-border-soft bg-background" aria-label="Where to begin">
    <div class="mx-auto grid max-w-content grid-cols-1 sm:grid-cols-2 lg:grid-cols-4" data-stagger-grid>
      {wayfinding.map((w, i) => (
        <a href={w.href} class:list={['group block px-m py-l no-underline', i < wayfinding.length - 1 && 'lg:border-r border-border-soft']}>
          <span class="font-display text-sm tabular-nums tracking-[0.12em] text-gold-ink">{w.n}</span>
          <h2 class="mt-2 font-display text-h4 text-foreground transition-colors group-hover:text-link">{w.title}</h2>
          <p class="mt-1 text-sm text-foreground/70">{w.body}</p>
        </a>
      ))}
    </div>
  </section>

  {/* Start here */}
  {startHere.length > 0 && (
    <section class="bg-card" aria-labelledby="home-start">
      <div class="mx-auto max-w-content px-m py-section-md">
        <div data-reveal>
          <p class="eyebrow text-xs uppercase tracking-eyebrow text-gold-ink">Start here</p>
          <h2 id="home-start" class="mt-2 font-display text-h3 text-foreground">A few courses to begin with</h2>
        </div>
        <ul class="mt-l grid grid-cols-1 gap-l sm:grid-cols-2 lg:grid-cols-3" data-stagger-grid>
          {startHere.slice(0, 3).map((c: any) => <CourseCard course={c} />)}
        </ul>
      </div>
    </section>
  )}

  {/* Stat band */}
  <section class="border-b border-border-soft bg-background" aria-label="The Academy at a glance">
    <div class="mx-auto grid max-w-content grid-cols-2 lg:grid-cols-4" data-stagger-grid data-countup-grid>
      {stats.map((s, i) => (
        <div class:list={['px-m py-l', i < stats.length - 1 && 'lg:border-r border-border-soft', i < 2 && 'border-b lg:border-b-0 border-border-soft']}>
          <p class="font-display text-h2 text-chapel-ink tabular-nums" data-countup={s.count === false ? undefined : true}>{s.value}</p>
          <p class="mt-2 text-xs uppercase tracking-eyebrow text-foreground/80">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Topics ticker — a slow marquee of what the Academy teaches. Decorative. */}
  <section class="border-b border-border-soft bg-card" aria-hidden="true">
    <div class="marquee py-3.5">
      <div class="marquee__track">
        {[0, 1].map(() => (
          <div class="marquee__group text-xs uppercase tracking-eyebrow text-foreground/55">
            {['Old Testament', 'Systematic Theology', 'Church History', 'Reformed Worship', 'Biblical Greek', 'Christian Ethics', 'Apologetics', 'Pastoral Care', 'The Confessions', 'Spiritual Formation'].map((topic) => (
              <span class="inline-flex items-center gap-3">{topic}<span class="text-gold-ink">&#10022;</span></span>
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Course catalog preview */}
  {featuredCourses.length > 0 && (
    <section class="bg-background" aria-labelledby="home-courses">
      <div class="mx-auto max-w-content px-m py-section-lg">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div data-reveal>
            <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Courses</p>
            <h2 id="home-courses" class="mt-2 font-display text-h2 text-foreground">Learn something worth knowing</h2>
          </div>
          <a href="/courses" class="link-arrow inline-flex items-center gap-1.5 text-sm uppercase tracking-[0.12em] text-link underline underline-offset-4 hover:text-primary-dark">See all courses<span class="link-arrow__icon" aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="mt-l h-px w-full bg-gold/50"></div>
        <ul class="mt-l grid grid-cols-1 gap-l sm:grid-cols-2 lg:grid-cols-3" data-stagger-grid>
          {featuredCourses.map((c: any) => <CourseCard course={c} />)}
        </ul>
      </div>
    </section>
  )}

  {/* Faculty strip */}
  {featuredFaculty.length > 0 && (
    <section class="surface-warm bg-muted" aria-labelledby="home-faculty">
      <div class="mx-auto max-w-content px-m py-section-lg">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div data-reveal>
            <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">The faculty</p>
            <h2 id="home-faculty" class="mt-2 font-display text-h2 text-foreground">Taught by ministers and scholars</h2>
          </div>
          <a href="/faculty" class="link-arrow inline-flex items-center gap-1.5 text-sm uppercase tracking-[0.12em] text-link underline underline-offset-4 hover:text-primary-dark">Meet the faculty<span class="link-arrow__icon" aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="mt-l h-px w-full bg-gold/50"></div>
        <ul class="mt-l grid grid-cols-1 gap-l md:grid-cols-3" data-stagger-grid>
          {featuredFaculty.map((f: any) => <FacultyCard person={f} />)}
        </ul>
      </div>
    </section>
  )}

  {/* Testimonials */}
  {testimonials.length > 0 && (
    <section class="bg-background" aria-labelledby="home-stories">
      <div class="mx-auto max-w-content px-m py-section-lg">
        <div data-reveal>
          <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">In their words</p>
          <h2 id="home-stories" class="mt-2 font-display text-h2 text-foreground">From the people we serve</h2>
        </div>
        <div class="mt-l h-px w-full bg-gold/50"></div>
        <div class="mt-l grid grid-cols-1 gap-l md:grid-cols-3" data-stagger-grid>
          {testimonials.map((t: any) => (
            <figure class="flex h-full flex-col">
              <blockquote class="font-display text-xl italic leading-relaxed text-foreground/90">{t.quote}</blockquote>
              <figcaption class="mt-auto pt-l">
                <div class="h-px w-full bg-border-soft"></div>
                <p class="mt-3 text-sm font-medium text-foreground">{t.name}</p>
                <p class="text-sm text-foreground/70">{[t.role, t.city].filter(Boolean).join(', ')}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? 'Begin your formation'}
    headline={page?.finalCtaHeadline ?? 'Tell us what you want to learn'}
    subhead={page?.finalCtaSubhead ?? 'We will help you find the right course, point you to a free intro, and answer any question. No application fee, no pressure.'}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Request information', linkType: 'external', externalUrl: '/get-started' }}
  />
</BaseLayout>
