---
// Safe to edit by hand for copy + structure changes.
// Kids. How children and families are welcomed at First Church.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPageHero, getSiteSettings } from '@/lib/queries';
import heroKids from '@/assets/sanctuary-interior.webp';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getPageHero('kidsPage').catch(() => null);
const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? `Kids · ${site.name}`;
const description =
  page?.seoDescription ??
  'Children are part of the worshipping congregation at First Church of Springfield. How we welcome kids and families on Sunday morning.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Kids', url: `${site.url}/kids` },
  ]),
];
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'Get Involved'}
    headline={page?.heroHeadline ?? 'Children are welcome here'}
    subhead={page?.heroSubhead ?? 'At First Church, little ones are part of the worshipping congregation, and we welcome their noise and their needs.'}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroKids}
    localImageAlt="The welcoming nave of First Church"
    headingId="kids-hero"
    size="short"
  />

  <section class="bg-background" aria-labelledby="kids-worship">
    <div class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 md:grid-cols-2 gap-l md:gap-section-md items-start">
      <SectionHeading
        eyebrow={page?.worshipEyebrow ?? 'On Sunday morning'}
        headline={page?.worshipHeadline ?? 'Kids belong in the room'}
        headingId="kids-worship"
      />
      <div class="text-foreground/85 text-lg leading-relaxed space-y-m">
        <p>
          {page?.worshipBodyP1 ?? "We do not tuck children away. They worship right alongside the rest of us, and there is a children's message during the service just for them."}
        </p>
        <p>
          {page?.worshipBodyP2 ?? 'We keep books, coloring materials, and fidget toys on hand. And if you need a quieter moment, a cry room with an audio stream of the service is always open.'}
        </p>
        <p>
          {page?.worshipBodyP3 ?? 'Bringing little ones for the first time? Come as you are. You will not be the only family in the pews, and you will not get any side-eye for the wiggles.'}
        </p>
      </div>
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? "Bring the Whole Family"}
    headline={page?.finalCtaHeadline ?? "We would love to meet your family"}
    subhead={page?.finalCtaSubhead ?? "Join us this Sunday, or reach out with any question about visiting with children."}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Plan a Visit', linkType: 'external', externalUrl: '/worship' }}
  />
</BaseLayout>
