---
// Safe to edit by hand for copy + structure changes.
// Course detail. Built for each course slug in Sanity. The signature Rule &
// Ledger components live here: the "At a glance" facts ledger (term, begins,
// schedule, sessions, format, venue, tuition, apply by) and the numbered session
// list. Dual CTA (express interest / request info) routes to /get-started.
// Without a Sanity project there are no slugs, so no detail pages are generated.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllCourseSlugs, getCourseBySlug, getCoursesPage, getSiteSettings } from '@/lib/queries';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import SanityImage from '@/components/SanityImage.astro';
import FinalCta from '@/components/FinalCta.astro';

export async function getStaticPaths() {
  const slugs = await getAllCourseSlugs().catch(() => []);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const [course, coursesPage, siteSettings] = await Promise.all([
  getCourseBySlug(slug as string),
  getCoursesPage().catch(() => null),
  getSiteSettings().catch(() => null),
]);
const settings = resolveSiteSettings(siteSettings);

if (!course) {
  return Astro.redirect('/404');
}

const title = course.seoTitle ?? `${course.title} · ${site.name}`;
const description = course.seoDescription ?? course.summary ?? `A course at ${site.name}.`;

const area = course.teachingAreas?.[0]?.title;
const no = course.nextOffering;

function fmtDate(d?: string): string {
  if (!d) return '';
  return new Date(`${d}T00:00:00`).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const price =
  course.priceNote ?? (course.priceTier?.amount != null ? `$${course.priceTier.amount}` : null);

// At-a-glance ledger rows, empties dropped.
const ledger = [
  ['Term', no?.term?.title],
  ['Begins', fmtDate(no?.term?.startDate)],
  ['Schedule', no?.schedule],
  ['Sessions', no?.sessions ? `${no.sessions} weeks` : null],
  ['Format', course.format],
  ['Venue', course.location],
  ['Tuition', price],
  ['Apply by', fmtDate(no?.term?.registrationDeadline)],
].filter(([, v]) => Boolean(v)) as [string, string][];

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Courses', url: `${site.url}/courses` },
    { name: course.title ?? (slug as string), url: `${site.url}/courses/${slug}` },
  ]),
  JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Course',
    name: course.title,
    description: course.summary ?? undefined,
    provider: { '@type': 'Organization', name: site.name, url: site.url },
  }),
];

const pillPrimary =
  'press-tactile inline-flex w-full items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] bg-primary text-primary-foreground hover:bg-primary-dark transition-colors';
const pillGhost =
  'press-tactile inline-flex w-full items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] border border-foreground text-foreground hover:bg-accent transition-colors';
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <section class="bg-background">
    <div class="mx-auto max-w-content px-m pt-section-lg pb-section-lg">
      <p class="mb-l text-xs uppercase tracking-[0.12em] text-foreground/70">
        <a href="/courses" class="hover:text-primary-dark transition-colors">Courses</a>
        {area && <span class="mx-2">/</span>}
        {area && <span>{area}</span>}
      </p>

      <div class="grid grid-cols-1 gap-x-12 gap-y-l lg:grid-cols-[1.15fr_.85fr]">
        {/* Main column */}
        <div>
          <h1 class="font-display text-h1 leading-headline-tight text-foreground">{course.title}</h1>
          {course.instructors?.length > 0 && (
            <p class="mt-m text-lg text-foreground/75">
              with{' '}
              {course.instructors.map((i: any, idx: number) => (
                <>
                  {idx > 0 && (idx === course.instructors.length - 1 ? ' and ' : ', ')}
                  <a href={`/faculty/${i.slug}`} class="text-link underline underline-offset-2 hover:text-primary-dark">{i.honorific ? `${i.honorific} ` : ''}{i.name}</a>
                </>
              ))}
            </p>
          )}
          {course.summary && <p class="mt-l max-w-prose text-lg leading-relaxed text-foreground/85">{course.summary}</p>}

          {course.whoFor?.length > 0 && (
            <div class="mt-l">
              <p class="text-xs uppercase tracking-eyebrow text-foreground/80">Who this is for</p>
              <ul class="mt-3 list-disc space-y-1.5 pl-5 text-foreground/80">
                {course.whoFor.map((w: string) => <li>{w}</li>)}
              </ul>
            </div>
          )}

          {course.sessionOutline?.length > 0 && (
            <div class="mt-l">
              <p class="text-xs uppercase tracking-eyebrow text-foreground/80">The sessions</p>
              <div class="mt-3 border-t border-border-soft">
                {course.sessionOutline.map((s: any, idx: number) => (
                  <div class="grid grid-cols-[3rem_1fr] gap-4 border-b border-border-soft py-4">
                    <span class="font-display text-lg tabular-nums text-gold-ink">{String(idx + 1).padStart(2, '0')}</span>
                    <div>
                      <h3 class="font-display text-h5 text-foreground">{s.title}</h3>
                      {s.focus && <p class="mt-1 text-sm text-foreground/70">{s.focus}</p>}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>

        {/* Aside: facts ledger + CTA + teacher */}
        <aside>
          <div class="lg:sticky lg:top-28">
            <div class="h-0.5 w-full bg-gold"></div>
            <div class="border border-t-0 border-border-soft bg-bg-soft">
              <div class="border-b border-border-soft px-5 py-4">
                <span class="text-xs uppercase tracking-eyebrow text-foreground/80">At a glance</span>
              </div>
              {ledger.length > 0 ? (
                <dl class="text-sm">
                  {ledger.map(([label, value]) => (
                    <div class="flex items-center justify-between gap-4 border-b border-border-soft px-5 py-3 last:border-b-0">
                      <dt class="text-foreground/70">{label}</dt>
                      <dd class="text-right font-medium text-foreground">{value}</dd>
                    </div>
                  ))}
                </dl>
              ) : (
                <p class="px-5 py-4 text-sm italic text-foreground/70">New dates coming. Request info to hear first.</p>
              )}
            </div>

            <div class="mt-l flex flex-col gap-3">
              <a href="/get-started" class={pillPrimary}>Express interest</a>
              <a href="/get-started" class={pillGhost}>Request information</a>
            </div>
            <p class="mt-3 text-center text-sm text-foreground/70">You can visit the first session free before you decide.</p>

            {course.instructors?.length > 0 && (
              <div class="mt-l border-t border-border-soft pt-l">
                <p class="text-xs uppercase tracking-eyebrow text-foreground/80">{course.instructors.length > 1 ? 'Your teachers' : 'Your teacher'}</p>
                <div class="mt-3 flex flex-col gap-4">
                  {course.instructors.map((i: any) => (
                    <a href={`/faculty/${i.slug}`} class="group grid grid-cols-[56px_1fr] items-center gap-3 no-underline">
                      <div class="image-well aspect-square overflow-hidden">
                        {i.photo?.asset && (
                          <SanityImage source={i.photo} width={120} sizes="56px" class="h-full w-full object-cover" />
                        )}
                      </div>
                      <div>
                        <p class="font-display text-h5 text-foreground transition-colors group-hover:text-link">{i.honorific ? `${i.honorific} ` : ''}{i.name}</p>
                        {i.degrees?.[0] && (
                          <p class="text-xs text-gold-ink">{i.degrees[0].degree}{i.degrees[0].institution ? `, ${i.degrees[0].institution}` : ''}</p>
                        )}
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <FinalCta
    eyebrow={coursesPage?.finalCtaEyebrow ?? 'Ready to begin?'}
    headline={coursesPage?.finalCtaHeadline ?? 'Tell us what you want to learn'}
    subhead={coursesPage?.finalCtaSubhead ?? 'Request information or book a free intro. No application fee, no pressure.'}
    cta={{ label: 'Request information', linkType: 'external', externalUrl: '/get-started' }}
  />
</BaseLayout>
