---
// Safe to edit by hand for copy + structure changes.
// Pastors & Staff. Bios + headshots for the people who serve the church.
// The bios below are short placeholders; replace them with your church's own
// staff and photos (rebrand checklist).
// (When the church wants to edit these without code, this is the natural
// candidate for a Sanity "staffMember" collection later.)

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPageHero, getSiteSettings, getStaffMembers } from '@/lib/queries';
import heroStaff from '@/assets/placeholders/teach-group-reading-bibles.jpg';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import Hero from '@/components/Hero.astro';
import SanityImage from '@/components/SanityImage.astro';
import PortableTextStatic from '@/components/PortableTextStatic.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getPageHero('staffPage').catch(() => null);

// Pastoral + office emails come from Sanity siteSettings via the resolver.
const settings = resolveSiteSettings(siteSettings);

// Staff render from the Sanity staffMember collection when present; otherwise
// the hardcoded bios below remain as the built-in fallback (so the page is
// never empty before an editor adds people in the Studio).
const sanityStaff = await getStaffMembers().catch(() => []);

const title = page?.seoTitle ?? `Pastors & Staff · ${site.name}`;
const description =
  page?.seoDescription ??
  'Meet the pastors and staff of The Presbyterian Academy: Rev. Jane Smith, Rev. Chris Brown, Alex Johnson, and Sam Lee.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Pastors & Staff', url: `${site.url}/pastor-staff` },
  ]),
];

const staff = [
  {
    name: 'Rev. Jane Smith',
    role: 'Pastor',
    email: settings.pastorEmail,
    bio: [
      `Rev. Jane Smith has served as Pastor since 2020 and loves helping people find their place in the church family.`,
    ],
    favorites: [
      { label: 'Reading', items: 'a good novel and anything about church history' },
      { label: 'Watching', items: 'documentaries and baking shows' },
      { label: 'Listening', items: 'podcasts and choral music' },
    ],
  },
  {
    name: 'Rev. Chris Brown',
    role: 'Parish Associate',
    bio: [
      `Rev. Chris Brown serves as Parish Associate and has spent many years walking alongside congregations and families in every season of life.`,
    ],
  },
  {
    name: 'Alex Johnson',
    role: 'Music Director',
    bio: [
      `Alex Johnson leads music at the church and loves helping the choir and congregation lift their voices together on Sunday mornings.`,
    ],
    favorites: [
      { label: 'Reading', items: 'composer biographies' },
      { label: 'Watching', items: 'classic films' },
      { label: 'Listening', items: 'organ recordings, jazz, and opera' },
    ],
  },
  {
    name: 'Sam Lee',
    role: 'Office Administrator',
    email: settings.email,
    bio: [
      `Sam Lee keeps the church office running smoothly and is usually the first friendly face you will meet when you stop by during the week.`,
    ],
    favorites: [
      { label: 'Reading', items: 'mysteries and cookbooks' },
      { label: 'Watching', items: 'documentaries and docuseries' },
      { label: 'Listening', items: 'audiobooks and classic soul' },
    ],
  },
];

// Normalize the Sanity collection and the hardcoded fallback into one render
// shape so the markup below stays single-source. Sanity bios are Portable Text
// blocks; fallback bios are plain strings. Favorites use {label, value}.
const useSanityStaff = Array.isArray(sanityStaff) && sanityStaff.length > 0;
const people = useSanityStaff
  ? sanityStaff.map((p: any) => ({
      name: p.name,
      role: p.role,
      email: p.email,
      sanityPhoto: p.photo?.asset ? p.photo : null,
      bioBlocks: p.bio,
      bioStrings: null as string[] | null,
      favorites: (p.favorites ?? []).map((f: any) => ({ label: f.label, value: f.value })),
    }))
  : staff.map((p) => ({
      name: p.name,
      role: p.role,
      email: (p as any).email as string | undefined,
      sanityPhoto: null,
      bioBlocks: null,
      bioStrings: p.bio,
      favorites: ((p as any).favorites ?? []).map((f: any) => ({ label: f.label, value: f.items })),
    }));
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'Pastors & Staff'}
    headline={page?.heroHeadline ?? "The people you'll meet at The Presbyterian Academy"}
    subhead={page?.heroSubhead ?? 'A small, dedicated team serving a historic congregation in downtown West Chester Township.'}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroStaff}
    localImageAlt="People reading together in a study group"
    headingId="staff-hero"
    size="short"
  />

  <section class="bg-background" aria-label="Pastors and staff">
    <div class="mx-auto max-w-content px-m py-section-lg space-y-section-md">
      {people.map((person) => (
        <article class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-l md:gap-section-md items-start border-b border-border-soft pb-section-md last:border-b-0 last:pb-0">
          <div class="md:sticky md:top-28">
            {/* Arched headshot — carries the building's arch motif onto the staff. */}
            <div class="w-44 sm:w-52 aspect-[4/5] overflow-hidden arch-top-sm ring-1 ring-primary/40 dark:ring-[#C7A875]/40 bg-muted shadow-sm">
              {/* Sanity headshot when uploaded; otherwise the arched frame
                  stays empty as a deliberate "headshot pending" placeholder. */}
              {person.sanityPhoto && (
                <SanityImage
                  source={person.sanityPhoto}
                  width={420}
                  sizes="(min-width: 640px) 208px, 176px"
                  alt={person.sanityPhoto.alt || `${person.name}, ${person.role} at The Presbyterian Academy`}
                  class="h-full w-full object-cover"
                />
              )}
            </div>
            <h2 class="mt-l font-display text-h3 text-foreground">{person.name}</h2>
            <p class="mt-xs text-xs uppercase tracking-eyebrow text-foreground/80">{person.role}</p>
            {person.email && (
              <a href={`mailto:${person.email}`} class="mt-s inline-block text-sm text-link underline underline-offset-2 hover:text-primary-dark transition-colors break-all">
                {person.email}
              </a>
            )}
          </div>
          <div class="text-foreground/85 text-lg leading-relaxed space-y-m">
            {person.bioBlocks ? (
              <PortableTextStatic value={person.bioBlocks} />
            ) : (
              person.bioStrings?.map((p) => <p>{p}</p>)
            )}
            {person.favorites && person.favorites.length > 0 && (
              <dl class="mt-l grid grid-cols-1 gap-y-1 border-t border-border-soft pt-m text-sm text-foreground/70">
                {person.favorites.map((f) => (
                  <div class="flex gap-2">
                    <dt class="w-20 shrink-0 font-semibold uppercase tracking-eyebrow text-xs pt-0.5 text-muted-foreground">{f.label}</dt>
                    <dd class="flex-1">{f.value}</dd>
                  </div>
                ))}
              </dl>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? "Come and See"}
    headline={page?.finalCtaHeadline ?? "We would love to meet you"}
    subhead={page?.finalCtaSubhead ?? "Join us for worship on Sunday, or reach out to the office any time."}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Plan a Visit', linkType: 'external', externalUrl: '/worship' }}
  />
</BaseLayout>
