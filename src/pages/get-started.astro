---
// Safe to edit by hand for copy + structure changes.
// Get Started — the express-interest hub. Express-interest form on the left, a
// ruled panel on the right with the free-intro (Calendly), a "visit a class"
// note, a syllabus note, and the "what happens next" steps. No payment is wired;
// the form captures interest and routes to a person. Rule & Ledger layout.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGetStartedPage, getSiteSettings } from '@/lib/queries';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import FormBlock from '@/components/FormBlock.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const [page, siteSettings] = await Promise.all([
  getGetStartedPage().catch(() => null),
  getSiteSettings().catch(() => null),
]);
const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? `Get Started · ${site.name}`;
const description =
  page?.seoDescription ??
  'Request information, book a free intro, or download a course syllabus. No application fee, no pressure.';

const heroEyebrow = page?.heroEyebrow ?? 'Get started';
const heroHeadline = page?.heroHeadline ?? 'Tell us what you want to learn';
const heroSubhead =
  page?.heroSubhead ??
  'Request information, book a free intro session, or download a course syllabus. No application fee, no pressure.';

const calendlyUrl = page?.calendlyUrl ?? import.meta.env.PUBLIC_CALENDLY_URL ?? '';

const steps = page?.steps?.length
  ? page.steps
  : [
      { title: 'You tell us a little', body: 'A short form, just enough for us to point you in the right direction.' },
      { title: 'We reply, person to person', body: 'A real teacher or staff member answers your questions within a few days.' },
      { title: 'You try before you decide', body: 'Sit in on a class or book a free intro. Enroll only when you are ready.' },
    ];

const pillPrimary =
  'press-tactile inline-flex items-center justify-center min-h-[44px] w-full px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] bg-primary text-primary-foreground hover:bg-primary-dark transition-colors';
const pillGhost =
  'press-tactile inline-flex items-center justify-center min-h-[44px] w-full px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] border border-foreground text-foreground hover:bg-accent transition-colors';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Get Started', url: `${site.url}/get-started` },
  ]),
];
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <section class="bg-background">
    <div class="mx-auto max-w-content px-m pt-section-lg pb-l">
      <div data-reveal>
        <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">{heroEyebrow}</p>
        <h1 class="mt-3 font-display text-h1 leading-headline-tight text-foreground">{heroHeadline}</h1>
        {heroSubhead && <p class="mt-m max-w-2xl text-lg text-foreground/80">{heroSubhead}</p>}
      </div>
      <div class="mt-l h-px w-full bg-gold/50"></div>
    </div>
  </section>

  <section class="bg-background">
    <div class="mx-auto grid max-w-content grid-cols-1 gap-x-12 gap-y-l px-m pb-section-lg lg:grid-cols-[1.1fr_.9fr]">
      {/* Express-interest form */}
      <div>
        <div data-reveal>
          <p class="eyebrow text-xs uppercase tracking-eyebrow text-gold-ink">Request information</p>
          <h2 class="mt-2 font-display text-h3 text-foreground">Ask us anything</h2>
          <p class="mt-3 text-foreground/80">Tell us what you are hoping to learn and we will help you find the right course.</p>
        </div>
        <div class="mt-l">
          <FormBlock form={page?.requestForm} fallbackEmail={settings.email} fallbackLabel="Email us" />
        </div>
      </div>

      {/* Ruled panel: free intro + visit + syllabus + steps */}
      <aside>
        <div class="h-0.5 w-full bg-gold"></div>
        <div class="border border-t-0 border-border-soft bg-card p-l">
          <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">{page?.calendlyEyebrow ?? 'Or talk to us first'}</p>
          <h3 class="mt-2 font-display text-h4 text-foreground">{page?.calendlyHeadline ?? 'Book a free intro session'}</h3>
          <p class="mt-2 text-sm text-foreground/75">{page?.calendlyBody ?? 'A short, no-pressure conversation about where you are and what fits.'}</p>
          {calendlyUrl ? (
            <a href={calendlyUrl} target="_blank" rel="noopener noreferrer" class={`${pillPrimary} mt-m`}>Book a free intro</a>
          ) : (
            <a href={`mailto:${settings.email}`} class={`${pillPrimary} mt-m`}>Email to set up an intro</a>
          )}

          <div class="mt-l border-t border-border-soft pt-l">
            <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Visit a class</p>
            <p class="mt-2 text-sm text-foreground/75">{page?.visitClassBody ?? 'You are welcome to sit in on the first session of any course, free, before you decide.'}</p>
          </div>

          <div class="mt-l border-t border-border-soft pt-l">
            <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">Take a syllabus with you</p>
            <p class="mt-2 text-sm text-foreground/75">{page?.syllabusBody ?? 'Every course page has a downloadable syllabus, so you can see exactly what a term covers.'}</p>
            <a href="/courses" class="mt-2 inline-block text-sm text-link underline underline-offset-2 hover:text-primary-dark">Browse courses</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  {/* What happens next */}
  <section class="surface-warm bg-muted">
    <div class="mx-auto max-w-content px-m py-section-md">
      <div data-reveal>
        <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80">{page?.stepsHeadline ?? 'What happens next'}</p>
      </div>
      <div class="mt-l grid grid-cols-1 gap-l md:grid-cols-3" data-stagger-grid>
        {steps.map((s: any, i: number) => (
          <div class="border-t-2 border-gold pt-4">
            <span class="font-display text-lg tabular-nums text-gold-ink">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="mt-2 font-display text-h5 text-foreground">{s.title}</h3>
            {s.body && <p class="mt-1 text-sm text-foreground/75">{s.body}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? 'Prefer to browse first?'}
    headline={page?.finalCtaHeadline ?? 'See what we teach'}
    subhead={page?.finalCtaSubhead ?? 'The catalog is open. Find a course, meet the teacher, and start when you are ready.'}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Browse courses', linkType: 'external', externalUrl: '/courses' }}
  />
</BaseLayout>
