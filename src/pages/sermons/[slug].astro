---
// Safe to edit by hand for copy + structure changes.
// Sermon detail. Embedded video, meta (date/speaker/series/scripture), notes,
// optional audio. Built per sermon slug in Sanity; without Sanity no detail
// pages are generated.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllSermonSlugs, getSermonBySlug, getSermonsPage, getSiteSettings } from '@/lib/queries';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import PortableText from '@/components/PortableText';
import SanityImage from '@/components/SanityImage.astro';
import FinalCta from '@/components/FinalCta.astro';

export async function getStaticPaths() {
  const slugs = await getAllSermonSlugs().catch(() => []);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const [sermon, siteSettings, sermonsPage] = await Promise.all([
  getSermonBySlug(slug as string),
  getSiteSettings().catch(() => null),
  getSermonsPage().catch(() => null),
]);

if (!sermon) {
  return Astro.redirect('/404');
}

const title = `${sermon.title} · Sermons · ${site.name}`;
const description = sermon.scripture ? `${sermon.title} — ${sermon.scripture}` : `A message from ${site.name}.`;

// Turn a YouTube/Vimeo watch URL into an embeddable player URL.
function embedUrl(url?: string): string | null {
  if (!url) return null;
  try {
    const u = new URL(url);
    if (u.hostname.includes('youtube.com') && u.searchParams.get('v')) {
      return `https://www.youtube.com/embed/${u.searchParams.get('v')}`;
    }
    if (u.hostname.includes('youtu.be')) {
      return `https://www.youtube.com/embed/${u.pathname.replace(/^\//, '')}`;
    }
    if (u.hostname.includes('vimeo.com')) {
      return `https://player.vimeo.com/video/${u.pathname.replace(/^\//, '')}`;
    }
    return url;
  } catch {
    return null;
  }
}
const embed = embedUrl(sermon.videoUrl);

const dateLabel = sermon.date
  ? new Date(sermon.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : '';
// Liturgical day rides with the date in the meta line ("June 7, 2026 · Third
// Sunday after Pentecost · Rev. ..."), keeping the record visible up top.
const metaLine = [dateLabel, sermon.liturgicalDay, sermon.speaker, sermon.series].filter(Boolean).join(' · ');

// Service record: the per-service archive (bulletin, manuscript, hymns, music,
// leaders). The panel below renders only when at least one item exists, so
// sermons without a record look exactly as before.
const hymns: Array<{ _key?: string; title?: string; number?: string }> = sermon.hymns ?? [];
const serviceMusic: Array<{ _key?: string; role?: string; title?: string; composer?: string }> = sermon.serviceMusic ?? [];
const worshipLeaders: Array<{ _key?: string; role?: string; name?: string }> = sermon.worshipLeaders ?? [];
const hasServiceRecord = Boolean(
  sermon.bulletinUrl || sermon.manuscriptUrl || hymns.length || serviceMusic.length || worshipLeaders.length,
);

// Outline download pill, matching the sermons-index pill vocabulary.
const pillOutline =
  'press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] border border-primary text-link hover:bg-accent transition-colors';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Sermons', url: `${site.url}/sermons` },
    { name: sermon.title ?? (slug as string), url: `${site.url}/sermons/${slug}` },
  ]),
];
---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <article class="bg-background">
    <div class="mx-auto max-w-3xl px-m pt-section-lg pb-l">
      <p class="text-xs uppercase tracking-widest text-foreground/80 mb-s">
        <a href="/sermons" class="hover:text-primary-dark transition-colors">Sermons</a>
        {sermon.series && <span class="mx-xs">·</span>}
        {sermon.series && <span>{sermon.series}</span>}
      </p>
      <h1 class="font-display text-h1 text-foreground leading-tight">{sermon.title}</h1>
      {metaLine && <p class="mt-m text-foreground/70">{metaLine}</p>}
      {sermon.scripture && <p class="mt-xs text-lg text-foreground/85 italic">{sermon.scripture}</p>}
    </div>

    {embed && (
      <div class="mx-auto max-w-4xl px-m">
        <div class="relative w-full overflow-hidden rounded-md shadow-sm" style="aspect-ratio: 16 / 9;">
          <iframe
            src={embed}
            title={sermon.title}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="absolute inset-0 h-full w-full border-0"
          ></iframe>
        </div>
      </div>
    )}

    {!embed && sermon.image?.asset && (
      <figure class="mx-auto max-w-4xl px-m">
        <SanityImage source={sermon.image} width={1600} sizes="(min-width: 920px) 896px, 100vw" class="w-full h-auto rounded-md" />
      </figure>
    )}

    <div class="mx-auto max-w-3xl px-m py-section-lg">
      {sermon.description && (
        /* Plain rich text — no interactive blocks, so server-rendered with no client JS. */
        <PortableText value={sermon.description} className="text-foreground/85 text-lg leading-relaxed" />
      )}
      {sermon.audioUrl && (
        <p class="mt-l">
          <a href={sermon.audioUrl} target="_blank" rel="noopener noreferrer" class="text-link underline underline-offset-2 hover:text-primary-dark transition-colors">
            Listen to the audio →
          </a>
        </p>
      )}

      {/* Service record. Renders only when the editor has attached something
          in the sermon's "Service record" tab: bulletin/manuscript downloads,
          the hymns the congregation sang, the choir + organ music, and who
          served. Date, preacher, liturgical day, and scripture already live in
          the header above, so together the page is a complete record of the
          service. */}
      {hasServiceRecord && (
        <section class="mt-section-md rounded-md border border-border-soft bg-card p-l" aria-labelledby="service-record">
          <p class="text-xs uppercase tracking-eyebrow text-foreground/80">From this service</p>
          <div class="mt-s mb-m h-px w-12 bg-gold/70" aria-hidden="true"></div>
          <h2 id="service-record" class="sr-only">Service record</h2>

          {(sermon.bulletinUrl || sermon.manuscriptUrl) && (
            <div class="flex flex-wrap gap-s">
              {sermon.bulletinUrl && (
                <a href={sermon.bulletinUrl} target="_blank" rel="noopener noreferrer" class={pillOutline}>
                  Bulletin (PDF)
                </a>
              )}
              {sermon.manuscriptUrl && (
                <a href={sermon.manuscriptUrl} target="_blank" rel="noopener noreferrer" class={pillOutline}>
                  Sermon notes (PDF)
                </a>
              )}
            </div>
          )}

          <div class="mt-l grid grid-cols-1 sm:grid-cols-2 gap-l">
            {hymns.length > 0 && (
              <div>
                <h3 class="font-display text-h5 text-foreground">Hymns</h3>
                <ul class="mt-s space-y-1 list-none p-0">
                  {hymns.map((h) => (
                    <li class="text-foreground/85">
                      {h.title}
                      {h.number && <span class="text-muted-foreground"> · {h.number}</span>}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {serviceMusic.length > 0 && (
              <div>
                <h3 class="font-display text-h5 text-foreground">Music</h3>
                <ul class="mt-s space-y-1 list-none p-0">
                  {serviceMusic.map((m) => (
                    <li class="text-foreground/85">
                      {m.role && <span class="text-xs uppercase tracking-eyebrow text-muted-foreground">{m.role}: </span>}
                      {m.title}
                      {m.composer && <span class="text-muted-foreground"> · {m.composer}</span>}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {worshipLeaders.length > 0 && (
              <div>
                <h3 class="font-display text-h5 text-foreground">Serving in worship</h3>
                <ul class="mt-s space-y-1 list-none p-0">
                  {worshipLeaders.map((w) => (
                    <li class="text-foreground/85">
                      <span class="text-xs uppercase tracking-eyebrow text-muted-foreground">{w.role}: </span>
                      {w.name}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </section>
      )}
    </div>
  </article>

  <FinalCta
    eyebrow={sermonsPage?.detailFinalCtaEyebrow ?? "Come and See"}
    headline={sermonsPage?.detailFinalCtaHeadline ?? "Join us this Sunday"}
    subhead={sermonsPage?.detailFinalCtaSubhead ?? "Worship is every Sunday in our historic sanctuary. Everyone is welcome."}
    cta={sermonsPage?.detailFinalCta?.label ? sermonsPage.detailFinalCta : { label: 'Plan a Visit', linkType: 'external', externalUrl: '/worship' }}
  />
</BaseLayout>
