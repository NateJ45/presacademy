---
// Safe to edit by hand for copy + structure changes.
// Use Our Space. Venue rental and space sharing at the church.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getUseOurSpacePage, getSiteSettings } from '@/lib/queries';
import heroSpace from '@/assets/hero-space.webp';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';
import { resolveSiteSettings } from '@/lib/siteSettings';
import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FormBlock from '@/components/FormBlock.astro';
import FinalCta from '@/components/FinalCta.astro';
import Sections from '@/components/Sections.astro';

const siteSettings = await getSiteSettings().catch(() => null);
const page = await getUseOurSpacePage().catch(() => null);

const settings = resolveSiteSettings(siteSettings);

const title = page?.seoTitle ?? `Use Our Space · ${site.name}`;
const description =
  page?.seoDescription ??
  'Host your event at a historic church in downtown Springfield. First Church offers competitive rates, a premium location near transit, and free parking.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Use Our Space', url: `${site.url}/use-our-space` },
  ]),
];

// Inline fallback. The use tags are editable in Sanity (useOurSpacePage.uses);
// this const renders when that field is empty, so the page is identical until
// an editor overrides it.
const FALLBACK_USES = [
  'Youth sports', 'Board meetings', 'Worship', 'Meal programs', 'Social services',
  'Speakers', 'Concerts', 'Performance rehearsals', 'Parties', '12-step groups',
];

const uses = page?.uses?.length ? page.uses : FALLBACK_USES;

---

<BaseLayout {title} {description} {schemas} {siteSettings}>
  <Hero
    eyebrow={page?.heroEyebrow ?? 'Use Our Space'}
    headline={page?.heroHeadline ?? 'Interested in using space at First Church?'}
    subhead={page?.heroSubhead ?? 'A historic, welcoming building in the heart of downtown Springfield, open to the wider community throughout the week.'}
    keyword={page?.heroKeyword}
    backgroundImage={page?.heroImage ?? null}
    localImage={heroSpace}
    localImageAlt="The historic sanctuary interior available to rent at First Church"
    headingId="space-hero"
    size="short"
  />

  <section class="bg-background" aria-labelledby="space-intro">
    <div class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 md:grid-cols-2 gap-l md:gap-section-md items-start">
      <SectionHeading
        eyebrow={page?.introEyebrow ?? 'A space for the neighborhood'}
        headline={page?.introHeadline ?? 'Throughout the week, our doors are open'}
        headingId="space-intro"
      />
      <div class="text-foreground/85 text-lg leading-relaxed space-y-m">
        <p>
          {page?.introBodyP1 ?? 'We host all sorts of gatherings throughout the week, from youth sports and board meetings to concerts, rehearsals, social services, and 12-step groups.'}
        </p>
        <p>
          {page?.introBodyP2 ?? 'You get a premium downtown Springfield location close to public transit, competitive rates, friendly support, and first-come, first-served free parking.'}
        </p>
        <ul class="flex flex-wrap gap-xs pt-xs list-none p-0">
          {uses.map((u) => (
            <li class="text-xs uppercase tracking-eyebrow text-foreground/80 border border-border-soft rounded-full px-3 py-1">{u}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="surface-warm bg-muted" aria-labelledby="space-inquire">
    <div class="mx-auto max-w-3xl px-m py-section-lg text-center">
      <h2 id="space-inquire" class="font-display text-h2 text-foreground">{page?.inquireHeadline ?? "Let's talk about your event"}</h2>
      <p class="mt-m text-lg text-foreground/85 leading-relaxed">
        {page?.inquireIntro ?? 'Get in touch to ask about fees and availability, and we will be back in touch soon.'}
      </p>
      <div class="mt-l text-left">
        <FormBlock form={page?.inquiryForm} fallbackEmail={settings.email} fallbackLabel="Inquire About the Space" />
      </div>
      <p class="mt-l text-sm text-foreground/70">
        Planning something long-term, like a regular meeting or sharing the space?{' '}
        <a
          href={`mailto:${settings.pastorEmail}`}
          class="underline underline-offset-2 hover:text-link transition-colors"
          >Email the Pastor directly</a
        >.
      </p>
    </div>
  </section>

  <Sections sections={page?.flexibleSections} fallbackEmail={settings.email} />

  <FinalCta
    eyebrow={page?.finalCtaEyebrow ?? "Visit First"}
    headline={page?.finalCtaHeadline ?? "Come see the space in person"}
    subhead={page?.finalCtaSubhead ?? "The best way to picture your event here is to experience the building. Join us for worship, or reach out to arrange a visit."}
    cta={page?.finalCta?.label ? page.finalCta : { label: 'Plan a Visit', linkType: 'external', externalUrl: '/worship' }}
  />
</BaseLayout>
