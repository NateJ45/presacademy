---
// Safe to edit by hand
// Custom 404. Warm, on-brand, two clear paths back. No search (there isn't one).
//
// Layout: two-column on desktop (text + photograph), stacked on mobile. The
// photo is sourced from Sanity and can be replaced with any studio photo.
// Asset is referenced by _ref so it pipes through the same SanityImage
// CDN/transform pipeline as every other photo on the site.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getNotFoundPage, getSiteSettings } from '@/lib/queries';
import SanityImage from '@/components/SanityImage.astro';
import notFoundPhoto from '@/assets/placeholders/study-bibles-closeup.jpg';

const [notFoundPage, siteSettings] = await Promise.all([
  getNotFoundPage().catch(() => null),
  getSiteSettings().catch(() => null),
]);

const seoTitle       = notFoundPage?.seoTitle       ?? 'Page not found';
const seoDescription = notFoundPage?.seoDescription ?? 'That page wandered off. Head back to the homepage or get in touch.';

const eyebrow  = notFoundPage?.eyebrow  ?? 'Error 404';
const headline = notFoundPage?.headline ?? "This page isn't in the index.";
const body     = notFoundPage?.body     ?? 'A link may be out of date, or the address mistyped. The catalog, the faculty, and a way to reach us are all a click away.';

// School CTAs: send a lost visitor to the catalog, the faculty, or a person.
const primaryLabel    = notFoundPage?.primaryCtaLabel    ?? 'Browse courses';
const primaryHref     = notFoundPage?.primaryCtaHref     ?? '/courses';
const secondaryLabel  = notFoundPage?.secondaryCtaLabel  ?? 'Meet the faculty';
const secondaryHref   = notFoundPage?.secondaryCtaHref   ?? '/faculty';
const tertiaryLabel   = notFoundPage?.tertiaryCtaLabel   ?? 'Get in touch';
const tertiaryHref    = notFoundPage?.tertiaryCtaHref    ?? '/contact';

// Sanity image wins when set; otherwise a bundled sanctuary photo (no dead
// template asset _ref). Rendered in the site's signature arched frame.
const sanityPhoto = notFoundPage?.heroImage?.asset ? notFoundPage.heroImage : null;
const caption = notFoundPage?.heroImage?.caption ?? 'The Presbyterian Academy';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  siteSettings={siteSettings}
  noindex
>
  <section
    class="mx-auto max-w-content px-m py-section-lg grid grid-cols-1 md:grid-cols-[1fr_1.1fr] gap-section-md items-center"
    aria-labelledby="not-found-heading"
  >
    {/* Text column. Two clear paths back — no search (there isn't one).
        Centered on mobile so the lone-element page reads as a sympathetic
        "you're off-path" moment; left-aligned on desktop where the
        two-column layout needs the text anchored beside the photo column. */}
    <div class="text-center md:text-left">
      <p class="eyebrow text-xs uppercase tracking-eyebrow text-foreground/80 mb-s">{eyebrow}</p>
      <h1 id="not-found-heading" class="font-display text-h1 text-foreground leading-headline-tight">
        {headline}
      </h1>
      <p class="mt-m max-w-xl mx-auto md:mx-0 text-lg text-foreground/80 leading-relaxed">
        {body}
      </p>

      <div class="mt-l flex flex-wrap gap-m justify-center md:justify-start">
        <a
          href={primaryHref}
          class="press-tactile inline-flex items-center px-l py-s bg-primary-dark text-white font-semibold uppercase tracking-eyebrow text-xs rounded-sm hover:bg-accent-dark"
        >
          {primaryLabel}
        </a>
        <a
          href={secondaryHref}
          class="press-tactile inline-flex items-center px-l py-s border border-primary text-link font-semibold uppercase tracking-eyebrow text-xs rounded-sm hover:bg-accent"
        >
          {secondaryLabel}
        </a>
        <a
          href={tertiaryHref}
          class="press-tactile inline-flex items-center px-l py-s border border-border-soft text-foreground/85 font-semibold uppercase tracking-eyebrow text-xs rounded-sm hover:border-primary hover:text-primary-dark"
        >
          {tertiaryLabel}
        </a>
      </div>
    </div>

    {/* Photo column. Stacks above the text on mobile (md:order-2 swaps it on
        desktop so the eye lands on text first, photo balances right). */}
    <figure class="order-first md:order-2">
      {/* Brass top rule + rectangular crop — the current "Rule & Ledger" frame.
          The Romanesque arch was retired in the brand evolution. */}
      <div class="h-0.5 w-full bg-gold"></div>
      <div class="overflow-hidden aspect-[5/6] bg-muted">
        {sanityPhoto ? (
          <SanityImage
            source={sanityPhoto}
            width={1000}
            sizes="(min-width: 768px) 50vw, 100vw"
            quality={75}
            alt={sanityPhoto.alt || 'The Presbyterian Academy'}
            class="w-full h-full object-cover"
          />
        ) : (
          <Image
            src={notFoundPhoto}
            alt="Two open study Bibles beside a cup of coffee"
            widths={[480, 768, 1000]}
            sizes="(min-width: 768px) 50vw, 100vw"
            class="w-full h-full object-cover"
          />
        )}
      </div>
      <figcaption class="mt-s text-xs uppercase tracking-eyebrow text-foreground/80 text-right">
        {caption}
      </figcaption>
    </figure>
  </section>
</BaseLayout>
