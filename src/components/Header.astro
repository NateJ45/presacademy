---
// Foundation, edit with care
// Site header. Two structural rows on desktop, one on mobile:
//   ┌─────────────────────────────────────── 4px accent stripe
//   │ ─────────────────────────────────────── eyebrow strip (desktop-only)
//   │   [site tagline]           email  · IG · FB · theme
//   ├─────────────────────────────────────── main row
//   │   [logo]                  [nav]  │  [Book a consultation CTA]
//   └───────────────────────────────────────
// On mobile the eyebrow strip is hidden (its info lives in the redesigned
// MobileNav drawer) and the main row centers the logo with the hamburger
// pinned absolute to the right.
//
// siteSettings is optional. Defaults render cleanly so the header works
// even before Sanity content is wired up.

import { resolveSiteSettings } from '@/lib/siteSettings';
import { site } from '@/data/site';
import { IconBrandInstagram, IconBrandFacebook } from '@tabler/icons-react';
import { ChevronDown } from 'lucide-react';
import ThemeToggle from './ThemeToggle';
import MobileNav from './MobileNav';
import { serviceTime } from '@/lib/serviceTime';

// The church brand is a text wordmark (Instrument Serif), not an image logo,
// so there are no logo assets to pipe through getImage here.

interface Props {
  siteSettings?: {
    siteName?: string;
    title?: string;
    tagline?: string;
    email?: string;
    phone?: string;
    addressLine?: string;
    socialInstagram?: string;
    socialFacebook?: string;
    // Church utility-bar content. All optional with real fallbacks below, so
    // the bar is never empty before Sanity is wired.
    worshipService?: { time?: string; day?: string; startTime24?: string; endTime24?: string } | null; // single source for the service time
    giveUrl?: string;        // giving portal; falls back to the /give page
    watchUrl?: string;       // livestream; falls back to the /sermons page
    // Editor-managed top menu (Site Settings -> Navigation). Each entry is a
    // navLink {label, href} or a navGroup {label, links:[{label, href}]}.
    // When absent/empty, the built-in FALLBACK_NAV_ITEMS below renders.
    navItems?: Array<{
      _type?: string;
      label?: string;
      href?: string;
      links?: Array<{ label?: string; href?: string }>;
    }> | null;
  } | null;
}

const { siteSettings } = Astro.props as Props;

// Identity / contact / social values resolve through one shared helper (see
// src/lib/siteSettings.ts) so the header, footer, pages, and JSON-LD stay in
// lockstep. An empty Sanity field renders blank instead of being masked by a
// hardcoded default.
const settings = resolveSiteSettings(siteSettings);

const brandName = settings.brandName;

// Utility-bar content. Service time + address read top-left; Watch + Give read
// top-right.
const serviceTimes = serviceTime(settings.worshipService).line;
const addressShort = settings.addressLine; // "9463 Cincinnati Columbus Rd"
const giveHref = settings.giveHref;
const watchHref = settings.watchHref;

const ig = settings.social.instagram;
const fb = settings.social.facebook;

// Subset of siteSettings the mobile menu needs. Pass as a plain object so the
// React island doesn't try to serialize the whole Sanity document graph.
const mobileNavSettings = {
  tagline: settings.tagline,
  email: settings.email,
  phone: settings.phone,
  socialInstagram: ig,
  socialFacebook: fb,
};

// Core nav structure. Flat items render as plain anchor links; dropdown
// items render as native <details>/<summary> disclosure groups on desktop
// (server-rendered, see the nav markup below) and as indented expandable
// groups in MobileNav.
//
// Why <details> and not a React island: the desktop nav must exist in the
// server-rendered HTML so search-engine crawlers see every internal link and
// so there is no flash-of-missing-nav (or CLS) before hydration. A native
// <details> disclosure is crawlable, keyboard-accessible, and works with zero
// JS. A tiny progressive-enhancement script (further down) adds the niceties
// browsers don't give us for free: open-on-hover, close-on-outside-click,
// close-on-Escape, and close-on-navigation. The links work without it.
//
// "Contact" is intentionally NOT in the primary nav — the "Book a consultation"
// CTA at the right of the nav row does that job, and the MobileNav drawer also
// surfaces the CTA at the top.
//
// Core nav: /, /about, /services, /faq, /journal, /contact (CTA button).
// Module routes (/portfolio, /process, /e-design, /shop, /gift-certificates,
// /quiz, /calculator, /guides, /press, /resources) are opt-in via modules/
// and are NOT linked from the core nav.

type NavItem =
  | { kind: 'flat'; label: string; href: string }
  | { kind: 'dropdown'; label: string; items: { label: string; href: string }[] };

// Raw shape of an editor-managed nav entry coming from Sanity.
type SettingsNavItem = {
  _type?: string;
  label?: string;
  href?: string;
  links?: Array<{ label?: string; href?: string }>;
};

// Built-in default menu. Used when Site Settings -> Navigation is empty, so the
// header is never broken or bare and a fresh clone of the template still renders
// a sensible menu before anyone touches Sanity.
const FALLBACK_NAV_ITEMS: NavItem[] = [
  { kind: 'flat', label: "I'm New", href: '/worship' },
  { kind: 'dropdown', label: 'About Us', items: [
    { label: 'What We Believe', href: '/what-we-believe' },
    { label: 'Music', href: '/music' },
    { label: 'Pastors & Staff', href: '/pastor-staff' },
  ] },
  { kind: 'dropdown', label: 'Get Involved', items: [
    { label: 'Grow', href: '/grow' },
    { label: 'Serve', href: '/serve' },
    { label: 'Kids', href: '/kids' },
    { label: 'Food Ministry', href: '/food' },
  ] },
  { kind: 'flat', label: 'Watch', href: '/sermons' },
  { kind: 'flat', label: 'Events', href: '/events' },
  { kind: 'dropdown', label: 'Space', items: [
    { label: 'Use Our Space', href: '/use-our-space' },
    { label: 'Weddings', href: '/weddings' },
    { label: 'Friends of the Church', href: 'https://example.org' },
  ] },
  { kind: 'flat', label: 'Contact', href: '/contact' },
];

// Map the editor-managed nav (Site Settings -> Navigation) into the {kind} shape
// the render + MobileNav already consume. navGroup -> dropdown, navLink -> flat.
// Entries missing a label/href are dropped so a half-filled row can't break the
// menu. Returns null when nothing usable is set, so we fall back to the default.
function navFromSettings(items?: SettingsNavItem[] | null): NavItem[] | null {
  if (!Array.isArray(items) || items.length === 0) return null;
  const mapped: NavItem[] = [];
  for (const it of items) {
    if (it?._type === 'navGroup') {
      const children = (Array.isArray(it.links) ? it.links : [])
        .filter((l) => l?.label && l?.href)
        .map((l) => ({ label: l.label as string, href: l.href as string }));
      if (it.label && children.length > 0) {
        mapped.push({ kind: 'dropdown', label: it.label, items: children });
      }
    } else if (it?.label && it?.href) {
      mapped.push({ kind: 'flat', label: it.label, href: it.href });
    }
  }
  return mapped.length > 0 ? mapped : null;
}

const NAV_ITEMS: NavItem[] = navFromSettings(siteSettings?.navItems) ?? FALLBACK_NAV_ITEMS;

// MobileNav consumes the same {kind} shape (NavLink[] with optional sub-items).
const NAV_LINKS = NAV_ITEMS;

const pathname = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
// A dropdown group is "active" (its trigger underline locks wide + aria-current
// is set) when the current route matches any of its child links.
function isGroupActive(items: { href: string }[]) {
  return items.some((item) => isActive(item.href));
}
---

<header class="site-header bg-background">
  {/* Brand accent stripe — same visual signature used at the top of the
      mobile menu drawer. Visible on every viewport. */}
  <div class="h-1 bg-primary" aria-hidden="true"></div>

  {/* Utility bar (all viewports). A deep Chapel-green strip carrying the
      church's front-door logistics: service time + address on the left,
      Watch Live + Give + social + theme on the right. This colored bar is the
      clearest "purpose-built church" signal and replaces the template's muted
      designer eyebrow. Cream text on deep green (~9:1 contrast). On phones the
      address + social icons drop away to keep one tidy line; the service time,
      Watch, Give, and theme toggle always show. */}
  <div class="bg-chapel text-chapel-foreground">
    <div class="mx-auto flex max-w-content items-center justify-between gap-m px-m sm:px-l py-1.5">
      <p class="flex min-w-0 items-center gap-2 text-[0.7rem] sm:text-xs">
        <span class="font-semibold uppercase tracking-eyebrow whitespace-nowrap">{serviceTimes}</span>
        <span class="hidden sm:inline text-chapel-foreground/50" aria-hidden="true">·</span>
        <span class="hidden sm:inline truncate text-chapel-foreground/80">{addressShort}</span>
      </p>

      <div class="flex items-center gap-3 sm:gap-m">
        {/* Watch Live — a gold pulse dot signals the livestream. */}
        <a
          href={watchHref}
          class="inline-flex items-center gap-1.5 text-[0.7rem] sm:text-xs uppercase tracking-eyebrow font-semibold text-chapel-foreground/90 hover:text-white transition-colors"
        >
          <span class="relative flex w-2 h-2 shrink-0" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full rounded-full bg-gold opacity-70 animate-ping"></span>
            <span class="relative inline-flex w-2 h-2 rounded-full bg-gold"></span>
          </span>
          <span class="hidden min-[400px]:inline">Watch Live</span>
          <span class="min-[400px]:hidden">Live</span>
        </a>

        <span class="h-3 w-px bg-chapel-foreground/25" aria-hidden="true"></span>

        <a
          href={giveHref}
          class="text-[0.7rem] sm:text-xs uppercase tracking-eyebrow font-semibold text-chapel-foreground/90 hover:text-white transition-colors"
        >
          Give
        </a>

        {(ig || fb) && (
          <div class="hidden sm:flex items-center gap-1">
            {ig && (
              <a
                href={ig}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="inline-flex h-7 w-7 items-center justify-center rounded-full text-chapel-foreground/80 hover:bg-white/10 hover:text-white transition-colors"
              >
                <IconBrandInstagram size={14} stroke={1.5} />
              </a>
            )}
            {fb && (
              <a
                href={fb}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="inline-flex h-7 w-7 items-center justify-center rounded-full text-chapel-foreground/80 hover:bg-white/10 hover:text-white transition-colors"
              >
                <IconBrandFacebook size={14} stroke={1.5} />
              </a>
            )}
          </div>
        )}

        {/* Theme toggle. Its button defaults to text-foreground (dark ink),
            which would disappear on the green bar, so force cream + a soft white
            hover via arbitrary variants. The descendant selector reaches through
            Astro's <astro-island> wrapper. Hydrate on idle to protect TBT. */}
        <div class="[&_button]:!text-chapel-foreground [&_button:hover]:!bg-white/10 [&_button:hover]:!text-white">
          <ThemeToggle client:idle />
        </div>
      </div>
    </div>
  </div>

  {/* Main nav row. Mobile (and tablet) center the logo; desktop ≥1024 px
      justifies logo left, nav+CTA grouped right. Breakpoint matches the
      eyebrow strip above — at viewports between md and lg the desktop
      layout would squish, so mobile-style header stays in use. */}
  <div class="relative mx-auto flex max-w-content items-center justify-center lg:justify-between px-l py-m border-b border-border">
    {/* Text wordmark in the display serif. The church brand is typographic,
        not an image logo, so it renders crisp at any density and needs no
        theme-swap machinery (it inherits the theme-aware foreground color). */}
    <a
      href="/"
      class="inline-flex flex-col leading-none hover:opacity-80 transition-opacity"
      aria-label={`${brandName} home`}
    >
      <span class="font-display text-xl sm:text-2xl text-foreground leading-none">{site.wordmark.line1}</span>
      {site.wordmark.line2 && (
        <span class="font-display text-base sm:text-lg text-foreground/70 leading-tight mt-0.5">{site.wordmark.line2}</span>
      )}
    </a>

    {/* Nav + CTA grouped on the right (lg+ only).

        The desktop nav is server-rendered as real <a> tags (flat links) plus
        native <details> disclosure groups (the two dropdowns). Everything is in
        the HTML at build time — crawlable, keyboard-usable, and present before
        any JS runs (no flash, no CLS). The progressive-enhancement script at the
        bottom of this file layers on hover-to-open + outside-click/Escape/
        navigation close; the nav is fully functional without it. */}
    <div class="hidden lg:flex items-center gap-l">
      <nav class="site-nav flex items-center gap-l" aria-label="Primary">
        {NAV_ITEMS.map((item) =>
          item.kind === 'flat' ? (
            <a
              href={item.href}
              class:list={[
                'nav-underline text-sm tracking-wide transition-colors',
                isActive(item.href)
                  ? 'text-link font-semibold'
                  : 'text-foreground hover:text-link',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ) : (
            <details class="site-nav__group relative">
              {/* <summary> is the disclosure toggle. It carries .nav-underline
                  so it gets the same bronze underline as flat links, and
                  aria-current="page" (which locks the underline wide) when one
                  of its children is the active route. role/aria-expanded are
                  managed natively by <details>. */}
              <summary
                class:list={[
                  'nav-underline text-sm tracking-wide transition-colors',
                  'inline-flex items-center gap-0.5 cursor-pointer select-none list-none',
                  'outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm',
                  isGroupActive(item.items)
                    ? 'text-link font-semibold'
                    : 'text-foreground hover:text-link',
                ]}
                aria-current={isGroupActive(item.items) ? 'page' : undefined}
              >
                {item.label}
                <ChevronDown
                  size={14}
                  className="site-nav__chevron mt-px transition-transform duration-150"
                  aria-hidden="true"
                />
              </summary>

              {/* Menu panel. Absolutely positioned under the summary so it
                  doesn't shift layout. Uses popover tokens to match the mobile
                  drawer + shadcn dropdowns, and the bronze ring + shadow of the
                  card rhythm. */}
              <div
                class="site-nav__menu absolute left-0 top-full mt-2 min-w-[200px] rounded-lg bg-popover p-1 text-popover-foreground shadow-md ring-1 ring-foreground/10 z-50"
              >
                {item.items.map((sub) => (
                  <a
                    href={sub.href}
                    class:list={[
                      'block rounded-md px-2.5 py-1.5 text-sm transition-colors',
                      'hover:bg-accent hover:text-accent-foreground focus-visible:bg-accent focus-visible:text-accent-foreground outline-none',
                      isActive(sub.href) ? 'font-semibold text-link' : 'text-foreground',
                    ]}
                    aria-current={isActive(sub.href) ? 'page' : undefined}
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            </details>
          )
        )}
      </nav>
      <span class="h-6 w-px bg-border-soft" aria-hidden="true"></span>
      <a
        href="/worship"
        class:list={[
          'press-tactile inline-flex items-center px-m py-2 rounded-full text-xs uppercase tracking-eyebrow font-semibold',
          isActive('/worship')
            ? 'bg-accent-dark text-white'
            : 'bg-primary text-primary-foreground hover:bg-primary-dark',
        ]}
      >
        Plan a Visit
      </a>
    </div>

    <MobileNav
      client:only="react"
      links={NAV_LINKS}
      siteSettings={mobileNavSettings}
    />
  </div>
</header>

<style>
  /* Desktop dropdown groups (native <details>). The links are server-rendered
     and fully usable with no JS; these styles + the script below add the
     dropdown affordances. */

  /* Hide the default disclosure triangle in every engine. */
  .site-nav__group > summary {
    list-style: none;
  }
  .site-nav__group > summary::-webkit-details-marker,
  .site-nav__group > summary::marker {
    display: none;
    content: "";
  }

  /* Rotate the chevron when the group is open. */
  .site-nav__group[open] > summary .site-nav__chevron {
    transform: rotate(180deg);
  }

  /* The menu panel starts hidden until the <details> is open. <details>
     natively hides non-summary children when closed, but we keep an explicit
     rule so the absolutely-positioned panel never flashes during hydration. */
  .site-nav__menu {
    display: none;
  }
  .site-nav__group[open] > .site-nav__menu {
    display: block;
  }
</style>

{/* Progressive enhancement for the desktop dropdown nav. Everything still
    works without this (native <details> toggles on click/Enter/Space, links
    are real <a> tags). This adds: open-on-hover with a small close delay,
    close-on-outside-click, close-on-Escape, and close-when-a-link-is-followed.
    Re-binds on astro:page-load so it survives View Transitions navigations. */}
<script>
  // Query groups fresh each call — the nav DOM is replaced on every View
  // Transitions navigation, so a captured list would go stale.
  function currentGroups() {
    return Array.from(
      document.querySelectorAll<HTMLDetailsElement>('.site-nav__group'),
    );
  }

  function closeAllGroups(except?: HTMLDetailsElement) {
    for (const g of currentGroups()) {
      if (g !== except) g.open = false;
    }
  }

  function initHeaderNav() {
    const groups = currentGroups();
    if (groups.length === 0) return;

    const closeAll = closeAllGroups;

    for (const group of groups) {
      const summary = group.querySelector('summary');
      let closeTimer: number | undefined;

      const cancelClose = () => {
        if (closeTimer) {
          window.clearTimeout(closeTimer);
          closeTimer = undefined;
        }
      };

      // Hover intent: open immediately on enter, close after a short delay on
      // leave so a diagonal mouse path to the menu doesn't snap it shut. Only
      // engages on pointers that can actually hover (skips touch).
      group.addEventListener('pointerenter', (e) => {
        if (e.pointerType === 'touch') return;
        cancelClose();
        closeAll(group);
        group.open = true;
      });
      group.addEventListener('pointerleave', (e) => {
        if (e.pointerType === 'touch') return;
        cancelClose();
        closeTimer = window.setTimeout(() => {
          group.open = false;
        }, 140);
      });

      // When opened via keyboard/click, make sure the others close.
      summary?.addEventListener('click', () => {
        // <details> toggles AFTER this handler, so the post-toggle state is the
        // inverse of the current one. If it's about to open, close the rest.
        if (!group.open) closeAll(group);
      });

      // Following a link inside the menu should close the group (so it isn't
      // left open behind the next page during a View Transitions swap).
      group.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          group.open = false;
        });
      });
    }
  }

  // Document-level listeners bind ONCE (guarded by a window flag), so they
  // don't stack up across View Transitions navigations. They query the nav
  // groups fresh each time they fire, so the swapped-in DOM is always covered.
  const w = window as typeof window & { __headerNavBound?: boolean };
  if (!w.__headerNavBound) {
    w.__headerNavBound = true;

    // Close any open group when clicking outside the nav.
    document.addEventListener('pointerdown', (e) => {
      const target = e.target as Node;
      if (!currentGroups().some((g) => g.contains(target))) closeAllGroups();
    });

    // Escape closes the open group and returns focus to its summary.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const openGroup = currentGroups().find((g) => g.open);
      if (openGroup) {
        openGroup.open = false;
        openGroup.querySelector('summary')?.focus();
      }
    });
  }

  initHeaderNav();
  document.addEventListener('astro:page-load', initHeaderNav);
</script>
