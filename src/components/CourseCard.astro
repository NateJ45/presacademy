---
// Safe to edit by hand.
// Rule & Ledger course card: a brass top-rule over a squared cover well, the
// teaching-area label, a status tag, a Fraunces title, the instructor at equal
// weight, a thin rule, and a one-line fact ledger (next cohort term, sessions,
// price). Used on the catalog grid, the home catalog preview, and the "Start
// here" rail. Carries data-* attributes so the catalog filter island can
// show/hide it via the shared .is-filtered-out utility.

import SanityImage from '@/components/SanityImage.astro';

interface Props {
  course: any;
  eager?: boolean;
}
const { course, eager = false } = Astro.props;

const area = course.teachingAreas?.[0]?.title ?? course.level ?? '';
const instructor = course.instructors?.[0];
const instructorName = instructor
  ? `${instructor.honorific ? instructor.honorific + ' ' : ''}${instructor.name}`
  : '';

const no = course.nextOffering;
const status = no?.status as string | undefined;
const statusLabel =
  status === 'open' ? 'Open' : status === 'waitlist' ? 'Waitlist' : status === 'closed' ? 'Closed' : null;
const statusClass =
  status === 'open'
    ? 'border-[#2f6b4f] text-[#2f6b4f]'
    : status === 'waitlist'
      ? 'border-link text-link'
      : 'border-border text-foreground/70';

const price =
  course.priceNote ?? (course.priceTier?.amount != null ? `$${course.priceTier.amount}` : null);
const facts = no
  ? [no.term?.title, no.sessions ? `${no.sessions} sessions` : null, price].filter(Boolean)
  : ['New dates coming'];

const topicSlugs = (course.teachingAreas ?? []).map((t: any) => t.slug).filter(Boolean).join(' ');
const teacherSlugs = (course.instructors ?? []).map((i: any) => i.slug).filter(Boolean).join(' ');
const termSlug = no?.term?.slug ?? '';
---

<li
  data-course-card
  data-topics={topicSlugs}
  data-teachers={teacherSlugs}
  data-term={termSlug}
  class="list-none"
>
  <a href={`/courses/${course.slug}`} class="card-lift group block h-full no-underline">
    <div class="h-0.5 w-full bg-gold transition-colors group-hover:bg-primary"></div>
    <div class="img-zoom relative aspect-[3/2] overflow-hidden bg-muted">
      {course.coverImage?.asset ? (
        <SanityImage
          source={course.coverImage}
          width={800}
          loading={eager ? 'eager' : 'lazy'}
          sizes="(min-width: 1024px) 360px, (min-width: 640px) 45vw, 90vw"
          class="h-full w-full object-cover"
        />
      ) : (
        <div class="image-well h-full w-full"></div>
      )}
    </div>
    <div class="mt-3 flex items-center justify-between gap-2">
      {area && <span class="text-xs uppercase tracking-eyebrow text-gold-ink">{area}</span>}
      {statusLabel && (
        <span class={`shrink-0 rounded-[2px] border px-2 py-0.5 text-[11px] font-semibold uppercase tracking-[0.08em] ${statusClass}`}>
          {statusLabel}
        </span>
      )}
    </div>
    <h3 class="mt-1.5 font-display text-h4 text-foreground transition-colors group-hover:text-link">{course.title}</h3>
    {instructorName && <p class="mt-1 text-sm text-foreground/75">{instructorName}</p>}
    <div class="mt-3 h-px w-full bg-border-soft"></div>
    <p class="mt-3 text-sm text-foreground/70">{facts.join(' · ')}</p>
  </a>
</li>
