---
// Detailed feature cards: optional image/eyebrow/title/body/badge/link per card.
// Section heading inherits the SectionShell text color (tone-adaptive); the cards
// themselves are light surfaces (bg-card) with dark text.
import SanityImage from '@/components/SanityImage.astro';

const { block } = Astro.props as { block: any };
const cards = block?.cards ?? [];
const COLS: Record<string, string> = {
  '2': 'sm:grid-cols-2',
  '3': 'sm:grid-cols-2 lg:grid-cols-3',
  '4': 'sm:grid-cols-2 lg:grid-cols-4',
};
const colClass = COLS[block?.columns ?? '3'] ?? COLS['3'];
const archCls = block?.arched ? 'arch-top-sm' : 'rounded-md';
---

{
  block && cards.length > 0 && (
    <div class="mx-auto max-w-content px-m">
      {(block.eyebrow || block.heading || block.intro) && (
        <div class="max-w-2xl">
          {block.eyebrow && <p class="text-xs uppercase tracking-eyebrow opacity-70">{block.eyebrow}</p>}
          {block.heading && <h2 class="mt-s font-display text-h2">{block.heading}</h2>}
          {block.intro && <p class="mt-s opacity-80 leading-relaxed">{block.intro}</p>}
        </div>
      )}
      <div class={`mt-l grid grid-cols-1 ${colClass} gap-m`} data-stagger-grid>
        {cards.map((c: any) => {
          const hasImg = !!c.image?.asset;
          const inner = (
            <Fragment>
              {hasImg && (
                <div class={`overflow-hidden mb-m img-zoom group aspect-[4/3] ${archCls}`}>
                  <SanityImage
                    source={c.image}
                    width={700}
                    sizes="(min-width: 1024px) 30vw, 90vw"
                    alt={c.image?.alt || c.title || ''}
                    class="h-full w-full object-cover"
                  />
                </div>
              )}
              {c.badge && (
                <span class="inline-block mb-xs rounded-full bg-gold/15 text-gold-ink px-2 py-0.5 text-[0.65rem] uppercase tracking-eyebrow font-semibold">
                  {c.badge}
                </span>
              )}
              {c.eyebrow && <p class="text-xs uppercase tracking-eyebrow text-muted-foreground">{c.eyebrow}</p>}
              <h3 class="font-display text-h4 text-foreground">{c.title}</h3>
              {c.body && <p class="mt-s text-foreground/80 leading-relaxed">{c.body}</p>}
              {c.ctaLabel && c.ctaUrl && (
                <span class="mt-m inline-flex items-center gap-xs text-xs uppercase tracking-eyebrow font-semibold text-link">
                  {c.ctaLabel} <span aria-hidden="true">&rarr;</span>
                </span>
              )}
            </Fragment>
          );
          return c.ctaUrl ? (
            <a href={c.ctaUrl} class="card-lift group block rounded-lg border border-border-soft bg-card p-l no-underline">
              {inner}
            </a>
          ) : (
            <div class="rounded-lg border border-border-soft bg-card p-l">{inner}</div>
          );
        })}
      </div>
    </div>
  )
}
