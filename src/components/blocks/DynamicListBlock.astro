---
// Dynamic list: pulls live content (featured courses, upcoming events, or
// faculty) into any page. Fetches at build time based on the chosen source.
// Cards are light surfaces; section heading inherits the tone color.
import { getFeaturedCourses, getUpcomingEvents, getFaculty, getTestimonials } from '@/lib/queries';

const { block } = Astro.props as { block: any };
const count = Math.min(12, Math.max(1, Number(block?.count ?? 3)));
const source = block?.source ?? 'featuredCourses';

const fmt = (d: string) =>
  d ? new Date(d).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : '';

type Item = { title: string; meta?: string; summary?: string; href?: string | null; isQuote?: boolean };
let items: Item[] = [];

if (source === 'featuredCourses') {
  const c = await getFeaturedCourses(count).catch(() => []);
  items = c.slice(0, count).map((x: any) => ({
    title: x.title,
    meta: x.instructors?.[0]?.name,
    summary: x.summary,
    href: x.slug ? `/courses/${x.slug}` : null,
  }));
} else if (source === 'upcomingEvents') {
  const e = await getUpcomingEvents().catch(() => []);
  items = e.slice(0, count).map((x: any) => ({
    title: x.title,
    meta: x.scheduleLabel || (x.start ? fmt(x.start) : ''),
    summary: x.summary,
    href: x.slug?.current ? `/events/${x.slug.current}` : null,
  }));
} else if (source === 'faculty') {
  const f = await getFaculty().catch(() => []);
  items = f.slice(0, count).map((x: any) => ({
    title: `${x.honorific ? x.honorific + ' ' : ''}${x.name}`,
    meta: x.title,
    summary: x.topDegree ? `${x.topDegree.degree}, ${x.topDegree.institution}` : '',
    href: x.slug ? `/faculty/${x.slug}` : null,
  }));
} else if (source === 'testimonials') {
  const t = await getTestimonials().catch(() => []);
  items = t.slice(0, count).map((x: any) => ({
    title: x.quote,
    meta: [x.name, x.role, x.city].filter(Boolean).join(' · '),
    isQuote: true,
  }));
}
---

{
  items.length > 0 && (
    <div class="mx-auto max-w-content px-m">
      {(block.eyebrow || block.heading || block.intro) && (
        <div class="max-w-2xl mb-l">
          {block.eyebrow && <p class="text-xs uppercase tracking-eyebrow opacity-70">{block.eyebrow}</p>}
          {block.heading && <h2 class="mt-s font-display text-h2">{block.heading}</h2>}
          {block.intro && <p class="mt-s opacity-80 leading-relaxed">{block.intro}</p>}
        </div>
      )}
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-m list-none p-0" data-stagger-grid>
        {items.map((it) => {
          const inner = it.isQuote ? (
            <Fragment>
              <blockquote class="font-display text-lg italic leading-snug text-foreground">{it.title}</blockquote>
              {it.meta && <p class="mt-m text-xs uppercase tracking-eyebrow text-foreground/70">{it.meta}</p>}
            </Fragment>
          ) : (
            <Fragment>
              <h3 class="font-display text-h4 text-foreground">{it.title}</h3>
              {it.meta && <p class="mt-xs text-sm text-foreground/70">{it.meta}</p>}
              {it.summary && <p class="mt-s text-foreground/80 leading-relaxed">{it.summary}</p>}
            </Fragment>
          );
          return (
            <li>
              {it.href ? (
                <a href={it.href} class="card-lift group block h-full rounded-lg border border-border-soft bg-card p-l no-underline">
                  {inner}
                </a>
              ) : (
                <div class="rounded-lg border border-border-soft bg-card p-l">{inner}</div>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  )
}
