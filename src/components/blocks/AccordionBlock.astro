---
// FAQ / accordion block. Native <details> (no JS), tone-adaptive: text inherits
// the SectionShell color and borders use currentColor so it reads on any tone.
const { block } = Astro.props as { block: any };
const items = block?.items ?? [];
---

{
  block && items.length > 0 && (
    <div class="mx-auto max-w-3xl px-m">
      {(block.eyebrow || block.heading || block.intro) && (
        <div class="mb-l">
          {block.eyebrow && <p class="text-xs uppercase tracking-eyebrow opacity-70">{block.eyebrow}</p>}
          {block.heading && <h2 class="mt-s font-display text-h2">{block.heading}</h2>}
          {block.intro && <p class="mt-s opacity-80 leading-relaxed">{block.intro}</p>}
        </div>
      )}
      <div class="divide-y divide-current/15 border-t border-b border-current/15">
        {items.map((qa: any) => (
          <details class="group py-m">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-m font-display text-h4">
              {qa.question}
              <span class="shrink-0 text-gold transition-transform group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <p class="mt-s opacity-85 leading-relaxed whitespace-pre-line">{qa.answer}</p>
          </details>
        ))}
      </div>
    </div>
  )
}
