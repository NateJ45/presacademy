---
// Media feature: an embedded video (YouTube/Vimeo) or an image, beside text.
// Body is plain text so it inherits the SectionShell tone color. The media side
// is editor-controlled.
import SanityImage from '@/components/SanityImage.astro';

const { block } = Astro.props as { block: any };
const mediaLeft = (block?.mediaSide ?? 'left') !== 'right';
const hasImage = !!block?.image?.asset;
const videoUrl = block?.videoUrl ?? null;

function toEmbed(url: string | null): string | null {
  if (!url) return null;
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([\w-]{11})/);
  if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
  const vimeo = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  return url;
}
const embedUrl = toEmbed(videoUrl);
const hasMedia = !!embedUrl || hasImage;
const pill =
  'press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] bg-primary text-primary-foreground hover:bg-primary-dark transition-colors';
---

{
  block && (block.heading || block.body || hasMedia) && (
    <div class="mx-auto max-w-content px-m grid grid-cols-1 md:grid-cols-2 gap-l md:gap-section-md items-center">
      <div class={mediaLeft ? 'md:order-2' : 'md:order-1'}>
        {block.eyebrow && <p class="text-xs uppercase tracking-eyebrow opacity-70">{block.eyebrow}</p>}
        {block.heading && <h2 class="mt-s font-display text-h2">{block.heading}</h2>}
        {block.body && <p class="mt-m opacity-85 leading-relaxed whitespace-pre-line">{block.body}</p>}
        {block.ctaLabel && block.ctaUrl && (
          <div class="mt-l">
            <a href={block.ctaUrl} class={pill}>{block.ctaLabel}</a>
          </div>
        )}
      </div>
      {hasMedia && (
        <div class={mediaLeft ? 'md:order-1' : 'md:order-2'}>
          {embedUrl ? (
            <div class="overflow-hidden rounded-md border border-border-soft" style="aspect-ratio: 16/9;">
              <iframe
                src={embedUrl}
                title={block.heading || 'Video'}
                loading="lazy"
                class="h-full w-full"
                style="border: 0;"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            </div>
          ) : hasImage ? (
            <div class="overflow-hidden rounded-md ring-1 ring-border-soft img-zoom group aspect-[4/3]">
              <SanityImage
                source={block.image}
                width={900}
                sizes="(min-width: 768px) 45vw, 90vw"
                alt={block.image?.alt || block.heading || ''}
                class="h-full w-full object-cover"
              />
            </div>
          ) : null}
        </div>
      )}
    </div>
  )
}
