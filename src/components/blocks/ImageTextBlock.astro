---
// Image + text block. Inner content only; SectionShell provides the background.
// Text inherits the section tone color; Portable Text body forced to inherit on
// dark tones via descendant overrides.
import SanityImage from '@/components/SanityImage.astro';
import PortableText from '@/components/PortableText';

const { block, defaultTone = 'default' } = Astro.props as { block: any; defaultTone?: string };
const imageRight = (block?.imageSide ?? 'right') !== 'left';
const hasImage = !!block?.image?.asset;
const tone = block?.background?.tone ?? defaultTone;
const onDark = !!(block?.background?.image?.asset || block?.background?.videoUrl) || tone === 'chapel' || tone === 'chapelDeep';
const ptDark = onDark
  ? '[&_p]:text-current [&_h3]:text-current [&_h4]:text-current [&_li]:text-current [&_a]:text-current [&_strong]:text-current'
  : '';
const pill =
  'press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s rounded-full text-xs font-semibold uppercase tracking-[0.18em] bg-primary text-primary-foreground hover:bg-primary-dark transition-colors';
---

{
  block && (
    <div class="mx-auto max-w-content px-m grid grid-cols-1 md:grid-cols-2 gap-l md:gap-section-md items-center">
      <div class={imageRight ? 'md:order-1' : 'md:order-2'}>
        {block.eyebrow && <p class="text-xs uppercase tracking-eyebrow opacity-70">{block.eyebrow}</p>}
        {block.heading && <h2 class="mt-s font-display text-h2">{block.heading}</h2>}
        {block.body && (
          <div class={`mt-m leading-relaxed ${ptDark}`}>
            <PortableText value={block.body} />
          </div>
        )}
        {block.ctaLabel && block.ctaUrl && (
          <div class="mt-l">
            <a href={block.ctaUrl} class={pill}>{block.ctaLabel}</a>
          </div>
        )}
      </div>
      {hasImage && (
        <div class={imageRight ? 'md:order-2' : 'md:order-1'}>
          <div class="group overflow-hidden ring-1 ring-primary/40 dark:ring-[#C7A875]/40 shadow-sm img-zoom aspect-[4/5] rounded-md">
            <SanityImage
              source={block.image}
              width={900}
              sizes="(min-width: 768px) 45vw, 90vw"
              alt={block.image?.alt || block.heading || ''}
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      )}
    </div>
  )
}
