---
// Text section block. Inner content only; SectionShell provides the background.
// Heading/eyebrow inherit the section text color; on dark tones the Portable Text
// body is forced to inherit (text-current) via descendant overrides so it reads.
import PortableText from '@/components/PortableText';

const { block, defaultTone = 'default' } = Astro.props as { block: any; defaultTone?: string };
const centered = block?.align === 'center';
const tone = block?.background?.tone ?? defaultTone;
const onDark = !!(block?.background?.image?.asset || block?.background?.videoUrl) || tone === 'chapel' || tone === 'chapelDeep';
const ptDark = onDark
  ? '[&_p]:text-current [&_h2]:text-current [&_h3]:text-current [&_h4]:text-current [&_li]:text-current [&_a]:text-current [&_strong]:text-current [&_blockquote]:text-current [&_blockquote]:border-current/40'
  : '';
---

{
  block && (
    <div class={`mx-auto max-w-3xl px-m ${centered ? 'text-center' : ''}`}>
      {block.eyebrow && <p class="text-xs uppercase tracking-eyebrow opacity-70">{block.eyebrow}</p>}
      {block.heading && <h2 class="mt-s font-display text-h2">{block.heading}</h2>}
      {block.body && (
        <div class={`mt-m leading-relaxed ${centered ? 'text-left' : ''} ${ptDark}`}>
          <PortableText value={block.body} />
        </div>
      )}
    </div>
  )
}
