---
// Foundation, edit with care
// Site footer, rebuilt for a church on the deep Chapel-green brand surface
// (the cool liturgical counterpoint to the warm page). Distinct from the base
// template's light single-strip footer.
//
// Structure (top to bottom):
//   1. Bronze accent stripe (brand signature, matches header utility bar)
//   2. Optional newsletter signup (only when siteSettings.newsletter.enabled)
//   3. Brand + mission + Plan a Visit  |  Sunday Worship card (times, address,
//      Get directions) — the church "front door" summary
//   4. Four-column link grid: Visit / Get Involved / Connect / Get in touch
//   5. Thin bottom bar: auto-year copyright, privacy link, optional credit
//
// STRUCTURE: do not edit layout/markup here to change wording. Editor-facing
// copy (service times, mission, contact, social, giving link) flows in through
// Sanity siteSettings, falling back to src/data/site.ts so real info shows
// before Sanity is wired.
//
// Tailwind v4 gotcha: max-w-xs/s/m/l are shadowed by this project's custom
// --spacing-* tokens. Use max-w-md / max-w-2xl / arbitrary values for text widths.

import { resolveSiteSettings } from '@/lib/siteSettings';
import { site } from '@/data/site';
import { IconBrandInstagram, IconBrandFacebook, IconBrandYoutube } from '@tabler/icons-react';
import { Phone, MapPin, Mail } from 'lucide-react';
import NewsletterSignup from '@/components/NewsletterSignup';
import { telHref } from '@/lib/phone';

interface NewsletterConfig {
  enabled?: boolean;
  heading?: string;
  blurb?: string;
  buttonLabel?: string;
  successMessage?: string;
  consentNote?: string;
  formActionUrl?: string | null;
  audienceId?: string | null;
}

interface Props {
  siteSettings?: {
    title?: string;
    email?: string;
    phone?: string;
    addressLine?: string;
    cityStateZip?: string;
    socialInstagram?: string;
    socialFacebook?: string;
    socialYoutube?: string;
    tagline?: string;
    mission?: string;
    worshipService?: { time?: string; day?: string; startTime24?: string; endTime24?: string } | null;
    giveUrl?: string;
    appUrl?: string;
    directoryUrl?: string;
    prayerUrl?: string;
    footerCredit?: string;
    footerCreditUrl?: string;
    newsletter?: NewsletterConfig | null;
    // Editor-managed footer link columns (Site Settings -> Navigation). When
    // empty, the built-in columns below render.
    footerColumns?: Array<{
      title?: string;
      links?: Array<{ label?: string; href?: string }>;
    }> | null;
  } | null;
}

const { siteSettings } = Astro.props as Props;

// Every identity / contact / social value resolves through one shared helper
// (see src/lib/siteSettings.ts) so the footer can't drift from the header, the
// pages, or the JSON-LD. Empty Sanity fields render blank (or hide) rather than
// showing a hardcoded stand-in.
const settings = resolveSiteSettings(siteSettings);
const brandName = settings.brandName;
const email = settings.email;
const phone = settings.phone;
const officeHours = settings.officeHours; // undefined when unset -> line hides
const ig = settings.social.instagram;
const fb = settings.social.facebook;
const yt = settings.social.youtube;
const tagline = settings.tagline;
const mission = settings.mission;
const addressLine = settings.addressLine;
const cityStateZip = settings.cityStateZip;
const mapHref = settings.mapHref;

const currentYear = new Date().getFullYear();
const siteCredit = siteSettings?.footerCredit;
const siteCreditUrl = siteSettings?.footerCreditUrl;

// STRUCTURE: footer navigation, grouped to mirror the header IA.
const EXPLORE_LINKS = [
  { label: 'Courses', href: '/courses' },
  { label: 'Faculty', href: '/faculty' },
  { label: 'Events', href: '/events' },
  { label: 'Resources', href: '/resources' },
];
const ABOUT_LINKS = [
  { label: 'About', href: '/about' },
  { label: 'For You', href: '/for-you' },
  { label: 'Pricing & Scholarships', href: '/pricing' },
  { label: 'FAQ', href: '/faq' },
];
const START_LINKS = [
  { label: 'Get started', href: '/get-started' },
  { label: 'Request information', href: '/get-started' },
  { label: 'Book a free intro', href: '/get-started' },
  { label: 'Contact', href: '/contact' },
];

// Footer link columns. Editors can override these in Site Settings -> Navigation
// (Footer link columns). When unset, the built-in columns render, with the
// optional app/directory/prayer integrations appended to Connect. The separate
// "Get in touch" column (contact + social) always renders and is not configured
// here. External links open in a new tab.
type FooterColumn = { title: string; links: { label: string; href: string; external?: boolean }[] };

const FALLBACK_FOOTER_COLUMNS: FooterColumn[] = [
  { title: 'Explore', links: EXPLORE_LINKS },
  { title: 'About', links: ABOUT_LINKS },
  { title: 'Get started', links: START_LINKS },
];

function footerColumnsFromSettings(
  cols?: Array<{ title?: string; links?: Array<{ label?: string; href?: string }> }> | null,
): FooterColumn[] | null {
  if (!Array.isArray(cols) || cols.length === 0) return null;
  const mapped: FooterColumn[] = [];
  for (const c of cols) {
    const links = (Array.isArray(c?.links) ? c.links : [])
      .filter((l) => l?.label && l?.href)
      .map((l) => ({ label: l.label as string, href: l.href as string }));
    if (c?.title && links.length > 0) mapped.push({ title: c.title, links });
  }
  return mapped.length > 0 ? mapped : null;
}

const FOOTER_COLUMNS: FooterColumn[] =
  footerColumnsFromSettings(siteSettings?.footerColumns) ?? FALLBACK_FOOTER_COLUMNS;

// Shared link class for the footer columns (cream on green, animated underline).
const footerLink =
  'link-underline inline-block text-chapel-foreground/80 hover:text-white transition-colors';
---

<footer class="bg-chapel-deep text-chapel-foreground">
  {/* Brand accent stripe — matches the header utility bar + mobile drawer. */}
  <div class="h-1 bg-primary" aria-hidden="true"></div>

  {/* Newsletter signup — renders only when siteSettings.newsletter.enabled. */}
  {siteSettings?.newsletter?.enabled && (
    <div class="mx-auto max-w-content px-m pt-l">
      <div class="max-w-md mx-auto">
        <NewsletterSignup
          client:visible
          newsletter={siteSettings.newsletter}
          source="footer"
        />
      </div>
    </div>
  )}

  {/* ---- Brand + mission  |  Sunday Worship card ---------------------------- */}
  <div class="mx-auto max-w-content px-m pt-section-md pb-l grid gap-l md:grid-cols-2 md:gap-section-md items-start">
    {/* Brand + mission + Plan a Visit */}
    <div class="text-center md:text-left">
      <a href="/" aria-label={`${brandName} home`} class="inline-flex flex-col leading-none hover:opacity-80 transition-opacity">
        <span class="font-display text-2xl text-chapel-foreground">{site.wordmark.line1}</span>
        {site.wordmark.line2 && (
          <span class="font-display text-lg text-chapel-foreground/70 mt-0.5">{site.wordmark.line2}</span>
        )}
      </a>
      <p class="mt-m text-chapel-foreground/75 italic font-display text-lg leading-snug max-w-[32rem] mx-auto md:mx-0">
        {mission}
      </p>
      <a
        href="/get-started"
        class="press-tactile mt-m inline-flex items-center px-l py-2.5 rounded-full text-xs uppercase tracking-eyebrow font-semibold bg-primary text-primary-foreground hover:bg-primary-dark transition-colors"
      >
        Request information
      </a>
    </div>

    {/* Where we meet — the campus address + directions. */}
    <div class="rounded-lg border border-chapel-foreground/15 bg-white/5 p-l text-center md:text-left">
      <p class="text-xs uppercase tracking-eyebrow text-chapel-foreground/70">Where we meet</p>
      <div class="mt-s mb-m h-px w-12 bg-gold/60 mx-auto md:mx-0" aria-hidden="true"></div>
      <p class="flex items-start justify-center md:justify-start gap-xs text-chapel-foreground/85">
        <MapPin size={16} aria-hidden="true" className="mt-1 shrink-0 text-gold" />
        <span>{addressLine}<br />{cityStateZip}</span>
      </p>
      <a
        href={mapHref}
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline mt-s inline-block text-sm font-semibold text-chapel-foreground hover:text-white transition-colors"
      >
        Get directions
      </a>
      <p class="mt-m text-sm text-chapel-foreground/70">Courses meet in person, in cohorts, on the West Chester campus.</p>
    </div>
  </div>

  {/* ---- Four-column link grid. Single centered column on mobile. ----------- */}
  <div class="mx-auto max-w-content px-m pb-l grid gap-l grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 text-center sm:text-left border-t border-chapel-foreground/15 pt-l">
    {FOOTER_COLUMNS.map((col, i) => (
      <nav aria-labelledby={`footer-col-${i}`}>
        <p id={`footer-col-${i}`} class="text-xs uppercase tracking-eyebrow text-chapel-foreground/70 mb-s">{col.title}</p>
        <ul class="text-sm space-y-2 list-none p-0">
          {col.links.map((l) => (
            <li>
              <a
                href={l.href}
                class={footerLink}
                {...((l.external || /^https?:\/\//.test(l.href)) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    ))}

    {/* GET IN TOUCH — email, phone, office hours, socials. */}
    <div>
      <p class="text-xs uppercase tracking-eyebrow text-chapel-foreground/70 mb-s">Get in touch</p>
      <address class="not-italic text-sm space-y-2">
        {email && (
          <p>
            <a href={`mailto:${email}`} class="inline-flex items-center gap-xs text-chapel-foreground/85 hover:text-white transition-colors">
              <Mail size={14} aria-hidden="true" />
              {email}
            </a>
          </p>
        )}
        {phone && (
          <p>
            <a href={telHref(phone)} class="inline-flex items-center gap-xs text-chapel-foreground/85 hover:text-white transition-colors">
              <Phone size={14} aria-hidden="true" />
              {phone}
            </a>
          </p>
        )}
        {officeHours && (
          <p class="text-chapel-foreground/60">Office hours: {officeHours}</p>
        )}
      </address>
      {(ig || fb || yt) && (
        <ul class="mt-m flex justify-center sm:justify-start gap-s text-sm list-none p-0">
          {ig && (
            <li>
              <a href={ig} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-chapel-foreground/25 text-chapel-foreground hover:bg-white/10 hover:border-white/40 hover:text-white transition-colors">
                <IconBrandInstagram size={20} stroke={1.5} />
              </a>
            </li>
          )}
          {fb && (
            <li>
              <a href={fb} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-chapel-foreground/25 text-chapel-foreground hover:bg-white/10 hover:border-white/40 hover:text-white transition-colors">
                <IconBrandFacebook size={20} stroke={1.5} />
              </a>
            </li>
          )}
          {yt && (
            <li>
              <a href={yt} target="_blank" rel="noopener noreferrer" aria-label="YouTube"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-chapel-foreground/25 text-chapel-foreground hover:bg-white/10 hover:border-white/40 hover:text-white transition-colors">
                <IconBrandYoutube size={20} stroke={1.5} />
              </a>
            </li>
          )}
        </ul>
      )}
    </div>
  </div>

  {/* Thin bottom bar — copyright, privacy, optional credit. */}
  <div class="border-t border-chapel-foreground/15">
    <div class="mx-auto max-w-content px-m py-m flex flex-col sm:flex-row items-center justify-center sm:justify-between gap-xs text-xs text-chapel-foreground/70 text-center">
      <p>© {currentYear} {brandName}</p>
      <div class="flex items-center gap-m">
        <a href="/pricing" class="link-underline hover:text-white transition-colors">Pricing</a>
        <a href="/privacy" class="underline underline-offset-2 hover:text-white transition-colors">Privacy policy</a>
        {siteCredit && (
          siteCreditUrl ? (
            <a href={siteCreditUrl} target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-white transition-colors">{siteCredit}</a>
          ) : (
            <span>{siteCredit}</span>
          )
        )}
      </div>
    </div>
  </div>
</footer>
