---
// Foundation, edit with care
// Site footer on the deep Chapel-green brand surface — composed as a printed
// book's COLOPHON page (the bookish / academic brand idiom) so it reads nothing
// like a generic org footer.
//
// Structure (top to bottom):
//   1. Bronze accent stripe (brand signature, matches the header utility bar)
//   2. Optional newsletter signup (only when siteSettings.newsletter.enabled)
//   3. Masthead: the wordmark at editorial scale + mission + the two CTAs
//   4. Imprint: where-we-meet / contact, the nav index, follow along — each
//      column labelled with a brass eyebrow rule
//   5. Funding acknowledgment: "Made possible by the {funder}" (current
//      underwriter, the Presbytery of Cincinnati)
//   6. Colophon: a monogram seal, the imprint line (locality + denomination),
//      the typeface credit, legal links, and the designer credit (always shown)
//
// STRUCTURE: do not edit layout/markup here to change wording. Editor-facing
// copy (service times, mission, contact, social, giving link) flows in through
// Sanity siteSettings, falling back to src/data/site.ts so real info shows
// before Sanity is wired.
//
// Tailwind v4 gotcha: max-w-xs/s/m/l are shadowed by this project's custom
// --spacing-* tokens. Use max-w-md / max-w-2xl / arbitrary values for text widths.

import { resolveSiteSettings } from '@/lib/siteSettings';
import { site } from '@/data/site';
import { IconBrandInstagram, IconBrandFacebook, IconBrandYoutube } from '@tabler/icons-react';
import { Phone, MapPin, Mail } from 'lucide-react';
import NewsletterSignup from '@/components/NewsletterSignup';
import { telHref } from '@/lib/phone';

interface NewsletterConfig {
  enabled?: boolean;
  heading?: string;
  blurb?: string;
  buttonLabel?: string;
  successMessage?: string;
  consentNote?: string;
  formActionUrl?: string | null;
  audienceId?: string | null;
}

interface Props {
  siteSettings?: {
    title?: string;
    email?: string;
    phone?: string;
    addressLine?: string;
    cityStateZip?: string;
    socialInstagram?: string;
    socialFacebook?: string;
    socialYoutube?: string;
    tagline?: string;
    mission?: string;
    funder?: string;
    worshipService?: { time?: string; day?: string; startTime24?: string; endTime24?: string } | null;
    giveUrl?: string;
    appUrl?: string;
    directoryUrl?: string;
    prayerUrl?: string;
    footerCredit?: string;
    footerCreditUrl?: string;
    newsletter?: NewsletterConfig | null;
    // Editor-managed footer link columns (Site Settings -> Navigation). When
    // empty, the built-in columns below render.
    footerColumns?: Array<{
      title?: string;
      links?: Array<{ label?: string; href?: string }>;
    }> | null;
  } | null;
}

const { siteSettings } = Astro.props as Props;

// Every identity / contact / social value resolves through one shared helper
// (see src/lib/siteSettings.ts) so the footer can't drift from the header, the
// pages, or the JSON-LD. Empty Sanity fields render blank (or hide) rather than
// showing a hardcoded stand-in.
const settings = resolveSiteSettings(siteSettings);
const brandName = settings.brandName;
const email = settings.email;
const phone = settings.phone;
const officeHours = settings.officeHours; // undefined when unset -> line hides
const ig = settings.social.instagram;
const fb = settings.social.facebook;
const yt = settings.social.youtube;
const tagline = settings.tagline;
const mission = settings.mission;
const addressLine = settings.addressLine;
const cityStateZip = settings.cityStateZip;
const mapHref = settings.mapHref;

const currentYear = new Date().getFullYear();
const siteCredit = siteSettings?.footerCredit;
const siteCreditUrl = siteSettings?.footerCreditUrl;

// Designer credit — always shown in the colophon. Editable via Sanity
// (siteSettings.footerCredit / footerCreditUrl); defaults to the studio that
// built the site so the credit is never missing.
const creditLabel = siteCredit ?? 'Designed by Nixon Creative Studio';
const creditUrl = siteCreditUrl ?? 'https://www.nixoncreativestudio.com';

// Short locality for the colophon imprint line (falls back to the full
// city/state/zip; the join in the markup drops it if neither is set).
const locality = settings.addressLocality ?? cityStateZip;

// Current-year underwriter, shown as a footer acknowledgment on every page.
// Editable in Sanity (Site Settings -> Funder); falls back to the current funder
// when unset, and clearing the field in Studio hides the line.
const funder = siteSettings?.funder ?? 'Presbytery of Cincinnati';

// STRUCTURE: footer navigation, grouped to mirror the header IA.
const EXPLORE_LINKS = [
  { label: 'Courses', href: '/courses' },
  { label: 'Faculty', href: '/faculty' },
  { label: 'Events', href: '/events' },
  { label: 'Resources', href: '/resources' },
];
const ABOUT_LINKS = [
  { label: 'About', href: '/about' },
  { label: 'For You', href: '/for-you' },
  { label: 'Pricing & Scholarships', href: '/pricing' },
  { label: 'FAQ', href: '/faq' },
];
const START_LINKS = [
  { label: 'Get started', href: '/get-started' },
  { label: 'Request information', href: '/get-started' },
  { label: 'Book a free intro', href: '/get-started' },
  { label: 'Contact', href: '/contact' },
];

// Footer link columns. Editors can override these in Site Settings -> Navigation
// (Footer link columns). When unset, the built-in columns render, with the
// optional app/directory/prayer integrations appended to Connect. The separate
// "Get in touch" column (contact + social) always renders and is not configured
// here. External links open in a new tab.
type FooterColumn = { title: string; links: { label: string; href: string; external?: boolean }[] };

const FALLBACK_FOOTER_COLUMNS: FooterColumn[] = [
  { title: 'Explore', links: EXPLORE_LINKS },
  { title: 'About', links: ABOUT_LINKS },
  { title: 'Get started', links: START_LINKS },
];

function footerColumnsFromSettings(
  cols?: Array<{ title?: string; links?: Array<{ label?: string; href?: string }> }> | null,
): FooterColumn[] | null {
  if (!Array.isArray(cols) || cols.length === 0) return null;
  const mapped: FooterColumn[] = [];
  for (const c of cols) {
    const links = (Array.isArray(c?.links) ? c.links : [])
      .filter((l) => l?.label && l?.href)
      .map((l) => ({ label: l.label as string, href: l.href as string }));
    if (c?.title && links.length > 0) mapped.push({ title: c.title, links });
  }
  return mapped.length > 0 ? mapped : null;
}

const FOOTER_COLUMNS: FooterColumn[] =
  footerColumnsFromSettings(siteSettings?.footerColumns) ?? FALLBACK_FOOTER_COLUMNS;

// Shared link class for the footer columns (cream on green, animated underline).
const footerLink =
  'link-underline inline-block text-chapel-foreground/80 hover:text-white transition-colors';
---

<footer
  class="bg-chapel-deep text-chapel-foreground"
  style="background-image: radial-gradient(rgba(241, 234, 217, 0.05) 1px, transparent 1.5px); background-size: 26px 26px;"
>
  {/* Brand accent stripe — matches the header utility bar + mobile drawer. */}
  <div class="h-1 bg-primary" aria-hidden="true"></div>

  {/* Newsletter signup — renders only when siteSettings.newsletter.enabled. */}
  {siteSettings?.newsletter?.enabled && (
    <div class="mx-auto max-w-content px-m pt-l">
      <div class="max-w-md mx-auto">
        <NewsletterSignup
          client:visible
          newsletter={siteSettings.newsletter}
          source="footer"
        />
      </div>
    </div>
  )}

  {/* ---- Masthead: the wordmark at editorial scale + a closing invitation. -- */}
  <div class="mx-auto max-w-content px-m pt-section-md pb-l" data-reveal>
    <div class="grid gap-l lg:grid-cols-[1.45fr_1fr] lg:items-end lg:gap-section-md">
      <div>
        <p class="flex items-center gap-2 text-xs uppercase tracking-eyebrow text-chapel-foreground/65">
          <span class="h-px w-6 bg-gold/70" aria-hidden="true"></span>
          {tagline}
        </p>
        <a
          href="/"
          aria-label={`${brandName} home`}
          class="mt-s block leading-[0.9] tracking-[-0.02em] hover:opacity-90 transition-opacity"
        >
          <span class="block font-display text-chapel-foreground" style="font-size: clamp(2.5rem, 7vw, 5.25rem)">{site.wordmark.line1}</span>
          {site.wordmark.line2 && (
            <span class="block font-display text-chapel-foreground/55" style="font-size: clamp(2.5rem, 7vw, 5.25rem)">{site.wordmark.line2}</span>
          )}
        </a>
      </div>
      <div class="lg:pb-2">
        <p class="font-display text-xl leading-snug text-chapel-foreground/85 max-w-[32rem]">{mission}</p>
        <div class="mt-l flex flex-wrap gap-s">
          <a
            href="/get-started"
            class="press-tactile inline-flex items-center rounded-full bg-chapel-foreground px-l py-2.5 text-xs uppercase tracking-eyebrow font-semibold text-chapel-deep hover:opacity-90 transition-opacity"
          >
            Request information
          </a>
          <a
            href="/get-started"
            class="press-tactile inline-flex items-center rounded-full border border-chapel-foreground/35 px-l py-2.5 text-xs uppercase tracking-eyebrow font-semibold text-chapel-foreground hover:bg-white/10 transition-colors"
          >
            Book a free intro
          </a>
        </div>
      </div>
    </div>
  </div>

  {/* ---- Imprint: where we meet · the index · follow along. --------------- */}
  <div class="mx-auto max-w-content px-m py-l grid gap-l sm:grid-cols-2 lg:grid-cols-12 border-t border-chapel-foreground/15" data-reveal>
    {/* Where we meet + contact */}
    <div class="lg:col-span-4">
      <p class="flex items-center gap-2 text-xs uppercase tracking-eyebrow text-chapel-foreground/65">
        <span class="h-px w-5 bg-gold/70" aria-hidden="true"></span>
        Where we meet
      </p>
      <address class="mt-m not-italic text-sm leading-relaxed space-y-2 text-chapel-foreground/85">
        <p class="flex items-start gap-2">
          <MapPin size={15} className="mt-0.5 shrink-0 text-gold" aria-hidden="true" />
          <span>{addressLine}<br />{cityStateZip}</span>
        </p>
        {email && (
          <p>
            <a href={`mailto:${email}`} class="link-underline inline-flex items-center gap-2 hover:text-white transition-colors">
              <Mail size={14} aria-hidden="true" />{email}
            </a>
          </p>
        )}
        {phone && (
          <p>
            <a href={telHref(phone)} class="link-underline inline-flex items-center gap-2 hover:text-white transition-colors">
              <Phone size={14} aria-hidden="true" />{phone}
            </a>
          </p>
        )}
        {officeHours && <p class="text-chapel-foreground/55">Office hours: {officeHours}</p>}
      </address>
      <a
        href={mapHref}
        target="_blank"
        rel="noopener noreferrer"
        class="link-underline mt-s inline-block text-sm font-semibold text-chapel-foreground hover:text-white transition-colors"
      >
        Get directions
      </a>
    </div>

    {/* The index — editor-managed nav columns. */}
    <div class="lg:col-span-5 grid grid-cols-2 sm:grid-cols-3 gap-l">
      {FOOTER_COLUMNS.map((col, i) => (
        <nav aria-labelledby={`footer-col-${i}`}>
          <p id={`footer-col-${i}`} class="flex items-center gap-2 text-xs uppercase tracking-eyebrow text-chapel-foreground/65">
            <span class="h-px w-5 bg-gold/70" aria-hidden="true"></span>
            {col.title}
          </p>
          <ul class="mt-m text-sm space-y-2.5 list-none p-0">
            {col.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class={footerLink}
                  {...((l.external || /^https?:\/\//.test(l.href)) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    {/* Follow along — social, or a contact nudge when none are set. */}
    <div class="lg:col-span-3">
      <p class="flex items-center gap-2 text-xs uppercase tracking-eyebrow text-chapel-foreground/65">
        <span class="h-px w-5 bg-gold/70" aria-hidden="true"></span>
        Follow along
      </p>
      {(ig || fb || yt) ? (
        <ul class="mt-m flex gap-s list-none p-0">
          {ig && (
            <li>
              <a href={ig} target="_blank" rel="noopener noreferrer" aria-label="Instagram"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-chapel-foreground/25 text-chapel-foreground hover:bg-white/10 hover:border-white/40 hover:text-white transition-colors">
                <IconBrandInstagram size={20} stroke={1.5} />
              </a>
            </li>
          )}
          {fb && (
            <li>
              <a href={fb} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-chapel-foreground/25 text-chapel-foreground hover:bg-white/10 hover:border-white/40 hover:text-white transition-colors">
                <IconBrandFacebook size={20} stroke={1.5} />
              </a>
            </li>
          )}
          {yt && (
            <li>
              <a href={yt} target="_blank" rel="noopener noreferrer" aria-label="YouTube"
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-chapel-foreground/25 text-chapel-foreground hover:bg-white/10 hover:border-white/40 hover:text-white transition-colors">
                <IconBrandYoutube size={20} stroke={1.5} />
              </a>
            </li>
          )}
        </ul>
      ) : (
        <a href="/contact" class="link-underline mt-m inline-block text-sm text-chapel-foreground/80 hover:text-white transition-colors">Get in touch</a>
      )}
    </div>
  </div>

  {/* ---- Funding acknowledgment — the school's current-year underwriter. ---- */}
  {funder && (
    <div class="mx-auto max-w-content px-m pb-l flex items-center justify-center gap-3 text-center">
      <span class="h-px w-8 bg-gold/45" aria-hidden="true"></span>
      <p class="text-xs uppercase tracking-[0.14em] text-chapel-foreground/60">Made possible by the {funder}</p>
      <span class="h-px w-8 bg-gold/45" aria-hidden="true"></span>
    </div>
  )}

  {/* ---- Colophon — the printed-imprint bottom bar: a monogram seal, the
       imprint line, the typeface credit, legal links, and the designer credit
       (always shown, editable via Sanity). -------------------------------- */}
  <div class="border-t border-chapel-foreground/15">
    <div class="mx-auto max-w-content px-m py-l flex flex-col gap-m lg:flex-row lg:items-center lg:justify-between">
      {/* Monogram seal + imprint line */}
      <div class="flex items-center gap-3">
        <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-[11px] border border-chapel-foreground/30 font-display text-base leading-none text-chapel-foreground/90" aria-hidden="true">PA</span>
        <p class="text-xs leading-relaxed text-chapel-foreground/65">
          <span class="font-medium text-chapel-foreground/90">{brandName}</span><br />
          {[locality, 'PC(USA)'].filter(Boolean).join('  ·  ')}
        </p>
      </div>

      {/* Typeface colophon + legal + designer credit */}
      <div class="flex flex-col gap-2 lg:items-end">
        <p class="text-[0.65rem] uppercase tracking-[0.16em] text-chapel-foreground/45">Set in Fraunces &amp; Source Sans&nbsp;3</p>
        <div class="flex flex-wrap items-center gap-x-m gap-y-1 text-xs text-chapel-foreground/65">
          <span>© {currentYear} {brandName}</span>
          <a href="/pricing" class="link-underline hover:text-white transition-colors">Pricing</a>
          <a href="/privacy" class="link-underline hover:text-white transition-colors">Privacy</a>
          {creditUrl ? (
            <a href={creditUrl} target="_blank" rel="noopener noreferrer" class="link-underline text-chapel-foreground/80 hover:text-white transition-colors">{creditLabel}</a>
          ) : (
            <span class="text-chapel-foreground/80">{creditLabel}</span>
          )}
        </div>
      </div>
    </div>
  </div>
</footer>
