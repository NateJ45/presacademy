---
// Safe to edit by hand
// /quiz — Style quiz page.
// Fetches the styleQuiz singleton from Sanity. If the doc is absent or has
// fewer than 2 questions, renders a warm "coming soon" state instead of an error.
// Passes the full quiz config + pre-built archetype image URLs into the React island.

import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import StyleQuiz from '@/components/StyleQuiz';
import { getStyleQuiz, getSiteSettings } from '@/lib/queries';
import { getSectionVisibility } from '@/lib/sectionVisibility';
import { breadcrumbSchema } from '@/lib/schemas';
import { urlFor } from '@/lib/sanity';
import { site } from '@/data/site';
import type { StyleQuizConfig } from '@/components/StyleQuiz';

const [quiz, siteSettings] = await Promise.all([
  getStyleQuiz().catch(() => null),
  getSiteSettings().catch(() => null),
]);

// Section visibility guard.
const visible = getSectionVisibility(siteSettings?.sectionVisibility);
if (!visible.styleQuiz) return Astro.redirect('/');

const title = 'What Is Your Design Style? · Studio Starter';
const description =
  'Take the style quiz to find your design archetype and get a personalized recommendation.';

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Style Quiz', url: `${site.url}/quiz` },
  ]),
];

// Validate the quiz doc: need at least 2 questions for a meaningful quiz.
const hasValidQuiz =
  quiz &&
  Array.isArray(quiz.questions) &&
  quiz.questions.length >= 2 &&
  Array.isArray(quiz.archetypes) &&
  quiz.archetypes.length >= 2;

// Pre-build Sanity image URLs for archetypes so the React island doesn't need
// the Sanity URL builder (keeps island bundle lean — no extra client-side dep).
// Each archetype image becomes a simple { url, alt } pair. We build multiple
// sizes for srcset in the island.
type ArchetypeImageUrl = { url: string; url2x: string; alt: string };
type ArchetypeWithUrls = {
  name: string;
  slug: string;
  description: unknown;
  images: ArchetypeImageUrl[];
  recommendedServiceRef?: { _id: string; name: string; slug: string } | null;
  resultCtaLabel?: string;
};

function buildArchetypeImages(arch: any): ArchetypeImageUrl[] {
  if (!Array.isArray(arch?.images)) return [];
  return arch.images
    .filter((img: any) => img?.asset)
    .map((img: any) => ({
      url: urlFor(img).width(600).quality(75).auto('format').url(),
      url2x: urlFor(img).width(1200).quality(75).auto('format').url(),
      alt: img.alt ?? '',
    }));
}

// Build answer image URLs for questions (used by the island for <img> rendering).
// Same reason: avoids shipping the Sanity URL builder to the client.
type AnswerImageUrl = { url: string; url2x: string; alt: string };
type AnswerWithUrl = {
  label: string;
  image?: AnswerImageUrl;
  archetypeWeights: Array<{ archetypeSlug: string; weight: number }>;
};
type QuestionWithUrls = {
  prompt: string;
  helpText?: string;
  answers: AnswerWithUrl[];
};

function buildAnswerImage(img: any): AnswerImageUrl | undefined {
  if (!img?.asset) return undefined;
  return {
    url: urlFor(img).width(400).height(300).fit('crop').quality(75).auto('format').url(),
    url2x: urlFor(img).width(800).height(600).fit('crop').quality(75).auto('format').url(),
    alt: img.alt ?? '',
  };
}

// Serialize the quiz config for the island — only if the quiz is valid.
let quizConfig: StyleQuizConfig | null = null;

if (hasValidQuiz) {
  const archetypesWithUrls: ArchetypeWithUrls[] = (quiz.archetypes ?? []).map((arch: any) => ({
    name: arch.name ?? '',
    slug: arch.slug ?? '',
    description: arch.description ?? null,
    images: buildArchetypeImages(arch),
    recommendedServiceRef: arch.recommendedServiceRef ?? null,
    resultCtaLabel: arch.resultCtaLabel ?? 'Book a consultation',
  }));

  const questionsWithUrls: QuestionWithUrls[] = (quiz.questions ?? []).map((q: any) => ({
    prompt: q.prompt ?? '',
    helpText: q.helpText ?? '',
    answers: (q.answers ?? []).map((a: any) => ({
      label: a.label ?? '',
      image: buildAnswerImage(a.image),
      archetypeWeights: Array.isArray(a.archetypeWeights)
        ? a.archetypeWeights.map((w: any) => ({
            archetypeSlug: w.archetypeSlug ?? '',
            weight: typeof w.weight === 'number' ? w.weight : 1,
          }))
        : [],
    })),
  }));

  const qualifiers = Array.isArray(quiz.qualifiers)
    ? quiz.qualifiers.map((q: any) => ({
        prompt: q.prompt ?? '',
        type: q.type ?? 'budget',
        options: Array.isArray(q.options)
          ? q.options.map((o: any) => ({ label: o.label ?? '', value: o.value ?? '' }))
          : [],
      }))
    : [];

  quizConfig = {
    questions: questionsWithUrls,
    qualifiers,
    archetypes: archetypesWithUrls,
    gate: {
      mode: quiz.gate?.mode ?? 'optional',
      heading: quiz.gate?.heading ?? '',
      blurb: quiz.gate?.blurb ?? '',
      consentNote: quiz.gate?.consentNote ?? '',
      espTag: quiz.gate?.espTag ?? '',
    },
    routing: {
      highIntentRule: quiz.routing?.highIntentRule ?? '',
      bookCtaLabel: quiz.routing?.bookCtaLabel ?? 'Book a consultation',
      guideCtaLabel: quiz.routing?.guideCtaLabel ?? 'Get the free guide',
      guideRef: quiz.routing?.guideRef
        ? { slug: quiz.routing.guideRef.slug ?? '' }
        : null,
    },
  };
}

const heroEyebrow = quiz?.introEyebrow ?? 'Discover Your Style';
const heroHeadline = quiz?.introHeadline ?? 'What Is Your Design Style?';
const heroSubhead = quiz?.introSubhead ?? '';
---

<BaseLayout {title} {description} {schemas} {siteSettings} seoImage={quiz?.seoImage}>
  <Hero
    eyebrow={heroEyebrow}
    headline={heroHeadline}
    subhead={heroSubhead}
    backgroundImage={quiz?.introImage ?? null}
    headingId="quiz-hero-heading"
    size="short"
  />

  <main id="quiz-main">
    {hasValidQuiz && quizConfig ? (
      <StyleQuiz client:visible config={quizConfig} />
    ) : (
      <section
        class="mx-auto max-w-content px-m py-section-lg text-center"
        aria-labelledby="quiz-coming-heading"
      >
        <div class="mx-auto max-w-xl">
          <div class="h-0.5 bg-primary w-16 mx-auto mb-l" aria-hidden="true"></div>
          <h2
            id="quiz-coming-heading"
            class="font-display text-h2 text-foreground"
          >
            Coming soon
          </h2>
          <p class="mt-m text-foreground/80 text-lg">
            This quiz is almost ready. Check back soon to find your design style
            and get a personal recommendation.
          </p>
          <div class="mt-l flex flex-wrap justify-center gap-s">
            <a
              href="/contact"
              class="inline-flex items-center px-l py-s bg-primary-dark text-white font-semibold uppercase tracking-widest text-sm hover:bg-accent-dark transition-colors press-tactile"
            >
              Get in touch
            </a>
            <a
              href="/portfolio"
              class="inline-flex items-center px-l py-s border border-primary text-link font-semibold uppercase tracking-widest text-sm hover:bg-accent transition-colors press-tactile"
            >
              Browse the portfolio
            </a>
          </div>
        </div>
      </section>
    )}
  </main>
</BaseLayout>
