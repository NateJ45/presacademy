---
// Safe to edit by hand for copy + structure changes.
// E-Design landing page. Productised offering for remote / online design clients.
//
// Sections:
//   1. Hero (image or text)
//   2. Intro copy (Portable Text)
//   3. How It Works — numbered steps
//   4. What's Included — bullet list
//   5. Pricing Tiers — ServiceCard-style columns
//   6. FAQ references — FaqAccordion (flat, no category grouping)
//   7. Final CTA
//
// Primary CTA always routes to /contact?type=e-design.
// Graceful coming-soon state when the eDesignPage Sanity doc is absent.

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEDesignPage, getSiteSettings } from '@/lib/queries';
import { getSectionVisibility } from '@/lib/sectionVisibility';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';

import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import FaqAccordion from '@/components/FaqAccordion';
import FinalCta from '@/components/FinalCta.astro';
import PortableText from '@/components/PortableText';

const [page, siteSettings] = await Promise.all([
  getEDesignPage().catch(() => null),
  getSiteSettings().catch(() => null),
]);

// Section visibility guard.
const visible = getSectionVisibility(siteSettings?.sectionVisibility);
if (!visible.eDesign) return Astro.redirect('/');

const title       = page?.seoTitle       ?? 'E-Design · Online Interior Design';
const description = page?.seoDescription ?? 'Professional interior design delivered remotely. Flat-fee pricing, digital mood boards, and a complete room plan, no travel required.';

const heroEyebrow  = page?.heroEyebrow  ?? 'Online Design.';
const heroHeadline = page?.heroHeadline ?? 'Beautiful Rooms, No Matter Where You Are.';
const heroSubhead  = page?.heroSubhead  ?? '';

const schemas = [
  breadcrumbSchema([
    { name: 'Home',     url: site.url },
    { name: 'E-Design', url: `${site.url}/e-design` },
  ]),
];

// Contact CTA href: always preselects the E-Design option in the form.
const CONTACT_HREF = '/contact?type=e-design';
---

<BaseLayout {title} {description} {schemas} {siteSettings} seoImage={page?.seoImage}>

  {/* ------- 1. Hero --------------------------------------------------------- */}
  <Hero
    eyebrow={heroEyebrow}
    headline={heroHeadline}
    subhead={heroSubhead}
    backgroundImage={page?.heroImage}
    headingId="edesign-hero-heading"
    size="short"
    scriptAccent={page?.heroScriptAccent ?? undefined}
  />

  {/* ======= COMING-SOON STATE ================================================
      When the eDesignPage document has not been published yet, we render a
      minimal holding page rather than a blank / broken page. The page stays
      live in the nav so Google keeps crawling it; the copy sets expectations
      without making a false promise. */}
  {!page ? (
    <section class="bg-background" aria-labelledby="edesign-coming-soon">
      <div class="mx-auto max-w-content px-m py-section-lg text-center max-w-2xl">
        <SectionHeading
          eyebrow="Coming Soon."
          headline="E-Design details are on the way."
          subhead="We're pulling together the full overview. In the meantime, reach out. We're happy to walk you through the remote design process directly."
          headingId="edesign-coming-soon"
          align="center"
          class="mx-auto"
        />
        <div class="mt-l flex justify-center">
          <a
            href={CONTACT_HREF}
            class="press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s text-xs font-semibold uppercase tracking-[0.18em] rounded-sm bg-primary-dark text-white hover:bg-accent-dark transition-colors"
          >
            Inquire about E-Design
          </a>
        </div>
      </div>
    </section>
  ) : (
    <>
      {/* ------- 2. Intro copy ----------------------------------------------- */}
      {page.intro && page.intro.length > 0 && (
        <section class="bg-background" aria-labelledby="edesign-intro-heading">
          <div class="mx-auto max-w-content px-m py-section-lg">
            <div class="max-w-3xl mx-auto">
              <SectionHeading
                eyebrow="The Offering."
                headline="What is E-Design?"
                headingId="edesign-intro-heading"
              />
              <div class="mt-l">
                <PortableText
                  value={page.intro}
                  className="text-foreground/85 text-lg leading-relaxed"
                />
              </div>
            </div>
          </div>
        </section>
      )}

      {/* ------- 3. How It Works --------------------------------------------- */}
      {page.howItWorks && page.howItWorks.length > 0 && (
        <section class="surface-warm bg-muted" aria-labelledby="edesign-how-heading">
          <div class="mx-auto max-w-content px-m py-section-lg">
            <SectionHeading
              eyebrow="The Process."
              headline="How E-Design Works."
              headingId="edesign-how-heading"
              align="center"
              class="mx-auto"
            />

            <ol class="mt-section-lg grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-l list-none p-0">
              {page.howItWorks.map((step: { stepNumber: number; title: string; body?: string }) => (
                <li class="card-lift relative flex flex-col bg-card text-card-foreground border border-border-soft rounded-md overflow-hidden shadow-[0_4px_18px_-14px_rgba(61,61,61,0.18)]">
                  {/* Brand-stripe signature */}
                  <div class="h-0.5 bg-primary" aria-hidden="true"></div>
                  <div class="p-l flex flex-col gap-s">
                    {/* Step numeral in Soft Sage — matches ProcessStep treatment */}
                    <span
                      class="font-mono text-4xl font-bold text-tertiary/60 leading-none"
                      aria-hidden="true"
                    >
                      {String(step.stepNumber).padStart(2, '0')}
                    </span>
                    <h3 class="font-display text-h3 text-foreground">{step.title}</h3>
                    {step.body && (
                      <p class="text-foreground/80 text-base leading-relaxed">{step.body}</p>
                    )}
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </section>
      )}

      {/* ------- 4. What's Included ------------------------------------------ */}
      {page.whatsIncluded && page.whatsIncluded.length > 0 && (
        <section class="bg-background" aria-labelledby="edesign-included-heading">
          <div class="mx-auto max-w-content px-m py-section-lg">
            <div class="max-w-3xl mx-auto">
              <SectionHeading
                eyebrow="The Deliverables."
                headline="What's Included."
                headingId="edesign-included-heading"
              />
              <ul class="mt-l grid grid-cols-1 sm:grid-cols-2 gap-y-m gap-x-l list-none p-0">
                {page.whatsIncluded.map((item: string) => (
                  <li class="flex items-start gap-s">
                    {/* Sage bullet — matches ServiceCard feature bullets */}
                    <span
                      class="mt-1.5 inline-block w-1.5 h-1.5 rounded-full bg-tertiary shrink-0"
                      aria-hidden="true"
                    ></span>
                    <span class="text-foreground/85">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      )}

      {/* ------- 5. Pricing Tiers -------------------------------------------- */}
      {page.tiers && page.tiers.length > 0 && (
        <section class="surface-warm bg-muted" aria-labelledby="edesign-tiers-heading">
          <div class="mx-auto max-w-content px-m py-section-lg">
            <SectionHeading
              eyebrow="The Tiers."
              headline="Choose the Right Package."
              headingId="edesign-tiers-heading"
              align="center"
              class="mx-auto"
            />

            <div class="mt-section-lg grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-l">
              {/* ServiceCard-style layout: brand stripe + name + price + bullets + best-for + CTA */}
              {page.tiers.map((tier: {
                name: string;
                price: string;
                features: string[];
                bestFor?: string;
                ctaLabel?: string;
              }) => (
                <article class="card-lift group relative flex flex-col h-full bg-card text-card-foreground border border-border-soft rounded-md overflow-hidden transition-colors hover:border-primary/40 shadow-[0_4px_18px_-14px_rgba(61,61,61,0.18)]">
                  <div class="h-0.5 bg-primary" aria-hidden="true"></div>
                  <div class="flex flex-col flex-1 p-l">
                    <header>
                      <h3 class="font-display text-h3 text-foreground">{tier.name}</h3>
                      <p class="mt-xs text-sm font-mono uppercase tracking-eyebrow text-link">
                        {tier.price}
                      </p>
                    </header>

                    {tier.features && tier.features.length > 0 && (
                      <ul class="mt-m space-y-1.5 text-sm text-foreground">
                        {tier.features.map((feature: string) => (
                          <li class="flex items-start gap-s">
                            <span
                              class="mt-1.5 inline-block w-1.5 h-1.5 rounded-full bg-tertiary shrink-0"
                              aria-hidden="true"
                            ></span>
                            <span>{feature}</span>
                          </li>
                        ))}
                      </ul>
                    )}

                    {tier.bestFor && (
                      <div class="mt-m pt-m border-t border-border-soft">
                        <p class="text-xs uppercase tracking-eyebrow text-foreground/80 mb-xs">Best for</p>
                        <p class="text-sm text-foreground/80 italic">{tier.bestFor}</p>
                      </div>
                    )}

                    <div class="mt-l pt-m flex-1 flex items-end">
                      <a
                        href={CONTACT_HREF}
                        class="inline-flex items-center min-h-[44px] py-s text-xs font-semibold uppercase tracking-eyebrow text-link hover:text-primary-dark transition-colors"
                      >
                        {tier.ctaLabel ?? 'Inquire about E-Design'} <span aria-hidden="true" class="ml-xs">→</span>
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* ------- 6. FAQ references ------------------------------------------- */}
      {page.faqRefs && page.faqRefs.length > 0 && (
        <section class="bg-background" aria-labelledby="edesign-faq-heading">
          <div class="mx-auto max-w-content px-m py-section-lg">
            <div class="max-w-3xl mx-auto">
              <SectionHeading
                eyebrow="Common Questions."
                headline="E-Design FAQ."
                headingId="edesign-faq-heading"
              />
              <div class="mt-l">
                {/* Flat list — no category grouping needed for a focused set of refs. */}
                <FaqAccordion
                  client:visible
                  faqs={page.faqRefs}
                  idPrefix="edesign-faq"
                />
              </div>
            </div>
          </div>
        </section>
      )}
    </>
  )}

  {/* ------- 7. Final CTA ---------------------------------------------------- */}
  {/* The dark FinalCta panel closes the page. When the eDesignPage doc has not
      been published yet, we render a fallback dark band that matches the same
      visual pattern (bronze stripe, Charcoal Dark bg, centered text + CTA).
      Once the doc is published, the Sanity-driven copy takes over. */}
  {page?.finalCta ? (
    <FinalCta
      eyebrow={page.finalCtaEyebrow}
      headline={page.finalCtaHeadline}
      subhead={page.finalCtaSubhead}
      cta={page.finalCta}
      scriptAccent={page.finalCtaScriptAccent}
      backgroundImage={page.finalCtaBackgroundImage}
    />
  ) : (
    <section class="bg-accent-dark text-bg" aria-labelledby="edesign-final-cta">
      <div class="h-0.5 bg-primary" aria-hidden="true"></div>
      <div class="mx-auto max-w-content px-m py-section-lg text-center">
        <p class="text-xs uppercase tracking-[0.22em] text-bg/75">Ready to Start?</p>
        <div class="mt-s mb-m h-px w-12 bg-bg/40 mx-auto" aria-hidden="true"></div>
        <h2 id="edesign-final-cta" class="font-display text-h1 leading-tight text-bg">
          Get a Room You Love From Wherever You Are.
        </h2>
        <p class="mt-m text-lg text-bg/85 max-w-2xl mx-auto">
          Reach out and we'll walk through what E-Design looks like for your space.
        </p>
        <div class="mt-l flex justify-center">
          <a
            href={CONTACT_HREF}
            class="press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s text-xs font-semibold uppercase tracking-[0.18em] rounded-sm bg-primary-dark text-white hover:bg-primary transition-colors"
          >
            Inquire about E-Design
          </a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
