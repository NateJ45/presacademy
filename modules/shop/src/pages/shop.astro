---
// Safe to edit by hand for copy + structure changes.
// Shop page. Affiliate product links organized into collections.
//
// FTC COMPLIANCE — non-negotiable, do not move or downplay:
//   The affiliate disclosure text (shopPage.disclosure) is rendered in a
//   prominent band ABOVE the first collection, not buried in the footer or
//   in small print. This is required by FTC guidelines for affiliate content.
//   All affiliate links carry rel="sponsored nofollow noopener" + target="_blank"
//   (enforced in ShopItemCard.astro).
//
// Sections:
//   1. Hero
//   2. FTC disclosure band (prominent, above all collections)
//   3. Intro copy (optional)
//   4. Collections + items via ShopGrid
//   5. Empty state / coming-soon state when no content or page is disabled

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getShopPage, getSiteSettings } from '@/lib/queries';
import { getSectionVisibility } from '@/lib/sectionVisibility';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';

import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ShopGrid from '@/components/ShopGrid.astro';

const [page, siteSettings] = await Promise.all([
  getShopPage().catch(() => null),
  getSiteSettings().catch(() => null),
]);

// Section visibility guard.
const visible = getSectionVisibility(siteSettings?.sectionVisibility);
if (!visible.shop) return Astro.redirect('/');

const title       = page?.seoTitle       ?? 'Shop Favorites · Studio Starter';
const description = page?.seoDescription ?? 'Hand-picked items the studio recommends. Some links are affiliate links.';

const heroEyebrow  = page?.heroEyebrow  ?? 'Shop Favorites.';
const heroHeadline = page?.heroHeadline ?? 'Things Worth Having.';
const heroSubhead  = page?.heroSubhead  ?? '';

// FTC disclosure: use Sanity content when present; always have a fallback so
// the legal requirement is met even before the doc is published.
const FTC_DISCLOSURE_FALLBACK =
  "Some links below are affiliate links. If you buy through them the studio may earn a small commission at no extra cost to you. We only share things we would genuinely recommend.";
const disclosure = page?.disclosure ?? FTC_DISCLOSURE_FALLBACK;

const collections = page?.collections ?? [];

// If `enabled` is explicitly false, render the page in a disabled/redirect state.
// A null `enabled` (doc not yet published) is treated as enabled — the page
// shows its coming-soon state instead of a hard redirect.
const isDisabled = page?.enabled === false;

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Shop', url: `${site.url}/shop` },
  ]),
];
---

<BaseLayout {title} {description} {schemas} {siteSettings} seoImage={page?.seoImage}>

  {/* ------- 1. Hero --------------------------------------------------------- */}
  <Hero
    eyebrow={heroEyebrow}
    headline={heroHeadline}
    subhead={heroSubhead}
    backgroundImage={page?.heroImage}
    headingId="shop-hero-heading"
    size="short"
    scriptAccent={page?.heroScriptAccent ?? undefined}
  />

  {/* Page disabled in Sanity: show a polite coming-soon rather than a 404. */}
  {isDisabled ? (
    <section class="bg-background" aria-labelledby="shop-disabled-heading">
      <div class="mx-auto max-w-content px-m py-section-lg text-center">
        <SectionHeading
          eyebrow="Coming Soon."
          headline="The shop is being refreshed."
          subhead="A fresh set of favorites is being curated. Check back soon."
          headingId="shop-disabled-heading"
          align="center"
          class="mx-auto"
        />
        <div class="mt-l flex justify-center">
          <a
            href="/"
            class="press-tactile inline-flex items-center justify-center min-h-[44px] px-l py-s text-xs font-semibold uppercase tracking-[0.18em] rounded-sm bg-primary-dark text-white hover:bg-accent-dark transition-colors"
          >
            Back to Home
          </a>
        </div>
      </div>
    </section>
  ) : (
    <>
      {/* ------- 2. FTC Disclosure band -------------------------------------- */}
      {/* This must appear prominently near the top of the page, above any
          affiliate links. FTC guidelines require clear and conspicuous
          disclosure before the consumer views the endorsed content. */}
      <aside
        aria-label="Affiliate disclosure"
        class="bg-muted border-y border-border-soft"
      >
        <div class="mx-auto max-w-content px-m py-m flex items-start gap-m">
          {/* Disclosure icon — a simple information indicator */}
          <svg
            aria-hidden="true"
            class="mt-px shrink-0 w-4 h-4 text-foreground/60"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
          <p class="text-sm text-foreground/80 leading-relaxed">
            {disclosure}
          </p>
        </div>
      </aside>

      {/* ------- 3. Intro copy (optional) ------------------------------------ */}
      {page?.intro && (
        <section class="bg-background" aria-labelledby="shop-intro-heading">
          <div class="mx-auto max-w-content px-m pt-section-md">
            <div class="max-w-2xl mx-auto text-center">
              <SectionHeading
                eyebrow="Studio Picks."
                headline="Things We Actually Use."
                headingId="shop-intro-heading"
                align="center"
                class="mx-auto"
              />
              <p class="mt-m text-foreground/80 text-lg leading-relaxed">
                {page.intro}
              </p>
            </div>
          </div>
        </section>
      )}

      {/* ------- 4. Collections + items -------------------------------------- */}
      {/* No collections: coming-soon empty state */}
      {collections.length > 0 ? (
        <ShopGrid collections={collections} />
      ) : (
        <section class="bg-background" aria-labelledby="shop-empty-heading">
          <div class="mx-auto max-w-content px-m py-section-lg text-center">
            <SectionHeading
              eyebrow="Coming Soon."
              headline="Picks are on the way."
              subhead="The studio is putting together its favorites. Check back soon."
              headingId="shop-empty-heading"
              align="center"
              class="mx-auto"
            />
          </div>
        </section>
      )}
    </>
  )}
</BaseLayout>
