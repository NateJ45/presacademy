---
// Safe to edit by hand for copy + structure changes.
// Process page. The "show, don't tell" page — walks visitors through the studio's steps so
// they know what working together actually feels like before they fill out the form.
//
// Sections:
//   1. Hero (text-only)
//   2. Process steps (4 detailed steps, full PortableText, features, tier notes)
//   3. FAQ block (only faqItems with alsoShowOnProcessPage = true)
//   4. Final CTA
//
// Steps and FAQs are auto-populated from their collections; the order is set in the
// individual documents (stepNumber for processStep, displayOrder for faqItem).

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getProcessPage, getSiteSettings } from '@/lib/queries';
import { breadcrumbSchema } from '@/lib/schemas';
import { site } from '@/data/site';

import Hero from '@/components/Hero.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ProcessStep from '@/components/ProcessStep.astro';
import FaqAccordion from '@/components/FaqAccordion';
import FinalCta from '@/components/FinalCta.astro';

const [page, siteSettings] = await Promise.all([
  getProcessPage().catch(() => null),
  getSiteSettings().catch(() => null),
]);

const title       = page?.seoTitle       ?? `The Process · ${site.name}`;
const description = page?.seoDescription ?? "From first call to final reveal -- here's exactly how working together unfolds.";

const heroEyebrow  = page?.heroEyebrow  ?? 'The Process.';
const heroHeadline = page?.heroHeadline ?? 'From First Call to Final Reveal.';
const heroSubhead  = page?.heroSubhead  ?? '';

const faqEyebrow  = page?.faqSectionEyebrow  ?? 'Common Questions.';
const faqHeadline = page?.faqSectionHeadline ?? 'Things People Ask Before We Start.';

const processSteps = page?.processSteps ?? [];
const faqs         = page?.faqs ?? [];

const schemas = [
  breadcrumbSchema([
    { name: 'Home', url: site.url },
    { name: 'Process', url: `${site.url}/process` },
  ]),
];
---

<BaseLayout {title} {description} {schemas} {siteSettings} seoImage={page?.seoImage}>
  {/* ------- 1. Hero --------------------------------------------------------- */}
  <Hero
    eyebrow={heroEyebrow}
    headline={heroHeadline}
    subhead={heroSubhead}
    backgroundImage={page?.heroImage}
    headingId="process-hero-heading"
    size="short"
    scriptAccent={page?.heroScriptAccent}
  />

  {/* ------- 2. Process steps ----------------------------------------------- */}
  <section
    class="bg-background"
    aria-label="Our process step by step"
  >
    <div class="mx-auto max-w-content px-m py-section-lg space-y-section-lg">
      {processSteps.map((step: any, i: number) => (
        <div class={i > 0 ? 'pt-section-lg border-t border-border-soft' : ''}>
          <ProcessStep step={step} variant="full" isLast={i === processSteps.length - 1} />
        </div>
      ))}
    </div>
  </section>

  {/* ------- 3. FAQ block --------------------------------------------------- */}
  {faqs.length > 0 && (
    <section
      class="bg-muted"
      aria-labelledby="process-faq-heading"
    >
      <div class="mx-auto max-w-content px-m py-section-lg">
        <SectionHeading
          eyebrow={faqEyebrow}
          headline={faqHeadline}
          headingId="process-faq-heading"
          align="center"
          class="mx-auto"
        />

        <div class="mt-section-lg max-w-3xl mx-auto">
          <FaqAccordion client:visible faqs={faqs} idPrefix="process-faq" />
        </div>

        <p class="mt-l text-center text-sm text-muted-foreground">
          More questions? <a href="/faq" class="text-link underline underline-offset-2 hover:text-primary-dark">See the full FAQ</a>.
        </p>
      </div>
    </section>
  )}

  {/* ------- 4. Final CTA ---------------------------------------------------- */}
  <FinalCta
    eyebrow={page?.finalCtaEyebrow}
    headline={page?.finalCtaHeadline}
    subhead={page?.finalCtaSubhead}
    cta={page?.finalCta}
    scriptAccent={page?.finalCtaScriptAccent}
    backgroundImage={page?.finalCtaBackgroundImage}
  />
</BaseLayout>
